{
  "name": "nikmcp",
  "version": "0.1.3",
  "description": "Custom Roblox Studio MCP server (dual-context): MCP stdio server + local HTTP bridge that the Studio edit plugin and F5 runtime agent poll. Drop-in superset of robloxstudio-mcp.",
  "type": "module",
  "bin": {
    "nikmcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc -p tsconfig.json --watch",
    "build:plugin": "node scripts/build-plugin.mjs",
    "selftest": "node tests/object-arg-regression.mjs",
    "selftest:chunk": "node tests/chunk-reassembly.mjs",
    "selftest:opencloud": "node tests/open-cloud-request.mjs",
    "selftest:apidump": "node tests/api-dump-validation.mjs",
    "selftest:luau": "node tests/luau-gate.mjs",
    "prepublishOnly": "npm run build",
    "selftest:sync": "node tests/sync-unit.mjs",
    "selftest:rocreate": "node tests/rocreate-unit.mjs"
  },
  "keywords": [
    "roblox",
    "roblox-studio",
    "mcp",
    "model-context-protocol",
    "luau",
    "claude",
    "ai"
  ],
  "author": "NiksPeak",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NiksPeak/NikMCP.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
