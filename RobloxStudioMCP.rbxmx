<roblox version="4">
 <Item class="Script" referent="RBX0">
  <Properties>
   <string name="Name">RobloxStudioMCP</string>
   <ProtectedString name="Source"><![CDATA[-- Roblox Studio MCP plugin entry point (edit context).
-- Server (Node bridge) is the source of truth; this plugin only probes, polls,
-- executes commands, and reports status. Dual-context: the F5 runtime agent
-- lives in RuntimeAgentSource.luau and is kept present in ServerScriptService
-- while armed, so any F5 (including Claude Code's auto-F5) is covered.
local HttpService = game:GetService("HttpService")
local ServerScriptService = game:GetService("ServerScriptService")
local ScriptEditorService = game:GetService("ScriptEditorService")

local Config = require(script.Config)
local Settings = require(script.Settings)
local Executor = require(script.Executor)
local StatusWidget = require(script.StatusWidget)
local RuntimeAgentSource = require(script.RuntimeAgentSource)

local CONTEXT = "edit"
local AGENT_NAME = "MCP_RuntimeAgent"
local SETTING_PORTS = "NikMCP_CandidatePorts_v2"
local SETTING_ARMED = "NikMCP_PlaytestArmed"
local SETTING_PORT_DIR = "NikMCP_PortDir"
local SETTING_SETTINGS = "NikMCP_Settings"
local SETTING_SELECTED = "NikMCP_SelectedPort"

-- == Candidate ports (persisted per-user; seeded with the auto-bind range) ====
local function loadPorts(): { number }
	local stored = plugin:GetSetting(SETTING_PORTS)
	if type(stored) == "table" then
		local out: { number } = {}
		for _, p in ipairs(stored) do
			if type(p) == "number" then
				table.insert(out, p)
			end
		end
		-- One-time rebase migration: a saved list whose base (first) port isn't the
		-- current DEFAULT_PORT predates the 49200->58741 rebase. Discard it so the
		-- dock defaults to 58741 like a fresh/published install. The reseed below is
		-- persisted, so once the base matches DEFAULT_PORT this never fires again and
		-- user-added chips survive normally.
		if #out > 0 and out[1] == Config.DEFAULT_PORT then
			return out
		end
	end
	-- fresh install (or post-rebase reset): seed the whole auto-bind range so each
	-- terminal's bridge has a chip, and persist it so the migration runs once.
	local seed: { number } = {}
	for _, p in ipairs(Config.CANDIDATE_PORTS) do
		table.insert(seed, p)
	end
	plugin:SetSetting(SETTING_PORTS, seed)
	return seed
end

local candidatePorts = loadPorts()
local function savePorts()
	plugin:SetSetting(SETTING_PORTS, candidatePorts)
end

local function loadArmed(): boolean
	local v = plugin:GetSetting(SETTING_ARMED)
	if type(v) == "boolean" then
		return v
	end
	return true -- default ON: F5 is covered out of the box
end

local function loadPortDir(): string
	local v = plugin:GetSetting(SETTING_PORT_DIR)
	return (v == "down") and "down" or "up" -- default "up"
end

-- Restore the last-selected port (must still be in the list), else the first.
local function loadSelectedPort(): number?
	local v = plugin:GetSetting(SETTING_SELECTED)
	if type(v) == "number" then
		for _, p in ipairs(candidatePorts) do
			if p == v then
				return v
			end
		end
	end
	return candidatePorts[1]
end

-- == Settings (tool gating + flags; plugin is source of truth) ===============
local function loadSettings(): { [string]: any }
	local raw = plugin:GetSetting(SETTING_SETTINGS)
	if type(raw) == "string" then
		local ok, decoded = pcall(function()
			return HttpService:JSONDecode(raw)
		end)
		if ok then
			return Settings.normalize(decoded)
		end
	end
	return Settings.normalize(raw) -- handles tables and nil
end

local settings = loadSettings()
local function saveSettings()
	local ok, json = pcall(function()
		return HttpService:JSONEncode(settings)
	end)
	if ok then
		plugin:SetSetting(SETTING_SETTINGS, json)
	end
end

-- Auth header (only when enabled + token set); nil otherwise.
local function authHeaders(): { [string]: string }?
	if settings.auth.enabled and settings.auth.token ~= "" then
		return { ["x-mcp-token"] = settings.auth.token }
	end
	return nil
end

-- == Connection state ========================================================
-- Each port is an INDEPENDENT, persistent connection with its own poll loop.
-- `connections[port]` exists while that port is connecting/connected; selection
-- is display-only (which connection the Status tab shows). Many can be live.
type Conn = {
	port: number,
	state: string, -- "connecting" | "connected"
	running: boolean, -- false = its loop should exit (Disconnect / unload)
	backoff: number,
	warned: string?, -- rate-limit: emit each state's diagnostic once
	serverAlive: boolean, -- this port's `server` flag from the poll/heartbeat (playtest live)
	commandsProven: boolean,
}
local connections: { [number]: Conn } = {}
local selectedPort: number? = loadSelectedPort()
local armed = loadArmed()
local lastEnsureOk = true -- did the most recent agent ensure/inject succeed?
local pluginRunning = true -- false on Unloading -> every connection loop exits

-- == Networking ============================================================
local function urlFor(port: number): string
	return ("http://127.0.0.1:%d"):format(port) -- always IPv4; localhost -> ::1 is refused on Windows
end

-- POST a finished command result back to the bridge. HttpService:PostAsync HARD-REJECTS
-- any request body > 1024 KB pre-flight (verified live), so an oversized result -- e.g. a
-- capture_viewport raw-RGBA payload (~3.7 MB) -- can never transmit in one POST and the
-- caller would hang to the Node timeout. Split anything over the slice size into ordered
-- parts sent to /response-chunk and reassembled bridge-side. Generic: any large result
-- (capture, big get_descendants, large get_script_source) takes this path automatically.
-- ponytail: 700 KB slice clears the 1024 KB cap with margin for the {id,seq,total} envelope;
-- base64/structured-JSON payloads barely expand when re-escaped. A pathologically
-- quote/backslash-dense >700 KB slice could approach the cap -- shrink CHUNK_SIZE if that
-- ever shows up (capture, the real driver, is base64 = zero expansion).
local CHUNK_SIZE = 700 * 1024
local function postResult(base: string, result: any)
	local payload = HttpService:JSONEncode(result)
	if #payload <= CHUNK_SIZE then
		pcall(function()
			HttpService:PostAsync(
				base .. "/response",
				payload,
				Enum.HttpContentType.ApplicationJson,
				false,
				authHeaders()
			)
		end)
		return
	end
	local total = math.ceil(#payload / CHUNK_SIZE)
	for seq = 0, total - 1 do
		local part = string.sub(payload, seq * CHUNK_SIZE + 1, (seq + 1) * CHUNK_SIZE)
		local body = HttpService:JSONEncode({ id = result.id, seq = seq, total = total, part = part })
		pcall(function()
			HttpService:PostAsync(
				base .. "/response-chunk",
				body,
				Enum.HttpContentType.ApplicationJson,
				false,
				authHeaders()
			)
		end)
	end
end

-- POST the current settings to ONE bridge (its own /settings). tokenOverride
-- forces a specific token header (used when disabling auth: the server still
-- requires the OLD token for that one request before it clears it).
local function pushSettingsTo(port: number, tokenOverride: string?)
	local ok, json = pcall(function()
		return HttpService:JSONEncode(settings)
	end)
	if not ok then
		return
	end
	local headers = authHeaders()
	if tokenOverride and tokenOverride ~= "" then
		headers = { ["x-mcp-token"] = tokenOverride }
	end
	pcall(function()
		HttpService:PostAsync(
			urlFor(port) .. "/settings",
			json,
			Enum.HttpContentType.ApplicationJson,
			false,
			headers
		)
	end)
end

-- Push current settings to every connected bridge (on any settings change).
local function pushSettingsAll(tokenOverride: string?)
	for port in pairs(connections) do
		pushSettingsTo(port, tokenOverride)
	end
end

local function backoffIntervalFor(conn: Conn): number
	local steps = Config.BACKOFF_STEPS
	local idx = math.min(conn.backoff, #steps)
	if idx < 1 then
		return Config.POLL_INTERVAL
	end
	return math.min(steps[idx], Config.BACKOFF_CAP)
end

-- == Playtest agent ========================================================
-- Full create-or-rewrite. Archivable so Play Solo (F5) clones it into the play
-- server DataModel; the agent is inert in edit (`if not RunService:IsRunning()`).
local function enablePlaytestAgent(port: number): (boolean, string?)
	local existing = ServerScriptService:FindFirstChild(AGENT_NAME)
	local agent = existing or Instance.new("Script")
	agent.Name = AGENT_NAME
	agent.Archivable = true
	agent.Parent = ServerScriptService -- parent before writing source (UpdateSourceAsync needs DataModel)
	agent:SetAttribute("McpPort", port)
	agent:SetAttribute("McpToken", (settings.auth.enabled and settings.auth.token) or "")

	local source = (RuntimeAgentSource:gsub("{{PORT}}", tostring(port)))
	local ok = pcall(function()
		ScriptEditorService:UpdateSourceAsync(agent, function()
			return source
		end)
	end)
	if ok then
		return true
	end
	-- fallback to .Source (edit context only); bind a local first (never lead with `(`)
	local target = agent :: any
	local fbOk, fbErr = pcall(function()
		target.Source = source
	end)
	if not fbOk then
		return false, tostring(fbErr)
	end
	return true
end

-- Idempotent: inject only when missing, so the poll loop never re-writes source
-- every tick. Present already => no-op (just keep Archivable true).
local function ensureAgent(port: number): boolean
	local existing = ServerScriptService:FindFirstChild(AGENT_NAME)
	if existing then
		existing.Archivable = true
		lastEnsureOk = true
		return true
	end
	local ok, err = enablePlaytestAgent(port)
	lastEnsureOk = ok
	if not ok then
		warn(("[NikMCP] playtest agent injection failed: %s"):format(tostring(err)))
	end
	return ok
end

local function removeAgent()
	local existing = ServerScriptService:FindFirstChild(AGENT_NAME)
	if existing then
		existing:Destroy()
	end
end

-- == UI / status widget ====================================================
local toolbar = plugin:CreateToolbar("Studio MCP")
local toggleButton = toolbar:CreateButton("MCP Status", "Show/hide the MCP status panel", "")
local agentButton = toolbar:CreateButton(
	"Playtest Agent",
	"Arm/disarm the F5 playtest agent. Armed: any F5 (incl. auto-F5) is covered. "
		.. "Note: while armed the agent Script saves with the place - disarm before publishing if you don't want it shipped.",
	""
)

local status = StatusWidget.new(plugin)
status.defaultPort = Config.DEFAULT_PORT -- used to suggest the first port when the list is empty
status:setDirection(loadPortDir()) -- persisted "+" suggestion direction (default "up")
toggleButton.Click:Connect(function()
	status:toggle()
end)

-- internal state is lowercase; the widget wants display-cased labels
local DISPLAY = { connected = "Connected", connecting = "Connecting", disconnected = "Disconnected" }

-- Compact target string for the Activity log (truncated).
local function activityTarget(cmd: any): string
	local p = cmd.payload or {}
	if type(p.path) == "string" then
		return p.path
	elseif type(p.parentPath) == "string" then
		return p.parentPath
	elseif type(p.paths) == "table" and #p.paths > 0 then
		local extra = #p.paths > 1 and (" +" .. tostring(#p.paths - 1)) or ""
		return tostring(p.paths[1]) .. extra
	elseif type(p.tag) == "string" then
		return "#" .. p.tag
	elseif type(p.query) == "string" then
		return "?" .. p.query
	elseif type(p.assetId) == "number" then
		return "asset " .. tostring(p.assetId)
	elseif type(p.code) == "string" then
		return (string.gsub(string.sub(p.code, 1, 40), "%s+", " "))
	end
	return ""
end

-- display state ("Connected"/"Connecting"/"Disconnected") for a port
local function stateDisplayOf(port: number?): string
	local c = port and connections[port]
	return (c and DISPLAY[c.state]) or "Disconnected"
end

-- Playtest agent row reflects the SELECTED port's heartbeat `server` flag.
local function refreshAgentRow()
	local sel = selectedPort and connections[selectedPort]
	if not armed then
		status:setAgentState("off") -- gray
	elseif not lastEnsureOk then
		status:setAgentState("error") -- red: armed but inject failed
	elseif sel and sel.serverAlive then
		status:setAgentState("active") -- green: playtest live on the selected port
	else
		status:setAgentState("armed") -- amber: armed, waiting for F5
	end
end

-- Push the whole UI from current state. Each chip shows its OWN connection
-- state; the address + four rows reflect the SELECTED port's connection.
local function render()
	local sel = selectedPort and connections[selectedPort]
	status:setConnectionState(stateDisplayOf(selectedPort))
	status:refreshPorts(candidatePorts)
	status:setSelectedPort(selectedPort)
	local states: { [number]: string } = {}
	for _, p in ipairs(candidatePorts) do
		states[p] = stateDisplayOf(p)
	end
	status:setPortStates(states)
	if sel and sel.state == "connected" then
		status:setHttp(true)
		status:setMcp(true)
		status:setCommands(sel.commandsProven and true or nil)
	else
		status:setHttp(nil) -- idle/gray when the selected port is not connected+live
		status:setMcp(nil)
		status:setCommands(nil)
	end
	refreshAgentRow()
end

local function firstConnectedPort(): number?
	return (next(connections))
end

local function countConnections(): number
	local n = 0
	for _ in pairs(connections) do
		n += 1
	end
	return n
end

local function setArmed(value: boolean)
	armed = value
	plugin:SetSetting(SETTING_ARMED, armed)
	agentButton:SetActive(armed)
	status:setArmed(armed)
	if armed then
		local port = selectedPort or firstConnectedPort() or Config.DEFAULT_PORT
		lastEnsureOk = enablePlaytestAgent(port)
		if not lastEnsureOk then
			warn("[NikMCP] could not arm playtest agent (source write failed)")
		end
	else
		removeAgent()
		lastEnsureOk = true
	end
	refreshAgentRow()
end

status.onArm = function()
	setArmed(not armed)
end

-- A connection answered -> Connected.
local function markConnected(conn: Conn)
	conn.state = "connected"
	conn.backoff = 0
	if armed then
		local agent = ServerScriptService:FindFirstChild(AGENT_NAME)
		if agent then
			agent:SetAttribute("McpPort", conn.port) -- point the agent at a live port
		end
	end
	if conn.warned ~= "connected" then
		conn.warned = "connected"
		print(("[NikMCP] connected on :%d"):format(conn.port))
	end
	pushSettingsTo(conn.port) -- this bridge enforces tool gating; refresh it on (re)connect
	render()
end

-- A connection stopped answering -> keep it, retry with backoff (Connecting).
-- Only THIS connection is affected; the others keep running.
local function markReconnecting(conn: Conn)
	conn.state = "connecting"
	conn.serverAlive = false
	conn.backoff += 1
	if conn.warned ~= "connecting" then
		conn.warned = "connecting"
		warn(("[NikMCP] :%d not answering; retrying with backoff. Start the Node server "
			.. "(npm start) and enable Allow HTTP Requests."):format(conn.port))
	end
	render()
end

-- Start an INDEPENDENT poll loop for `port` (no-op if already up).
local function startConnection(port: number)
	if connections[port] then
		return
	end
	local conn: Conn = {
		port = port,
		state = "connecting",
		running = true,
		backoff = 0,
		warned = nil,
		serverAlive = false,
		commandsProven = false,
	}
	connections[port] = conn
	render()

	-- Apply the merged liveness from a /poll response (server flag drives the
	-- Playtest-agent row); no separate per-tick heartbeat is needed.
	local function applyServerFlag(serverFlag: boolean)
		if serverFlag ~= conn.serverAlive then
			conn.serverAlive = serverFlag
			if port == selectedPort then
				refreshAgentRow()
			end
		end
	end

	task.spawn(function()
		local activeUntil = 0 -- os.clock() deadline for the faster POLL_ACTIVE cadence
		while conn.running and pluginRunning do
			-- Merged short-poll: one immediate GET carrying status + any command.
			local base = urlFor(port)
			local ok, body = pcall(function()
				return HttpService:GetAsync(base .. "/poll?context=" .. CONTEXT, true, authHeaders())
			end)
			if not conn.running then
				break
			end
			if not ok then
				markReconnecting(conn)
				task.wait(backoffIntervalFor(conn))
				continue
			end
			if conn.state ~= "connected" then
				markConnected(conn) -- answered: Connecting -> Connected
			end

			local decoded: any = nil
			if body and body ~= "" then
				local good, d = pcall(function()
					return HttpService:JSONDecode(body)
				end)
				if good then
					decoded = d
				end
			end
			applyServerFlag(decoded ~= nil and decoded.server == true)

			local cmd = decoded and decoded.command or nil
			if cmd and cmd.id then
				activeUntil = os.clock() + Config.ACTIVE_WINDOW -- snappier right after activity
				local result
				local startClock = os.clock()
				if cmd.type == "enable_playtest_agent" then
					setArmed(true) -- arming makes the agent persistent + F5-covered
					result = { ok = lastEnsureOk, output = lastEnsureOk and "playtest agent armed" or "arm failed" }
				else
					result = Executor.execute(cmd)
				end
				if result and result.ok == false then
					warn(("[NikMCP] command %q failed: %s")
						:format(tostring(cmd.type), tostring(result.err)))
				end
				if settings.activityLog then
					local ms = math.floor((os.clock() - startClock) * 1000 + 0.5)
					status:addActivity({
						tool = (":%d %s"):format(port, tostring(cmd.type)),
						target = activityTarget(cmd),
						ok = result.ok ~= false,
						ms = ms,
						time = os.time(),
					})
				end
				result.id = cmd.id
				postResult(base, result) -- chunks the POST if the result exceeds the 1024 KB PostAsync cap
				conn.commandsProven = true
				if port == selectedPort then
					status:setCommands(true)
				end
			end

			-- adaptive cadence: fast for ~2s after a command, else idle scaled by
			-- the number of connected ports (keeps total req-rate under the limit)
			local interval
			if os.clock() < activeUntil then
				interval = Config.POLL_ACTIVE
			else
				interval = math.max(Config.POLL_IDLE, 0.15 * countConnections())
			end
			task.wait(interval)
		end
		-- loop ended (Disconnect / removed / unload): clear iff still ours
		if connections[port] == conn then
			connections[port] = nil
		end
		render()
	end)
end

-- Stop a port's loop (Disconnect / remove). Removes it immediately so the UI
-- updates now; the loop sees running=false and exits on its next check.
local function stopConnection(port: number)
	local conn = connections[port]
	if conn then
		conn.running = false
		connections[port] = nil
	end
end

-- == Port chips: select (display-only) / add / remove ======================
-- Selection NEVER touches any connection's running state.
status.onSelectPort = function(port: number)
	if port == selectedPort then
		return
	end
	selectedPort = port
	plugin:SetSetting(SETTING_SELECTED, port)
	render()
end

status.onAddPort = function(port: number)
	local exists = false
	for _, p in ipairs(candidatePorts) do
		if p == port then
			exists = true
			break
		end
	end
	if not exists then
		table.insert(candidatePorts, port)
		savePorts()
	end
	selectedPort = port -- newly added (or existing) port becomes selected (still its own state)
	plugin:SetSetting(SETTING_SELECTED, port)
	render()
end

status.onRemovePort = function(port: number)
	local idx
	for i, p in ipairs(candidatePorts) do
		if p == port then
			idx = i
			break
		end
	end
	if not idx then
		return
	end
	stopConnection(port) -- if it was connected, stop just that loop first
	table.remove(candidatePorts, idx)
	if #candidatePorts == 0 then
		table.insert(candidatePorts, Config.DEFAULT_PORT) -- never leave the list empty
	end
	savePorts()
	if selectedPort == port then
		selectedPort = candidatePorts[math.min(idx, #candidatePorts)] or candidatePorts[1]
		if selectedPort then
			plugin:SetSetting(SETTING_SELECTED, selectedPort)
		end
	end
	render()
end

-- == Settings callbacks from the dock (persist + re-push to ALL bridges) ======
status.onToggleTool = function(name: string, value: boolean)
	settings.tools[name] = value
	saveSettings()
	pushSettingsAll()
end

status.onSetFlag = function(key: string, value: boolean)
	settings[key] = value
	saveSettings()
	pushSettingsAll()
	if key == "soundEnabled" then
		status:setSoundEnabled(value)
	end
end

-- Numeric settings (playtest auto-stop thresholds).
status.onSetNumber = function(key: string, value: number)
	settings[key] = value
	saveSettings()
	pushSettingsAll()
end

status.onSetAuth = function(enabled: boolean, token: string)
	local wasEnabled = settings.auth.enabled
	local oldToken = settings.auth.token
	settings.auth.enabled = enabled
	settings.auth.token = token
	saveSettings()
	if (not enabled) and wasEnabled and oldToken ~= "" then
		pushSettingsAll(oldToken) -- disabling: bridges still require the old token for this push
	else
		pushSettingsAll() -- enabling adopts via TOFU; token edits re-push with the live header
	end
end

-- == Connect / Disconnect primary button (acts on the SELECTED port only) =====
status.onPrimary = function()
	if not selectedPort then
		return
	end
	if connections[selectedPort] then
		stopConnection(selectedPort)
		print(("[NikMCP] disconnected :%d"):format(selectedPort))
		render()
	else
		startConnection(selectedPort)
	end
end

-- == Toolbar: arm/disarm playtest agent ====================================
agentButton.Click:Connect(function()
	setArmed(not armed)
end)

-- == Startup: restore selection, sync armed + settings; stay DISCONNECTED ====
status:setSettings(settings)
status:setSoundEnabled(settings.soundEnabled)
setArmed(armed)
render() -- shows the restored selected port, all Disconnected (no auto-connect)

-- == Global maintenance loop: keep the armed agent present + agent row fresh ==
-- (Runs even with zero connections; each connection runs its own poll loop.)
task.spawn(function()
	while pluginRunning do
		if armed then
			ensureAgent(selectedPort or firstConnectedPort() or Config.DEFAULT_PORT)
		end
		-- A live server context (F5 agent polling) counts as playtest activity,
		-- so a watched run isn't auto-stopped for idleness.
		for _, conn in pairs(connections) do
			if conn.serverAlive then
				Executor.notePlaytestActivity()
				break
			end
		end
		-- Auto-stop safety net: an abandoned Run-mode playtest started via
		-- playtest_control never leaves Studio stuck in Run.
		local stoppedReason = Executor.maybeAutoStopPlaytest({
			enabled = settings.playtestAutoStop,
			maxSeconds = settings.playtestMaxSeconds,
			idleSeconds = settings.playtestIdleSeconds,
		})
		if stoppedReason then
			warn("[NikMCP] auto-stopped idle playtest (" .. stoppedReason .. ")")
		end
		refreshAgentRow()
		task.wait(1)
	end
end)

plugin.Unloading:Connect(function()
	pluginRunning = false
	for _, conn in pairs(connections) do
		conn.running = false
	end
end)
]]></ProtectedString>
   <token name="RunContext">0</token>
  </Properties>
  <Item class="ModuleScript" referent="RBX1">
   <Properties>
    <string name="Name">Config</string>
    <ProtectedString name="Source"><![CDATA[--!strict
-- Keep DEFAULT_PORT in sync with the Node default (src/config.ts).
local Config = {}

Config.DEFAULT_PORT = 58741 -- boshyxd robloxstudio-mcp's port (drop-in replacement)
-- The Node bridge auto-binds the first free port in [DEFAULT_PORT, +PORT_RANGE)
-- so each terminal gets its own bridge. Seed the chip list with that whole range
-- so the user can connect to each terminal. Default seed only; the edit plugin
-- persists the live list per-user (plugin:SetSetting) so add/remove survives restarts.
Config.PORT_RANGE = 20
Config.CANDIDATE_PORTS = {}
for i = 0, Config.PORT_RANGE - 1 do
	table.insert(Config.CANDIDATE_PORTS, Config.DEFAULT_PORT + i)
end

-- Poll cadence while connected (seconds). Merged short-poll (no held requests):
-- one /poll per cycle carrying status + any command.
Config.POLL_INTERVAL = 0.25 -- legacy (runtime agent uses its own constant)
Config.POLL_IDLE = 0.5 -- normal cadence per connection
Config.POLL_ACTIVE = 0.2 -- faster for ~2s after a command, then back to idle
Config.ACTIVE_WINDOW = 2.0 -- seconds to stay on POLL_ACTIVE after a command
Config.HEARTBEAT_INTERVAL = 1.0

-- Reconnect backoff (seconds). Climb the steps, then hold at the cap
-- until a probe succeeds; reset to POLL_INTERVAL on connect.
Config.BACKOFF_STEPS = { 0.25, 0.5, 1, 2 }
Config.BACKOFF_CAP = 5

return Config
]]></ProtectedString>
   </Properties>
  </Item>
  <Item class="ModuleScript" referent="RBX2">
   <Properties>
    <string name="Name">Settings</string>
    <ProtectedString name="Source"><![CDATA[--!strict
-- Settings model shared by the edit plugin (persistence + push) and the dock UI.
-- The plugin is the source of truth; the Node server enforces these so a disabled
-- tool can't run even if a client calls it. Default: every tool enabled.
local Settings = {}

-- Tool catalog (ordered for the UI). `group` drives the Read/Write/Experimental
-- headers; names MUST match the server's registerTool names + WRITE_TOOLS set.
Settings.TOOLS = {
	-- read / inspect
	{ name = "get_instance_tree", group = "read", label = "Instance tree" },
	{ name = "read_console", group = "read", label = "Read console" },
	{ name = "get_selection", group = "read", label = "Get selection" },
	{ name = "search_instances", group = "read", label = "Search instances" },
	{ name = "get_script_source", group = "read", label = "Get script source" },
	{ name = "list_scripts", group = "read", label = "List scripts" },
	{ name = "get_place_info", group = "read", label = "Place info" },
	{ name = "get_tagged", group = "read", label = "Get tagged" },
	{ name = "get_properties", group = "read", label = "Get properties (curated)" },
	{ name = "get_attribute", group = "read", label = "Get attribute" },
	{ name = "get_attributes", group = "read", label = "Get attributes" },
	{ name = "grep_scripts", group = "read", label = "Grep scripts" },
	{ name = "get_script_analysis", group = "read", label = "Script analysis" },
	{ name = "mass_get_property", group = "read", label = "Mass get property" },
	{ name = "get_class_info", group = "read", label = "Class info" },
	{ name = "get_services", group = "read", label = "Get services" },
	{ name = "get_descendants", group = "read", label = "Get descendants" },
	{ name = "get_connected_instances", group = "read", label = "Connected instances" },
	{ name = "compare_instances", group = "read", label = "Compare instances" },
	{ name = "get_project_structure", group = "read", label = "Project structure" },
	{ name = "get_file_tree", group = "read", label = "File tree" },
	{ name = "search_by_property", group = "read", label = "Search by property" },
	{ name = "get_tags", group = "read", label = "Get tags" },
	-- write / edit (read-only mode blocks these)
	{ name = "run_luau", group = "write", label = "Run Luau" },
	{ name = "set_property", group = "write", label = "Set property" },
	{ name = "write_script", group = "write", label = "Write script" },
	{ name = "set_selection", group = "write", label = "Set selection" },
	{ name = "create_instance", group = "write", label = "Create instance" },
	{ name = "delete_instance", group = "write", label = "Delete instance" },
	{ name = "clone_instance", group = "write", label = "Clone instance" },
	{ name = "rename_instance", group = "write", label = "Rename instance" },
	{ name = "set_parent", group = "write", label = "Set parent" },
	{ name = "move_instance", group = "write", label = "Move instance" },
	{ name = "bulk_set_property", group = "write", label = "Bulk set property" },
	{ name = "tag_instance", group = "write", label = "Tag instance" },
	{ name = "untag_instance", group = "write", label = "Untag instance" },
	{ name = "insert_asset", group = "write", label = "Insert asset" },
	{ name = "set_attribute", group = "write", label = "Set attribute" },
	{ name = "set_attributes", group = "write", label = "Set attributes" },
	{ name = "delete_attribute", group = "write", label = "Delete attribute" },
	{ name = "edit_script_lines", group = "write", label = "Edit script lines" },
	{ name = "insert_script_lines", group = "write", label = "Insert script lines" },
	{ name = "delete_script_lines", group = "write", label = "Delete script lines" },
	{ name = "find_and_replace_in_scripts", group = "write", label = "Find & replace in scripts" },
	{ name = "undo", group = "write", label = "Undo" },
	{ name = "redo", group = "write", label = "Redo" },
	{ name = "mass_create_objects", group = "write", label = "Mass create objects" },
	{ name = "mass_duplicate", group = "write", label = "Mass duplicate" },
	{ name = "smart_duplicate", group = "write", label = "Smart duplicate" },
	{ name = "mass_set_property", group = "write", label = "Mass set property" },
	{ name = "set_properties", group = "write", label = "Set properties (multi)" },
	{ name = "enable_playtest_agent", group = "write", label = "Enable playtest agent" },
	-- assets / marketplace
	{ name = "get_asset_details", group = "assets", label = "Asset details" },
	{ name = "get_asset_thumbnail", group = "assets", label = "Asset thumbnail" },
	{ name = "preview_asset", group = "assets", label = "Preview asset" },
	{ name = "search_materials", group = "assets", label = "Search materials" },
	{ name = "search_assets", group = "assets", label = "Search assets (Open Cloud)" },
	{ name = "list_library", group = "assets", label = "List library (Open Cloud)" },
	{ name = "upload_decal", group = "assets", label = "Upload decal (Open Cloud)" },
	-- experimental (may be unsupported from a plugin; see Phase D)
	{ name = "capture_viewport", group = "experimental", label = "Capture viewport" },
	{ name = "playtest_control", group = "experimental", label = "Playtest control" },
	{ name = "get_playtest_output", group = "experimental", label = "Get playtest output" },
	{ name = "simulate_keyboard_input", group = "experimental", label = "Simulate keyboard" },
	{ name = "simulate_mouse_input", group = "experimental", label = "Simulate mouse" },
	{ name = "character_navigation", group = "experimental", label = "Character navigation" },
	{ name = "play_animation", group = "experimental", label = "Play animation (server)" },
	-- build / scene / view (Task 16)
	{ name = "export_build", group = "scene", label = "Export build" },
	{ name = "create_build", group = "scene", label = "Create build" },
	{ name = "import_build", group = "scene", label = "Import build" },
	{ name = "generate_build", group = "scene", label = "Generate build" },
	{ name = "create_keyframe_sequence", group = "scene", label = "Create keyframe sequence" },
	{ name = "create_sound", group = "scene", label = "Create sound" },
	{ name = "set_lighting", group = "scene", label = "Set lighting" },
	{ name = "import_scene", group = "scene", label = "Import scene" },
	{ name = "create_ui_tree", group = "scene", label = "Create UI tree" },
	{ name = "search_files", group = "scene", label = "Search files (names/paths)" },
	{ name = "raycast", group = "scene", label = "Raycast" },
	{ name = "get_bounding_box", group = "scene", label = "Bounding box" },
	{ name = "get_selection_bounds", group = "scene", label = "Selection bounds" },
	{ name = "get_camera", group = "scene", label = "Get camera" },
	{ name = "set_camera", group = "scene", label = "Set camera (view)" },
	{ name = "focus_instance", group = "scene", label = "Focus instance" },
	{ name = "get_perf_stats", group = "scene", label = "Perf stats" },
	{ name = "group_instances", group = "scene", label = "Group instances" },
	{ name = "ungroup_instance", group = "scene", label = "Ungroup instance" },
	{ name = "align_instances", group = "scene", label = "Align instances" },
	{ name = "measure_distance", group = "scene", label = "Measure distance" },
}

-- ordered group headers for the Settings UI
Settings.GROUPS = {
	{ key = "read", label = "Read tools" },
	{ key = "write", label = "Write tools" },
	{ key = "assets", label = "Assets / marketplace" },
	{ key = "experimental", label = "Experimental" },
	{ key = "scene", label = "Build / scene / view" },
}

function Settings.default(): { [string]: any }
	local tools: { [string]: boolean } = {}
	for _, t in ipairs(Settings.TOOLS) do
		tools[t.name] = true
	end
	return {
		tools = tools,
		readOnly = false,
		confirmDestructive = false,
		auth = { enabled = false, token = "" },
		soundEnabled = true,
		activityLog = true,
		-- Task 17: auto-stop an abandoned Run-mode playtest started via playtest_control.
		playtestAutoStop = true,
		playtestMaxSeconds = 300,
		playtestIdleSeconds = 120,
	}
end

-- Merge a (possibly partial / stale) stored table onto fresh defaults so new
-- tools added later default ON and missing/garbage fields are coerced.
function Settings.normalize(stored: any): { [string]: any }
	local s = Settings.default()
	if type(stored) ~= "table" then
		return s
	end
	if type(stored.tools) == "table" then
		for _, t in ipairs(Settings.TOOLS) do
			if type(stored.tools[t.name]) == "boolean" then
				s.tools[t.name] = stored.tools[t.name]
			end
		end
	end
	if type(stored.readOnly) == "boolean" then
		s.readOnly = stored.readOnly
	end
	if type(stored.confirmDestructive) == "boolean" then
		s.confirmDestructive = stored.confirmDestructive
	end
	if type(stored.auth) == "table" then
		if type(stored.auth.enabled) == "boolean" then
			s.auth.enabled = stored.auth.enabled
		end
		if type(stored.auth.token) == "string" then
			s.auth.token = stored.auth.token
		end
	end
	if type(stored.soundEnabled) == "boolean" then
		s.soundEnabled = stored.soundEnabled
	end
	if type(stored.activityLog) == "boolean" then
		s.activityLog = stored.activityLog
	end
	if type(stored.playtestAutoStop) == "boolean" then
		s.playtestAutoStop = stored.playtestAutoStop
	end
	if type(stored.playtestMaxSeconds) == "number" and stored.playtestMaxSeconds > 0 then
		s.playtestMaxSeconds = stored.playtestMaxSeconds
	end
	if type(stored.playtestIdleSeconds) == "number" and stored.playtestIdleSeconds > 0 then
		s.playtestIdleSeconds = stored.playtestIdleSeconds
	end
	return s
end

return Settings
]]></ProtectedString>
   </Properties>
  </Item>
  <Item class="ModuleScript" referent="RBX3">
   <Properties>
    <string name="Name">Serializer</string>
    <ProtectedString name="Source"><![CDATA[--!strict
-- Bidirectional conversion between Roblox datatypes and JSON-safe tables.
-- Tagged form: { __t = "Vector3", x = ..., y = ..., z = ... }
local Serializer = {}

function Serializer.serialize(value: any): any
	local t = typeof(value)
	if t == "Vector3" then
		return { __t = "Vector3", x = value.X, y = value.Y, z = value.Z }
	elseif t == "Vector2" then
		return { __t = "Vector2", x = value.X, y = value.Y }
	elseif t == "CFrame" then
		return { __t = "CFrame", comps = { value:GetComponents() } }
	elseif t == "Color3" then
		return { __t = "Color3", r = value.R, g = value.G, b = value.B }
	elseif t == "UDim2" then
		local s, o = value.X, value.Y
		return { __t = "UDim2", xs = s.Scale, xo = s.Offset, ys = o.Scale, yo = o.Offset }
	elseif t == "UDim" then
		return { __t = "UDim", scale = value.Scale, offset = value.Offset }
	elseif t == "EnumItem" then
		return { __t = "EnumItem", enum = tostring(value.EnumType), name = value.Name }
	elseif t == "Instance" then
		return { __t = "Instance", className = value.ClassName, name = value.Name, path = value:GetFullName() }
	elseif t == "table" then
		local out: { [any]: any } = {}
		for k, v in pairs(value) do
			out[k] = Serializer.serialize(v)
		end
		return out
	else
		-- string | number | boolean | nil pass through
		return value
	end
end

function Serializer.deserialize(value: any): any
	if type(value) ~= "table" then
		return value
	end
	local tag = value.__t
	if tag == "Vector3" then
		return Vector3.new(value.x, value.y, value.z)
	elseif tag == "Vector2" then
		return Vector2.new(value.x, value.y)
	elseif tag == "CFrame" then
		return CFrame.new(table.unpack(value.comps))
	elseif tag == "Color3" then
		return Color3.new(value.r, value.g, value.b)
	elseif tag == "UDim2" then
		return UDim2.new(value.xs, value.xo, value.ys, value.yo)
	elseif tag == "UDim" then
		return UDim.new(value.scale, value.offset)
	elseif tag == "EnumItem" then
		local enumName = (value.enum :: string):gsub("^Enum%.", "")
		local enums = Enum :: any
		return enums[enumName][value.name]
	else
		return value -- plain table
	end
end

return Serializer
]]></ProtectedString>
   </Properties>
  </Item>
  <Item class="ModuleScript" referent="RBX4">
   <Properties>
    <string name="Name">Executor</string>
    <ProtectedString name="Source"><![CDATA[-- Executes commands against the DataModel. Used by the edit plugin.
-- (The runtime agent inlines a minimal version; the tools added in Task 5 are
-- edit-context handlers. During a live playtest, auto routes to the server agent,
-- which only supports run_luau / get_instance_tree and returns a clean
-- "agent does not support command" error for the rest.)
local ChangeHistoryService = game:GetService("ChangeHistoryService")
local RunService = game:GetService("RunService")
local ScriptEditorService = game:GetService("ScriptEditorService")
local StudioTestService = game:GetService("StudioTestService")
local ServerScriptService = game:GetService("ServerScriptService")
local TestService = game:GetService("TestService")
local CollectionService = game:GetService("CollectionService")
local LogService = game:GetService("LogService")
local Selection = game:GetService("Selection")
local InsertService = game:GetService("InsertService")
local AssetService = game:GetService("AssetService")
local CaptureService = game:GetService("CaptureService")
local MarketplaceService = game:GetService("MarketplaceService")
local Stats = game:GetService("Stats")
local Serializer = require(script.Parent.Serializer)

local Executor = {}

-- Resolve a dot-path like "game.Workspace.Foo" to an Instance, or nil.
local function resolvePath(path: string): Instance?
	if path == "" or path == "game" then
		return game
	end
	local node: Instance? = game
	for segment in string.gmatch(path, "[^%.]+") do
		if segment == "game" then
			continue
		end
		if not node then
			return nil
		end
		node = node:FindFirstChild(segment)
	end
	return node
end

local function pathInfo(inst: Instance): any
	return { path = inst:GetFullName(), className = inst.ClassName, name = inst.Name }
end

-- Run a mutation wrapped in one ChangeHistory recording (edit context only).
-- Returns (ok, returnedValueOrError).
local function recorded(label: string, fn: () -> any): (boolean, any)
	local inEdit = not RunService:IsRunning()
	local recording: any = nil
	if inEdit then
		recording = ChangeHistoryService:TryBeginRecording(label)
	end
	local ok, ret = pcall(fn)
	if inEdit and recording then
		ChangeHistoryService:FinishRecording(
			recording,
			ok and Enum.FinishRecordingOperation.Commit or Enum.FinishRecordingOperation.Cancel
		)
	end
	return ok, ret
end

-- == Console ring buffer (feeds read_console) ================================
local CONSOLE_CAP = 500
local consoleRing: { { text: string, level: string, t: number } } = {}
local function pushConsole(text: string, level: string, t: number)
	table.insert(consoleRing, { text = text, level = level, t = t })
	if #consoleRing > CONSOLE_CAP then
		table.remove(consoleRing, 1)
	end
end
-- seed once from history, then keep it live
local function seedConsole()
	local ok, history = pcall(function()
		return LogService:GetLogHistory()
	end)
	if ok and type(history) == "table" then
		for _, e in ipairs(history) do
			pushConsole(tostring(e.message), e.messageType.Name, e.timestamp or 0)
		end
	end
end
seedConsole()
-- Playtest log ring (feeds get_playtest_output). Only fills while capturing
-- (set by playtest_control start/stop) so it isolates a single playtest run.
local PLAYTEST_CAP = 1000
local playtestRing: { { text: string, level: string, t: number } } = {}
local playtestCapturing = false
-- Lifecycle tracking for get_playtest_status + the auto-stop safety net. Only
-- set when a Run-mode playtest is started via playtest_control (we never auto-stop
-- a user-initiated F5/Play). startedAt = unix start; lastActivity bumps on
-- get_playtest_output and on any live server-context poll.
local playtestStartedAt: number? = nil
local playtestLastActivity: number = 0
local function pushPlaytest(text: string, level: string, t: number)
	if not playtestCapturing then
		return
	end
	table.insert(playtestRing, { text = text, level = level, t = t })
	if #playtestRing > PLAYTEST_CAP then
		table.remove(playtestRing, 1)
	end
end
LogService.MessageOut:Connect(function(message, messageType)
	local t = os.time()
	pushConsole(tostring(message), messageType.Name, t)
	pushPlaytest(tostring(message), messageType.Name, t)
end)

-- loadstring + captured print/warn. Available at PluginSecurity (edit);
-- requires LoadStringEnabled in server runtime context.
local function runLuau(code: string): { ok: boolean, output: string, result: any?, err: string? }
	local buffer: { string } = {}
	local function capture(...)
		local n = select("#", ...)
		local parts = table.create(n)
		for i = 1, n do
			parts[i] = tostring((select(i, ...)))
		end
		table.insert(buffer, table.concat(parts, "\t"))
	end

	local chunk, compileErr = loadstring(code)
	if not chunk then
		return { ok = false, output = "", err = "compile error: " .. tostring(compileErr) }
	end

	-- Sandbox env: capture print/warn, fall through to real globals otherwise.
	local env = setmetatable({ print = capture, warn = capture }, { __index = getfenv() })
	setfenv(chunk, env)

	local packed = table.pack(pcall(chunk))
	local ok = packed[1]
	local output = table.concat(buffer, "\n")
	if not ok then
		return { ok = false, output = output, err = tostring(packed[2]) }
	end
	local result: any? = nil
	if packed.n > 1 then
		result = Serializer.serialize(packed[2])
	end
	return { ok = true, output = output, result = result }
end

local function getInstanceTree(path: string, maxDepth: number): any
	local root = resolvePath(path)
	if not root then
		return { ok = false, err = "path not found: " .. path }
	end
	local function walk(inst: Instance, depth: number): any
		local node = { name = inst.Name, className = inst.ClassName, children = {} :: { any } }
		if depth < maxDepth then
			for _, child in ipairs(inst:GetChildren()) do
				table.insert(node.children, walk(child, depth + 1))
			end
		end
		return node
	end
	return { ok = true, result = walk(root, 0) }
end

local function setProperty(path: string, property: string, rawValue: any): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	local value = Serializer.deserialize(rawValue)
	local inEdit = not RunService:IsRunning()
	local recording: any = nil
	if inEdit then
		recording = ChangeHistoryService:TryBeginRecording("set_property:" .. property)
	end
	local ok, err = pcall(function()
		local target = inst :: any
		target[property] = value
	end)
	if inEdit and recording then
		ChangeHistoryService:FinishRecording(
			recording,
			ok and Enum.FinishRecordingOperation.Commit or Enum.FinishRecordingOperation.Cancel
		)
	end
	if not ok then
		return { ok = false, err = tostring(err) }
	end
	return { ok = true, output = ("set %s.%s"):format(path, property) }
end

-- Edit-only: write script source via the officially supported API.
local function writeScript(path: string, source: string, className: string?): any
	if RunService:IsRunning() then
		return { ok = false, err = "write_script is edit-context only" }
	end
	local inst = resolvePath(path)
	if not inst and className then
		-- create at the parent path; last segment is the new name
		local parentPath, name = string.match(path, "^(.*)%.([^%.]+)$")
		local parent = parentPath and resolvePath(parentPath) or game:GetService("ServerScriptService")
		if not parent then
			return { ok = false, err = "parent path not found for " .. path }
		end
		local created = Instance.new(className)
		created.Name = name or "NewScript"
		created.Parent = parent
		inst = created
	end
	if not inst then
		return { ok = false, err = "path not found and no className to create: " .. path }
	end
	local recording = ChangeHistoryService:TryBeginRecording("write_script")
	local ok, err = pcall(function()
		ScriptEditorService:UpdateSourceAsync(inst, function()
			return source
		end)
	end)
	if recording then
		ChangeHistoryService:FinishRecording(
			recording,
			ok and Enum.FinishRecordingOperation.Commit or Enum.FinishRecordingOperation.Cancel
		)
	end
	if not ok then
		return { ok = false, err = tostring(err) }
	end
	return { ok = true, output = "wrote source to " .. inst:GetFullName() }
end

-- == Phase B: read / inspect ================================================
local LEVEL_MATCH = {
	error = "MessageError",
	warning = "MessageWarning",
	output = "MessageOutput",
}

local function readConsole(count: number, levelFilter: string?): any
	local want = levelFilter and LEVEL_MATCH[levelFilter] or nil
	local picked = {}
	for i = #consoleRing, 1, -1 do
		local e = consoleRing[i]
		if not want or e.level == want then
			table.insert(picked, 1, e)
			if #picked >= count then
				break
			end
		end
	end
	return { ok = true, result = { lines = picked, total = #consoleRing } }
end

local function getSelection(): any
	local out = {}
	for _, inst in ipairs(Selection:Get()) do
		table.insert(out, pathInfo(inst))
	end
	return { ok = true, result = out }
end

local function searchInstances(p: any): any
	local root = resolvePath(p.root or "game") or game
	local query = p.query and string.lower(tostring(p.query)) or nil
	local className = p.className
	local tag = p.tag
	local limit = p.limit or 100
	local out = {}
	local function matches(inst: Instance): boolean
		if className then
			local okc, isa = pcall(function()
				return inst:IsA(className)
			end)
			if not okc or not isa then
				return false
			end
		end
		if query and not string.find(string.lower(inst.Name), query, 1, true) then
			return false
		end
		return true
	end
	if tag then
		for _, inst in ipairs(CollectionService:GetTagged(tag)) do
			if (root == game or inst:IsDescendantOf(root)) and matches(inst) then
				table.insert(out, pathInfo(inst))
				if #out >= limit then
					break
				end
			end
		end
	else
		for _, inst in ipairs(root:GetDescendants()) do
			if matches(inst) then
				table.insert(out, pathInfo(inst))
				if #out >= limit then
					break
				end
			end
		end
	end
	return { ok = true, result = out }
end

local function getScriptSource(path: string): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	if not inst:IsA("LuaSourceContainer") then
		return { ok = false, err = path .. " is not a script (" .. inst.ClassName .. ")" }
	end
	local src: any = nil
	local ok = pcall(function()
		src = ScriptEditorService:GetEditorSource(inst)
	end)
	if not ok or src == nil then
		local ok2 = pcall(function()
			local target = inst :: any
			src = target.Source
		end)
		if not ok2 then
			return { ok = false, err = "could not read source of " .. path }
		end
	end
	return { ok = true, result = { path = inst:GetFullName(), source = src } }
end

local function listScripts(rootPath: string): any
	local root = resolvePath(rootPath or "game") or game
	local out = {}
	for _, inst in ipairs(root:GetDescendants()) do
		if inst:IsA("LuaSourceContainer") then
			table.insert(out, pathInfo(inst))
		end
	end
	return { ok = true, result = out }
end

local function getPlaceInfo(): any
	local KEY_SERVICES = {
		"Workspace", "Players", "ReplicatedStorage", "ReplicatedFirst",
		"ServerScriptService", "ServerStorage", "StarterGui", "StarterPack",
		"StarterPlayer", "Lighting", "SoundService", "Teams",
	}
	local services = {}
	for _, n in ipairs(KEY_SERVICES) do
		local found = false
		pcall(function()
			found = game:FindService(n) ~= nil
		end)
		services[n] = found
	end
	local counts = {}
	for _, child in ipairs(game:GetChildren()) do
		counts[child.Name] = #child:GetChildren()
	end
	local cam = workspace.CurrentCamera
	return {
		ok = true,
		result = {
			placeId = game.PlaceId,
			gameId = game.GameId,
			placeName = game.Name,
			services = services,
			topLevelCounts = counts,
			selectionCount = #Selection:Get(),
			camera = cam and Serializer.serialize(cam.CFrame) or nil,
		},
	}
end

local function getTagged(tag: string): any
	local out = {}
	for _, inst in ipairs(CollectionService:GetTagged(tag)) do
		table.insert(out, pathInfo(inst))
	end
	return { ok = true, result = out }
end

-- Curated common-property dump (Luau has no full reflection). Optional explicit
-- propertyNames overrides the curated set.
local CURATED_PROPS = {
	"Archivable", "Position", "Size", "CFrame", "Orientation", "Anchored",
	"CanCollide", "CanTouch", "CanQuery", "Transparency", "Reflectance",
	"Color", "BrickColor", "Material", "CastShadow", "Massless",
	"Enabled", "Visible", "Active", "Text", "TextColor3", "TextScaled",
	"BackgroundColor3", "BackgroundTransparency", "Image", "Value",
	"Adornee", "Locked", "AssetId", "SoundId", "Volume", "PlaybackSpeed",
	"Brightness", "Range", "Disabled", "PrimaryPart",
}

local function getProperties(path: string, propertyNames: { string }?): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	local names = propertyNames or CURATED_PROPS
	local props: { [string]: any } = {}
	local target = inst :: any
	for _, name in ipairs(names) do
		local ok, value = pcall(function()
			return target[name]
		end)
		if ok and value ~= nil then
			props[name] = Serializer.serialize(value)
		end
	end
	return {
		ok = true,
		result = {
			path = inst:GetFullName(),
			className = inst.ClassName,
			name = inst.Name,
			properties = props,
			curated = propertyNames == nil,
		},
	}
end

-- == Phase C: write / edit (ChangeHistory-wrapped in edit) ===================
local function setSelection(paths: { string }): any
	local insts = {}
	for _, p in ipairs(paths) do
		local inst = resolvePath(p)
		if inst then
			table.insert(insts, inst)
		end
	end
	local ok, err = pcall(function()
		Selection:Set(insts)
	end)
	if not ok then
		return { ok = false, err = tostring(err) }
	end
	return { ok = true, output = ("selected %d instance(s)"):format(#insts) }
end

local function createInstance(p: any): any
	local parent = resolvePath(p.parentPath)
	if not parent then
		return { ok = false, err = "parent path not found: " .. tostring(p.parentPath) }
	end
	local ok, ret = recorded("create_instance", function()
		local inst = Instance.new(p.className)
		if p.name then
			inst.Name = p.name
		end
		if type(p.properties) == "table" then
			local target = inst :: any
			for k, v in pairs(p.properties) do
				target[k] = Serializer.deserialize(v)
			end
		end
		inst.Parent = parent
		return inst
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = "created " .. ret:GetFullName(), result = pathInfo(ret) }
end

local function deleteInstance(path: string): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	local full = inst:GetFullName()
	local ok, ret = recorded("delete_instance", function()
		inst:Destroy()
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = "deleted " .. full }
end

local function cloneInstance(path: string, parentPath: string?): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	local parent = parentPath and resolvePath(parentPath) or inst.Parent
	if not parent then
		return { ok = false, err = "parent path not found" }
	end
	local ok, ret = recorded("clone_instance", function()
		inst.Archivable = true
		local clone = inst:Clone()
		if not clone then
			error("clone failed")
		end
		clone.Parent = parent
		return clone
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = "cloned to " .. ret:GetFullName(), result = pathInfo(ret) }
end

local function renameInstance(path: string, name: string): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	local ok, ret = recorded("rename_instance", function()
		inst.Name = name
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = ("renamed to %s"):format(name), result = pathInfo(inst) }
end

local function setParent(path: string, parentPath: string): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	local parent = resolvePath(parentPath)
	if not parent then
		return { ok = false, err = "parent path not found: " .. parentPath }
	end
	local ok, ret = recorded("set_parent", function()
		inst.Parent = parent
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = "moved " .. inst:GetFullName(), result = pathInfo(inst) }
end

local function moveInstance(p: any): any
	local inst = resolvePath(p.path)
	if not inst then
		return { ok = false, err = "path not found: " .. tostring(p.path) }
	end
	local ok, ret = recorded("move_instance", function()
		local target = inst :: any
		if p.cframe ~= nil then
			local cf = Serializer.deserialize(p.cframe)
			if inst:IsA("Model") then
				inst:PivotTo(cf)
			else
				target.CFrame = cf
			end
		elseif p.position ~= nil then
			local pos = Serializer.deserialize(p.position)
			if inst:IsA("Model") then
				inst:PivotTo(CFrame.new(pos))
			else
				target.Position = pos
			end
		else
			error("move_instance needs cframe or position")
		end
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = "moved " .. inst:GetFullName() }
end

local function bulkSetProperty(paths: { string }, property: string, rawValue: any): any
	local value = Serializer.deserialize(rawValue)
	local count = 0
	local failed = {}
	local ok, ret = recorded("bulk_set_property:" .. property, function()
		for _, p in ipairs(paths) do
			local inst = resolvePath(p)
			if inst then
				local target = inst :: any
				local setOk = pcall(function()
					target[property] = value
				end)
				if setOk then
					count += 1
				else
					table.insert(failed, p)
				end
			else
				table.insert(failed, p)
			end
		end
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return {
		ok = true,
		output = ("set %s on %d/%d"):format(property, count, #paths),
		result = { set = count, failed = failed },
	}
end

local function tagInstance(path: string, tag: string, add: boolean): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	local ok, ret = recorded(add and "tag_instance" or "untag_instance", function()
		if add then
			CollectionService:AddTag(inst, tag)
		else
			CollectionService:RemoveTag(inst, tag)
		end
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = ("%s %q on %s"):format(add and "added tag" or "removed tag", tag, inst:GetFullName()) }
end

local function insertAsset(assetId: number, parentPath: string?): any
	local parent = parentPath and resolvePath(parentPath) or workspace
	if not parent then
		return { ok = false, err = "parent path not found: " .. tostring(parentPath) }
	end
	local inserted = {}
	local ok, ret = recorded("insert_asset", function()
		local container = InsertService:LoadAsset(assetId)
		for _, child in ipairs(container:GetChildren()) do
			child.Parent = parent
			table.insert(inserted, pathInfo(child))
		end
		container:Destroy()
	end)
	if not ok then
		return { ok = false, err = "LoadAsset failed (asset must be owned or public): " .. tostring(ret) }
	end
	return { ok = true, output = ("inserted %d instance(s)"):format(#inserted), result = inserted }
end

-- == Batch 1: viewport capture + playtest control ===========================
-- base64 of a raw byte buffer (for JSON transport of the screenshot's RGBA).
-- Buffer-based (Boshy-style) so a multi-megapixel frame encodes fast and never
-- stalls the poll loop. The PNG itself is encoded in Node (src/png-encoder.ts) --
-- pure-Luau PNG encoding of a full frame was the old "capture never returns" stall.
local B64 = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
local B64BYTES = buffer.create(64)
for i = 0, 63 do
	buffer.writeu8(B64BYTES, i, string.byte(B64, i + 1))
end
local PAD = string.byte("=")

local function base64Buffer(buf: buffer): string
	local len = buffer.len(buf)
	local fullTriples = math.floor(len / 3)
	local remaining = len - fullTriples * 3
	local outLen = (fullTriples + (remaining > 0 and 1 or 0)) * 4
	local out = buffer.create(outLen)
	local si, di = 0, 0
	for _ = 1, fullTriples do
		local b0 = buffer.readu8(buf, si)
		local b1 = buffer.readu8(buf, si + 1)
		local b2 = buffer.readu8(buf, si + 2)
		buffer.writeu8(out, di, buffer.readu8(B64BYTES, bit32.rshift(b0, 2)))
		buffer.writeu8(out, di + 1, buffer.readu8(B64BYTES, bit32.bor(bit32.lshift(bit32.band(b0, 3), 4), bit32.rshift(b1, 4))))
		buffer.writeu8(out, di + 2, buffer.readu8(B64BYTES, bit32.bor(bit32.lshift(bit32.band(b1, 15), 2), bit32.rshift(b2, 6))))
		buffer.writeu8(out, di + 3, buffer.readu8(B64BYTES, bit32.band(b2, 63)))
		si += 3
		di += 4
	end
	if remaining == 2 then
		local b0 = buffer.readu8(buf, si)
		local b1 = buffer.readu8(buf, si + 1)
		buffer.writeu8(out, di, buffer.readu8(B64BYTES, bit32.rshift(b0, 2)))
		buffer.writeu8(out, di + 1, buffer.readu8(B64BYTES, bit32.bor(bit32.lshift(bit32.band(b0, 3), 4), bit32.rshift(b1, 4))))
		buffer.writeu8(out, di + 2, buffer.readu8(B64BYTES, bit32.lshift(bit32.band(b1, 15), 2)))
		buffer.writeu8(out, di + 3, PAD)
	elseif remaining == 1 then
		local b0 = buffer.readu8(buf, si)
		buffer.writeu8(out, di, buffer.readu8(B64BYTES, bit32.rshift(b0, 2)))
		buffer.writeu8(out, di + 1, buffer.readu8(B64BYTES, bit32.lshift(bit32.band(b0, 3), 4)))
		buffer.writeu8(out, di + 2, PAD)
		buffer.writeu8(out, di + 3, PAD)
	end
	return buffer.tostring(out)
end

-- EditableImage:ReadPixelsBuffer has a per-call size ceiling; read in <=1024x1024
-- tiles and stitch into one tightly-packed RGBA buffer (Boshy-style). Needed for
-- frames larger than 1024 on either axis.
local function readPixelsTiled(img: any, w: number, h: number): buffer
	local TILE = 1024
	local full = buffer.create(w * h * 4)
	local fullRowBytes = w * 4
	local ty = 0
	while ty < h do
		local tileH = math.min(TILE, h - ty)
		local tx = 0
		while tx < w do
			local tileW = math.min(TILE, w - tx)
			local tileBuf = img:ReadPixelsBuffer(Vector2.new(tx, ty), Vector2.new(tileW, tileH))
			local tileRowBytes = tileW * 4
			for row = 0, tileH - 1 do
				buffer.copy(full, (ty + row) * fullRowBytes + tx * 4, tileBuf, row * tileRowBytes, tileRowBytes)
			end
			tx += TILE
		end
		ty += TILE
	end
	return full
end

-- Real screenshot via CaptureService + EditableImage. Returns RAW RGBA (base64) +
-- dimensions; Node encodes the PNG. Capture ONLY works in Edit mode with the Studio
-- viewport visible and rendering (engine limit -- it reads the rendered screen) and
-- requires Game Settings > Security > "Allow Mesh / Image APIs".
local function captureViewport(): any
	local capturedId: string? = nil
	local okCap = pcall(function()
		local done = false
		CaptureService:CaptureScreenshot(function(id)
			capturedId = id
			done = true
		end)
		local waited = 0
		while not done and waited < 10 do
			task.wait(0.1)
			waited += 0.1
		end
	end)
	if not okCap or not capturedId then
		-- the screenshot step itself failed/timed out (callback never fired)
		return {
			ok = false,
			err = "capture_viewport: screenshot timed out (CaptureService:CaptureScreenshot never returned). "
				.. "Capture only works in Edit mode with the Studio viewport visible and rendering -- "
				.. "make sure the 3D viewport is focused and not hidden behind a playtest or another tab.",
		}
	end
	-- Pass the capture content id string directly; only wrap with Content.fromUri
	-- when that library exists (older Studio builds lack it).
	local imgArg: any = capturedId
	if (Content :: any) and (Content :: any).fromUri then
		imgArg = (Content :: any).fromUri(capturedId :: string)
	end
	local img: any = nil
	local okImg, errImg = pcall(function()
		img = AssetService:CreateEditableImageAsync(imgArg)
	end)
	if not okImg or not img then
		-- image-handle creation failed -- most commonly the Mesh/Image API toggle
		return {
			ok = false,
			err = "capture_viewport: could not create an EditableImage from the screenshot. If "
				.. "Game Settings > Security > 'Allow Mesh / Image APIs' is OFF, turn it ON and retry. "
				.. "(raw error: " .. tostring(errImg) .. ")",
		}
	end
	-- Read pixels in Luau (tiled), base64 the raw RGBA, and hand it to Node to PNG-encode.
	local okEnc, resultOrErr = pcall(function()
		local size = img.Size
		local w, h = math.floor(size.X), math.floor(size.Y)
		local rgba = readPixelsTiled(img, w, h)
		return { rgba = base64Buffer(rgba), width = w, height = h }
	end)
	pcall(function()
		(img :: any):Destroy()
	end)
	if not okEnc then
		return { ok = false, err = "capture_viewport: read pixels failed: " .. tostring(resultOrErr) }
	end
	return { ok = true, result = resultOrErr }
end

-- Start/stop a real playtest via StudioTestService:ExecuteRunModeAsync /
-- ExecutePlayModeAsync (the same API that drives F8/F5). These yield for the
-- whole playtest and spin up a SEPARATE run DataModel, so the edit-context
-- plugin sees RunService:IsRunning()==false throughout -- the true "is it live"
-- signal is the runtime agent's `server` liveness (merged in by the Node layer).
-- NOTE: RunService:Run() is a no-op from a plugin in this Studio build (verified
-- empirically: IsRunning() stays false even after a wait); ExecuteRunModeAsync
-- is the mechanism that actually starts the simulation.
local PLAYTEST_STOP_SIGNAL = "__MCP_STOP__"
local playtestStopListener: Instance? = nil

-- Inject a Script into ServerScriptService that, once cloned into the run
-- DataModel, ends the test when it sees the stop signal in the log stream.
-- Must be injected BEFORE Execute*ModeAsync so it travels into the run session.
local function injectPlaytestStopListener()
	-- Guard against duplicates (idempotent re-arm).
	local existing = ServerScriptService:FindFirstChild("__MCP_CommandListener")
	if existing then
		playtestStopListener = existing
		return
	end
	local listener = Instance.new("Script")
	listener.Name = "__MCP_CommandListener"
	local source = table.concat({
		'local LogService = game:GetService("LogService")',
		'local StudioTestService = game:GetService("StudioTestService")',
		'LogService.MessageOut:Connect(function(msg)',
		'\tif msg == "' .. PLAYTEST_STOP_SIGNAL .. '" then',
		'\t\tpcall(function() StudioTestService:EndTest("stopped_by_mcp") end)',
		'\tend',
		'end)',
	}, "\n")
	local seOk = pcall(function()
		ScriptEditorService:UpdateSourceAsync(listener, function()
			return source
		end)
	end)
	if not seOk then
		listener.Source = source
	end
	listener.Parent = ServerScriptService
	playtestStopListener = listener
end

local function cleanupPlaytestStopListener()
	if playtestStopListener then
		pcall(function()
			playtestStopListener:Destroy()
		end)
		playtestStopListener = nil
	end
	local stray = ServerScriptService:FindFirstChild("__MCP_CommandListener")
	if stray then
		pcall(function()
			stray:Destroy()
		end)
	end
end

local function playtestControl(p: any): any
	local action = tostring(p.action)
	local mode = p.mode or "run"
	if action == "start" then
		if RunService:IsRunning() or playtestStartedAt ~= nil then
			return { ok = false, err = "a playtest/simulation is already running" }
		end
		if mode ~= "run" and mode ~= "play" then
			return { ok = false, err = "playtest_control: mode must be 'run' or 'play'" }
		end
		playtestRing = {}
		playtestCapturing = true
		if p.numPlayers ~= nil then
			pcall(function()
				TestService.NumberOfPlayers = math.clamp(tonumber(p.numPlayers) or 1, 1, 8)
			end)
		end
		injectPlaytestStopListener()
		local launchErr: string? = nil
		task.spawn(function()
			local ok, err = pcall(function()
				if mode == "play" then
					return StudioTestService:ExecutePlayModeAsync({})
				end
				return StudioTestService:ExecuteRunModeAsync({})
			end)
			if not ok then
				launchErr = tostring(err)
			end
			-- Execute*ModeAsync returns only when the playtest ENDS.
			playtestCapturing = false
			playtestStartedAt = nil
			cleanupPlaytestStopListener()
		end)
		-- Brief wait to surface an immediate launch failure before reporting.
		task.wait(0.3)
		if launchErr ~= nil then
			playtestCapturing = false
			cleanupPlaytestStopListener()
			local fn = (mode == "play") and "ExecutePlayModeAsync" or "ExecuteRunModeAsync"
			return { ok = false, err = "StudioTestService:" .. fn .. " failed: " .. launchErr }
		end
		playtestStartedAt = os.time()
		playtestLastActivity = os.time()
		return {
			ok = true,
			output = "launched " .. mode .. " mode via StudioTestService (separate DataModel); "
				.. "confirm it is live with get_playtest_status (agentConnected/running) -- the edit "
				.. "plugin cannot see the run DataModel directly",
		}
	elseif action == "stop" then
		-- Primary: signal the in-run listener to EndTest. Fallback: EndTest direct.
		pcall(function()
			warn(PLAYTEST_STOP_SIGNAL)
		end)
		local endOk = pcall(function()
			StudioTestService:EndTest("stopped_by_mcp")
		end)
		playtestCapturing = false
		playtestStartedAt = nil
		cleanupPlaytestStopListener()
		return {
			ok = true,
			output = "sent stop (warn " .. PLAYTEST_STOP_SIGNAL
				.. (endOk and " + EndTest)" or " ; EndTest direct call errored, listener signal sent)"),
		}
	end
	return { ok = false, err = "playtest_control: action must be 'start' or 'stop'" }
end

-- Drain (default) or peek the captured playtest log ring.
local function getPlaytestOutput(p: any): any
	playtestLastActivity = os.time() -- agent is actively watching -> not idle
	local lines = playtestRing
	if p.drain ~= false then
		playtestRing = {}
	end
	return { ok = true, result = { lines = lines, capturing = playtestCapturing, count = #lines } }
end

-- Playtest lifecycle status (feeds the ungated get_playtest_status tool). The
-- Node server merges in agentConnected from bridge `server` liveness.
local function getPlaytestStatus(): any
	-- Raw edit-context signals only. The authoritative "is a playtest live" signal
	-- is the runtime agent's `server` liveness, which only the Node layer can see;
	-- it gates `running`/`mode`/`duration` on that. We surface:
	--   simRunning      = RunService:IsRunning() (true only for same-DataModel sims)
	--   startedAtUnix   = our launch timestamp; non-nil ONLY while an Execute*ModeAsync
	--                     we started is still yielding (cleared the instant it returns)
	-- A StudioTestService run spins up a separate DataModel, so simRunning stays
	-- false there; the live signal is startedAtUnix + server liveness.
	local simRunning = RunService:IsRunning()
	local players = 0
	pcall(function()
		players = #game:GetService("Players"):GetPlayers()
	end)
	local duration = playtestStartedAt and (os.time() - playtestStartedAt) or 0
	return {
		ok = true,
		result = {
			running = simRunning,
			mode = playtestStartedAt ~= nil and "run" or nil,
			startedAtUnix = playtestStartedAt,
			durationSec = duration,
			players = players,
		},
	}
end

-- == Batch 2: attributes ====================================================
local function getAttribute(path: string, name: string): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	return { ok = true, result = { path = inst:GetFullName(), name = name, value = Serializer.serialize(inst:GetAttribute(name)) } }
end

local function getAttributes(path: string): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	local out: { [string]: any } = {}
	for k, v in pairs(inst:GetAttributes()) do
		out[k] = Serializer.serialize(v)
	end
	return { ok = true, result = { path = inst:GetFullName(), attributes = out } }
end

local function setAttribute(path: string, name: string, rawValue: any): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	local ok, ret = recorded("set_attribute:" .. name, function()
		inst:SetAttribute(name, Serializer.deserialize(rawValue))
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = ("set attribute %q on %s"):format(name, inst:GetFullName()) }
end

local function setAttributes(path: string, attrs: any): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	if type(attrs) ~= "table" then
		return { ok = false, err = "set_attributes needs an 'attributes' table" }
	end
	local count = 0
	local ok, ret = recorded("set_attributes", function()
		for k, v in pairs(attrs) do
			inst:SetAttribute(k, Serializer.deserialize(v))
			count += 1
		end
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = ("set %d attribute(s) on %s"):format(count, inst:GetFullName()) }
end

local function deleteAttribute(path: string, name: string): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	local ok, ret = recorded("delete_attribute:" .. name, function()
		inst:SetAttribute(name, nil)
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = ("deleted attribute %q from %s"):format(name, inst:GetFullName()) }
end

-- == Batch 3: script editing depth ==========================================
local function readEditorSource(inst: Instance): (boolean, string)
	local src: any = nil
	local ok = pcall(function()
		src = ScriptEditorService:GetEditorSource(inst)
	end)
	if not ok or src == nil then
		local ok2 = pcall(function()
			src = (inst :: any).Source
		end)
		if not ok2 or src == nil then
			return false, "could not read source"
		end
	end
	return true, src
end

local function splice(lines: { string }, startIdx: number, deleteCount: number, insert: { string }?): { string }
	local out = {}
	for i = 1, startIdx - 1 do
		out[#out + 1] = lines[i]
	end
	if insert then
		for _, l in ipairs(insert) do
			out[#out + 1] = l
		end
	end
	for i = startIdx + deleteCount, #lines do
		out[#out + 1] = lines[i]
	end
	return out
end

local function escapePattern(s: string): string
	return (s:gsub("([%(%)%.%%%+%-%*%?%[%]%^%$])", "%%%1"))
end

-- Resolve a script + read source; returns (inst, source) or (nil, errResult).
local function resolveScript(path: string): (Instance?, string?, any?)
	local inst = resolvePath(path)
	if not inst then
		return nil, nil, { ok = false, err = "path not found: " .. path }
	end
	if not inst:IsA("LuaSourceContainer") then
		return nil, nil, { ok = false, err = path .. " is not a script (" .. inst.ClassName .. ")" }
	end
	local rok, src = readEditorSource(inst)
	if not rok then
		return nil, nil, { ok = false, err = "could not read source of " .. path }
	end
	return inst, src, nil
end

local function writeLineEdit(inst: Instance, newLines: { string }, label: string): any
	local newSrc = table.concat(newLines, "\n")
	local ok, err = recorded(label, function()
		ScriptEditorService:UpdateSourceAsync(inst, function()
			return newSrc
		end)
	end)
	if not ok then
		return { ok = false, err = tostring(err) }
	end
	return { ok = true, output = ("%s %s (%d lines)"):format(label, inst:GetFullName(), #newLines) }
end

local function editScriptLines(p: any): any
	if RunService:IsRunning() then
		return { ok = false, err = "script editing is edit-context only" }
	end
	local inst, src, errRes = resolveScript(p.path)
	if not inst then
		return errRes
	end
	local lines = string.split(src :: string, "\n")
	local startLine = math.max(1, math.floor(p.startLine or 1))
	local endLine = math.min(#lines, math.floor(p.endLine or startLine))
	if endLine < startLine then
		endLine = startLine - 1 -- nothing deleted; pure insert at startLine
	end
	local inserted = string.split(tostring(p.newText or ""), "\n")
	local newLines = splice(lines, startLine, endLine - startLine + 1, inserted)
	return writeLineEdit(inst, newLines, "edit_script_lines")
end

local function insertScriptLines(p: any): any
	if RunService:IsRunning() then
		return { ok = false, err = "script editing is edit-context only" }
	end
	local inst, src, errRes = resolveScript(p.path)
	if not inst then
		return errRes
	end
	local lines = string.split(src :: string, "\n")
	local at = math.max(1, math.min(#lines + 1, math.floor(p.line or (#lines + 1))))
	local inserted = string.split(tostring(p.newText or ""), "\n")
	local newLines = splice(lines, at, 0, inserted)
	return writeLineEdit(inst, newLines, "insert_script_lines")
end

local function deleteScriptLines(p: any): any
	if RunService:IsRunning() then
		return { ok = false, err = "script editing is edit-context only" }
	end
	local inst, src, errRes = resolveScript(p.path)
	if not inst then
		return errRes
	end
	local lines = string.split(src :: string, "\n")
	local startLine = math.max(1, math.floor(p.startLine or 1))
	local endLine = math.min(#lines, math.floor(p.endLine or startLine))
	if endLine < startLine then
		return { ok = false, err = "delete_script_lines: endLine < startLine" }
	end
	local newLines = splice(lines, startLine, endLine - startLine + 1, nil)
	return writeLineEdit(inst, newLines, "delete_script_lines")
end

local function findReplaceInScripts(p: any): any
	if RunService:IsRunning() then
		return { ok = false, err = "find_and_replace_in_scripts is edit-context only" }
	end
	local find = p.find
	if not find or find == "" then
		return { ok = false, err = "find_and_replace_in_scripts: 'find' is required" }
	end
	local root = resolvePath(p.root or "game") or game
	local replace = tostring(p.replace or "")
	local useRegex = p.regex == true
	local pat = useRegex and find or escapePattern(find)
	local repl = useRegex and replace or (replace:gsub("%%", "%%%%"))
	local changed = {}
	local ok, ret = recorded("find_and_replace_in_scripts", function()
		for _, inst in ipairs(root:GetDescendants()) do
			if inst:IsA("LuaSourceContainer") then
				local rok, src = readEditorSource(inst)
				if rok then
					local newSrc, count = string.gsub(src, pat, repl)
					if count > 0 and newSrc ~= src then
						ScriptEditorService:UpdateSourceAsync(inst, function()
							return newSrc
						end)
						table.insert(changed, { path = inst:GetFullName(), replacements = count })
					end
				end
			end
		end
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = ("changed %d script(s)"):format(#changed), result = changed }
end

local function grepScripts(p: any): any
	local pattern = p.pattern
	if not pattern or pattern == "" then
		return { ok = false, err = "grep_scripts: 'pattern' is required" }
	end
	local root = resolvePath(p.root or "game") or game
	local useRegex = p.regex == true
	local limit = p.limit or 500
	local out = {}
	for _, inst in ipairs(root:GetDescendants()) do
		if inst:IsA("LuaSourceContainer") then
			local rok, src = readEditorSource(inst)
			if rok then
				local lineNo = 0
				for line in (src .. "\n"):gmatch("(.-)\n") do
					lineNo += 1
					local hit
					if useRegex then
						hit = string.find(line, pattern) ~= nil
					else
						hit = string.find(line, pattern, 1, true) ~= nil
					end
					if hit then
						table.insert(out, { path = inst:GetFullName(), line = lineNo, text = line })
						if #out >= limit then
							break
						end
					end
				end
			end
		end
		if #out >= limit then
			break
		end
	end
	return { ok = true, result = { matches = out, truncated = #out >= limit } }
end

local function getScriptAnalysis(p: any): any
	local inst, src, errRes = resolveScript(p.path)
	if not inst then
		return errRes
	end
	local chunk, err = loadstring(src :: string)
	if not chunk then
		return { ok = true, result = { path = inst:GetFullName(), compiles = false, diagnostics = { tostring(err) } } }
	end
	return { ok = true, result = { path = inst:GetFullName(), compiles = true, diagnostics = {} } }
end

-- == Batch 4: undo / redo + mass ops ========================================
local function undo(): any
	if RunService:IsRunning() then
		return { ok = false, err = "undo is edit-context only" }
	end
	local ok, err = pcall(function()
		ChangeHistoryService:Undo()
	end)
	if not ok then
		return { ok = false, err = tostring(err) }
	end
	return { ok = true, output = "undo" }
end

local function redo(): any
	if RunService:IsRunning() then
		return { ok = false, err = "redo is edit-context only" }
	end
	local ok, err = pcall(function()
		ChangeHistoryService:Redo()
	end)
	if not ok then
		return { ok = false, err = tostring(err) }
	end
	return { ok = true, output = "redo" }
end

-- Translate a PVInstance (BasePart or Model) by a WORLD-space delta.
local function translateInstance(inst: Instance, delta: Vector3)
	if inst:IsA("PVInstance") then
		pcall(function()
			(inst :: any):PivotTo((inst :: any):GetPivot() + delta)
		end)
	end
end

local function massCreateObjects(items: any): any
	if type(items) ~= "table" then
		return { ok = false, err = "mass_create_objects needs an items[] array" }
	end
	local made, failed = {}, {}
	local ok, ret = recorded("mass_create_objects", function()
		for _, item in ipairs(items) do
			local parent = item.parentPath and resolvePath(item.parentPath) or nil
			if not parent then
				table.insert(failed, { parentPath = item.parentPath, err = "parent not found" })
				continue
			end
			local cok, cerr = pcall(function()
				local inst = Instance.new(item.className)
				if item.name then
					inst.Name = item.name
				end
				if type(item.properties) == "table" then
					local target = inst :: any
					for k, v in pairs(item.properties) do
						pcall(function()
							target[k] = Serializer.deserialize(v)
						end)
					end
				end
				inst.Parent = parent
				table.insert(made, pathInfo(inst))
			end)
			if not cok then
				table.insert(failed, { className = item.className, err = tostring(cerr) })
			end
		end
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return {
		ok = true,
		output = ("created %d, %d failed"):format(#made, #failed),
		result = { created = made, failed = failed },
	}
end

local function massDuplicate(p: any): any
	local inst = resolvePath(p.path)
	if not inst then
		return { ok = false, err = "path not found: " .. tostring(p.path) }
	end
	local count = math.max(1, math.floor(p.count or 1))
	local offset = p.offset ~= nil and Serializer.deserialize(p.offset) or Vector3.new(0, 0, 0)
	local parent = inst.Parent
	if not parent then
		return { ok = false, err = "cannot duplicate the root" }
	end
	local made = {}
	local ok, ret = recorded("mass_duplicate", function()
		inst.Archivable = true
		for i = 1, count do
			local clone = inst:Clone()
			clone.Parent = parent
			if typeof(offset) == "Vector3" and offset.Magnitude > 0 then
				translateInstance(clone, offset * i)
			end
			table.insert(made, pathInfo(clone))
		end
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = ("duplicated %d time(s)"):format(#made), result = made }
end

-- Grid/line clone layout. mode='grid' (default) tiles by columns+spacing;
-- mode='line' steps by spacing*i.
local function smartDuplicate(p: any): any
	local inst = resolvePath(p.path)
	if not inst then
		return { ok = false, err = "path not found: " .. tostring(p.path) }
	end
	local parent = inst.Parent
	if not parent then
		return { ok = false, err = "cannot duplicate the root" }
	end
	local count = math.max(1, math.floor(p.count or 1))
	local mode = p.mode or "grid"
	local spacing = p.spacing ~= nil and Serializer.deserialize(p.spacing) or Vector3.new(10, 0, 10)
	if typeof(spacing) ~= "Vector3" then
		spacing = Vector3.new(10, 0, 10)
	end
	local columns = math.max(1, math.floor(p.columns or math.ceil(math.sqrt(count))))
	local made = {}
	local ok, ret = recorded("smart_duplicate", function()
		inst.Archivable = true
		for i = 0, count - 1 do
			local clone = inst:Clone()
			clone.Parent = parent
			local delta: Vector3
			if mode == "line" then
				delta = spacing * i
			else
				local col = i % columns
				local row = math.floor(i / columns)
				delta = Vector3.new(spacing.X * col, spacing.Y * row, spacing.Z * row)
			end
			if delta.Magnitude > 0 then
				translateInstance(clone, delta)
			end
			table.insert(made, pathInfo(clone))
		end
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = ("placed %d clone(s) in %s pattern"):format(#made, mode), result = made }
end

local function massGetProperty(paths: { string }, property: string): any
	local out: { [string]: any } = {}
	local missing = {}
	for _, path in ipairs(paths) do
		local inst = resolvePath(path)
		if inst then
			local ok, val = pcall(function()
				return (inst :: any)[property]
			end)
			if ok then
				out[path] = Serializer.serialize(val)
			else
				table.insert(missing, path)
			end
		else
			table.insert(missing, path)
		end
	end
	return { ok = true, result = { property = property, values = out, missing = missing } }
end

-- == Batch 5: deeper inspection =============================================
-- Luau has no full reflection from a plugin. We return what IS discoverable
-- (creatable? which curated props apply) and document the limitation honestly.
local function getClassInfo(className: string): any
	local okNew, inst = pcall(function()
		return Instance.new(className)
	end)
	if not okNew or not inst then
		return {
			ok = true,
			result = {
				className = className,
				creatable = false,
				note = "Not creatable via Instance.new (abstract/service/unknown). Luau has no "
					.. "full reflection from a plugin; methods/events/full property lists need the "
					.. "Roblox API dump JSON, which is not bundled.",
			},
		}
	end
	local applicable = {}
	local target = inst :: any
	for _, name in ipairs(CURATED_PROPS) do
		local ok = pcall(function()
			return target[name]
		end)
		if ok then
			table.insert(applicable, name)
		end
	end
	inst:Destroy()
	return {
		ok = true,
		result = {
			className = className,
			creatable = true,
			applicableCuratedProperties = applicable,
			note = "Luau has no full reflection from a plugin; methods/events and the complete "
				.. "property list are not enumerable without bundling the Roblox API dump. Listed "
				.. "props are the curated subset that apply to this class.",
		},
	}
end

local function getServices(): any
	local out = {}
	for _, child in ipairs(game:GetChildren()) do
		table.insert(out, { name = child.Name, className = child.ClassName })
	end
	return { ok = true, result = out }
end

local function getDescendants(path: string, maxDepth: number?): any
	local root = resolvePath(path)
	if not root then
		return { ok = false, err = "path not found: " .. path }
	end
	local out = {}
	local cap = 5000
	if maxDepth then
		local function walk(inst: Instance, d: number)
			for _, c in ipairs(inst:GetChildren()) do
				if #out >= cap then
					return
				end
				table.insert(out, pathInfo(c))
				if d < maxDepth then
					walk(c, d + 1)
				end
			end
		end
		walk(root, 1)
	else
		for _, d in ipairs(root:GetDescendants()) do
			table.insert(out, pathInfo(d))
			if #out >= cap then
				break
			end
		end
	end
	return { ok = true, result = { descendants = out, truncated = #out >= cap } }
end

local OBJECT_PROPS = { "PrimaryPart", "Adornee", "Part0", "Part1", "Attachment0", "Attachment1" }
local function getConnectedInstances(path: string): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	local out = {}
	local seen: { [Instance]: boolean } = {}
	local function add(i: Instance?)
		if i and i ~= inst and not seen[i] then
			seen[i] = true
			table.insert(out, pathInfo(i))
		end
	end
	if inst:IsA("BasePart") then
		local ok, parts = pcall(function()
			return (inst :: any):GetConnectedParts(true)
		end)
		if ok and type(parts) == "table" then
			for _, part in ipairs(parts) do
				add(part)
			end
		end
	end
	local target = inst :: any
	for _, name in ipairs(OBJECT_PROPS) do
		local ok, val = pcall(function()
			return target[name]
		end)
		if ok and typeof(val) == "Instance" then
			add(val)
		end
	end
	return { ok = true, result = out }
end

local function compareInstances(pathA: string, pathB: string): any
	local ia, ib = resolvePath(pathA), resolvePath(pathB)
	if not ia or not ib then
		return { ok = false, err = "one or both paths not found" }
	end
	local diffs: { [string]: any } = {}
	local ta, tb = ia :: any, ib :: any
	for _, name in ipairs(CURATED_PROPS) do
		local oka, va = pcall(function()
			return ta[name]
		end)
		local okb, vb = pcall(function()
			return tb[name]
		end)
		if oka and okb and va ~= vb then
			diffs[name] = { a = Serializer.serialize(va), b = Serializer.serialize(vb) }
		end
	end
	return {
		ok = true,
		result = {
			a = ia:GetFullName(),
			b = ib:GetFullName(),
			classA = ia.ClassName,
			classB = ib.ClassName,
			differences = diffs,
		},
	}
end

local function getProjectStructure(): any
	local services = {}
	for _, child in ipairs(game:GetChildren()) do
		local byClass: { [string]: number } = {}
		for _, c in ipairs(child:GetChildren()) do
			byClass[c.ClassName] = (byClass[c.ClassName] or 0) + 1
		end
		table.insert(services, {
			name = child.Name,
			className = child.ClassName,
			childCount = #child:GetChildren(),
			childrenByClass = byClass,
		})
	end
	return { ok = true, result = { placeId = game.PlaceId, gameId = game.GameId, services = services } }
end

-- Nested tree of scripts (only branches that contain a LuaSourceContainer).
local function getFileTree(rootPath: string?): any
	local root = resolvePath(rootPath or "game") or game
	local function build(inst: Instance): any
		local node = {
			name = inst.Name,
			className = inst.ClassName,
			isScript = inst:IsA("LuaSourceContainer"),
			children = {} :: { any },
		}
		for _, c in ipairs(inst:GetChildren()) do
			local child = build(c)
			if child.isScript or #child.children > 0 then
				table.insert(node.children, child)
			end
		end
		return node
	end
	return { ok = true, result = build(root) }
end

local function setProperties(path: string, props: any): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	if type(props) ~= "table" then
		return { ok = false, err = "set_properties needs a 'properties' table" }
	end
	local set, failed = 0, {}
	local target = inst :: any
	local ok, ret = recorded("set_properties", function()
		for k, v in pairs(props) do
			local sok = pcall(function()
				target[k] = Serializer.deserialize(v)
			end)
			if sok then
				set += 1
			else
				table.insert(failed, k)
			end
		end
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = ("set %d property(ies) on %s"):format(set, inst:GetFullName()), result = { set = set, failed = failed } }
end

-- Type-aware match. The MCP client can deliver top-level scalar args as STRINGS
-- ("true"/"0"), so a plain `val == want` never matches boolean/number properties.
-- Coerce `want` to the actual property value's type before comparing.
local function valueMatches(val: any, want: any): boolean
	if val == want then
		return true
	end
	local vt = type(val)
	if vt == "boolean" then
		return val == (want == true or want == "true")
	elseif vt == "number" then
		return val == tonumber(want)
	end
	return false
end

local function searchByProperty(p: any): any
	local property = p.property
	if not property then
		return { ok = false, err = "search_by_property: 'property' is required" }
	end
	local root = resolvePath(p.root or "game") or game
	local want = Serializer.deserialize(p.value)
	local limit = p.limit or 100
	local out = {}
	for _, inst in ipairs(root:GetDescendants()) do
		local ok, val = pcall(function()
			return (inst :: any)[property]
		end)
		if ok and valueMatches(val, want) then
			table.insert(out, pathInfo(inst))
			if #out >= limit then
				break
			end
		end
	end
	return { ok = true, result = out }
end

local function getTags(path: string): any
	local inst = resolvePath(path)
	if not inst then
		return { ok = false, err = "path not found: " .. path }
	end
	return { ok = true, result = { path = inst:GetFullName(), tags = CollectionService:GetTags(inst) } }
end

-- == Batch 6: assets / marketplace ==========================================
local function getAssetDetails(assetId: number): any
	local ok, info = pcall(function()
		return MarketplaceService:GetProductInfo(assetId)
	end)
	if not ok then
		return { ok = false, err = "GetProductInfo failed: " .. tostring(info) }
	end
	return { ok = true, result = info }
end

local function thumbId(assetId: number, size: number?): string
	local s = size or 420
	return ("rbxthumb://type=Asset&id=%d&w=%d&h=%d"):format(assetId, s, s)
end

local function getAssetThumbnail(assetId: number, size: number?): any
	return { ok = true, result = { assetId = assetId, thumbnail = thumbId(assetId, size) } }
end

local function previewAsset(assetId: number): any
	local details = getAssetDetails(assetId)
	if details.ok and type(details.result) == "table" then
		details.result.thumbnail = thumbId(assetId, 420)
	end
	return details
end

local function searchMaterials(query: string?): any
	local q = query and string.lower(query) or nil
	local out = {}
	for _, m in ipairs(Enum.Material:GetEnumItems()) do
		if not q or string.find(string.lower(m.Name), q, 1, true) then
			table.insert(out, m.Name)
		end
	end
	return { ok = true, result = out }
end

local function searchAssets(): any
	return {
		ok = false,
		err = "search_assets is not supported from a plugin: catalog/marketplace search needs the "
			.. "Roblox web / Open Cloud API. Use get_asset_details with a known assetId, or insert_asset.",
	}
end

local function listLibrary(): any
	return {
		ok = false,
		err = "list_library is not supported from a plugin: no API enumerates your inventory/library "
			.. "from edit. Use the Open Cloud / web API.",
	}
end

local function uploadDecal(): any
	return {
		ok = false,
		err = "upload_decal is not supported from a plugin: publishing an image asset requires Open "
			.. "Cloud Assets API credentials (an API key), which a Studio plugin cannot supply.",
	}
end

-- == Batch 7: input simulation (mostly restricted; honest where it is) =======
-- VirtualInputManager needs RobloxScriptSecurity; a normal plugin/game script
-- cannot access it, so SendKey/Mouse calls fail and we report that honestly.
local function getVIM(): any
	local ok, vim = pcall(function()
		return game:GetService("VirtualInputManager")
	end)
	return ok and vim or nil
end

local function simulateKeyboardInput(p: any): any
	local vim = getVIM()
	if not vim then
		return { ok = false, err = "simulate_keyboard_input: VirtualInputManager is not accessible (RobloxScriptSecurity)." }
	end
	local ok, err = pcall(function()
		local keyCode = (Enum.KeyCode :: any)[p.key]
		local action = p.action or "press"
		if action ~= "up" then
			vim:SendKeyEvent(true, keyCode, false, game)
		end
		if action ~= "down" then
			vim:SendKeyEvent(false, keyCode, false, game)
		end
	end)
	if not ok then
		return { ok = false, err = "SendKeyEvent failed (VirtualInputManager is restricted from this context): " .. tostring(err) }
	end
	return { ok = true, output = "sent key " .. tostring(p.key) }
end

local function simulateMouseInput(p: any): any
	local vim = getVIM()
	if not vim then
		return { ok = false, err = "simulate_mouse_input: VirtualInputManager is not accessible (RobloxScriptSecurity)." }
	end
	local ok, err = pcall(function()
		local x, y = p.x or 0, p.y or 0
		local action = p.action or "move"
		if action == "move" then
			vim:SendMouseMoveEvent(x, y, game)
		else
			local button = p.button or 0
			vim:SendMouseButtonEvent(x, y, button, action == "down", game, 1)
		end
	end)
	if not ok then
		return { ok = false, err = "SendMouseEvent failed (VirtualInputManager is restricted from this context): " .. tostring(err) }
	end
	return { ok = true, output = "sent mouse " .. tostring(p.action or "move") }
end

local function characterNavigation(p: any): any
	if not RunService:IsRunning() then
		return {
			ok = false,
			err = "character_navigation needs a running playtest (no player character exists in edit). "
				.. "Run during F5 so the runtime agent handles it.",
		}
	end
	local Players = game:GetService("Players")
	local player = Players:GetPlayers()[1]
	if not player or not player.Character then
		return { ok = false, err = "character_navigation: no player character in the running game" }
	end
	local hum = player.Character:FindFirstChildOfClass("Humanoid")
	if not hum then
		return { ok = false, err = "character_navigation: player has no Humanoid" }
	end
	local target = Serializer.deserialize(p.position)
	if typeof(target) ~= "Vector3" then
		return { ok = false, err = "character_navigation needs a Vector3 'position'" }
	end
	hum:MoveTo(target)
	return { ok = true, output = ("moving character toward (%.1f, %.1f, %.1f)"):format(target.X, target.Y, target.Z) }
end

-- == Task 16 Batch A: build / scene / UI tree / file search =================
-- A "build" = { className, name, properties?, attributes?, tags?, children:[...] }.
local function serializeBuild(inst: Instance, depth: number, maxDepth: number): any
	local node: any = { className = inst.ClassName, name = inst.Name }
	local props: { [string]: any } = {}
	local target = inst :: any
	for _, name in ipairs(CURATED_PROPS) do
		local ok, val = pcall(function()
			return target[name]
		end)
		-- skip Instance-valued props: they reference other instances and don't
		-- round-trip through a self-contained build JSON.
		if ok and val ~= nil and typeof(val) ~= "Instance" then
			props[name] = Serializer.serialize(val)
		end
	end
	if next(props) then
		node.properties = props
	end
	local attrs: { [string]: any } = {}
	for k, v in pairs(inst:GetAttributes()) do
		attrs[k] = Serializer.serialize(v)
	end
	if next(attrs) then
		node.attributes = attrs
	end
	local tags = CollectionService:GetTags(inst)
	if #tags > 0 then
		node.tags = tags
	end
	if depth < maxDepth then
		local children = {}
		for _, c in ipairs(inst:GetChildren()) do
			table.insert(children, serializeBuild(c, depth + 1, maxDepth))
		end
		if #children > 0 then
			node.children = children
		end
	end
	return node
end

local function exportBuild(p: any): any
	local inst = resolvePath(p.path)
	if not inst then
		return { ok = false, err = "path not found: " .. tostring(p.path) }
	end
	local maxDepth = p.maxDepth and math.floor(p.maxDepth) or 8
	return { ok = true, result = serializeBuild(inst, 0, maxDepth) }
end

local function createBuild(p: any): any
	local res = exportBuild(p)
	if not res.ok then
		return res
	end
	return { ok = true, result = { kind = "build", name = p.name or res.result.name, build = res.result } }
end

-- Recursively instantiate a build node under parent. Properties/attributes via
-- Serializer.deserialize (best-effort, pcall-guarded); tags via CollectionService.
local function instantiateBuild(node: any, parent: Instance): Instance
	local inst = Instance.new(node.className)
	if node.name then
		inst.Name = node.name
	end
	if type(node.properties) == "table" then
		local target = inst :: any
		for k, v in pairs(node.properties) do
			pcall(function()
				target[k] = Serializer.deserialize(v)
			end)
		end
	end
	if type(node.attributes) == "table" then
		for k, v in pairs(node.attributes) do
			pcall(function()
				inst:SetAttribute(k, Serializer.deserialize(v))
			end)
		end
	end
	if type(node.tags) == "table" then
		for _, tg in ipairs(node.tags) do
			pcall(function()
				CollectionService:AddTag(inst, tostring(tg))
			end)
		end
	end
	inst.Parent = parent
	if type(node.children) == "table" then
		for _, child in ipairs(node.children) do
			instantiateBuild(child, inst)
		end
	end
	return inst
end

local function importBuild(p: any): any
	if type(p.build) ~= "table" or not p.build.className then
		return { ok = false, err = "import_build needs a 'build' object with a className" }
	end
	local parent = resolvePath(p.parentPath)
	if not parent then
		return { ok = false, err = "parent path not found: " .. tostring(p.parentPath) }
	end
	local ok, ret = recorded("import_build", function()
		local b = p.build
		if p.name then
			b = table.clone(b)
			b.name = p.name
		end
		return instantiateBuild(b, parent)
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = "imported build under " .. parent:GetFullName(), result = pathInfo(ret) }
end

-- Compact high-level generators (distinct from import_build's literal JSON).
local function generateBuild(p: any): any
	local spec = p.spec
	if type(spec) ~= "table" or not spec.kind then
		return { ok = false, err = "generate_build needs a 'spec' with a 'kind' (grid|baseplate)" }
	end
	if spec.kind == "baseplate" then
		local ok, ret = recorded("generate_build:baseplate", function()
			local base = Instance.new("Part")
			base.Name = spec.name or "Baseplate"
			base.Anchored = true
			base.Size = Vector3.new(512, 16, 512)
			base.Position = Vector3.new(0, -8, 0)
			base.BrickColor = BrickColor.new("Dark green")
			base.Material = Enum.Material.Grass
			base.TopSurface = Enum.SurfaceType.Smooth
			base.Parent = workspace
			return base
		end)
		if not ok then
			return { ok = false, err = tostring(ret) }
		end
		return { ok = true, output = "created baseplate", result = pathInfo(ret) }
	elseif spec.kind == "grid" then
		local parent = resolvePath(spec.parentPath or "game.Workspace") or workspace
		local className = spec.className or "Part"
		local rows = math.max(1, math.floor(spec.rows or 1))
		local cols = math.max(1, math.floor(spec.cols or 1))
		local spacing = spec.spacing ~= nil and Serializer.deserialize(spec.spacing) or Vector3.new(8, 0, 8)
		if typeof(spacing) ~= "Vector3" then
			spacing = Vector3.new(8, 0, 8)
		end
		local made = {}
		local ok, ret = recorded("generate_build:grid", function()
			for r = 0, rows - 1 do
				for c = 0, cols - 1 do
					local inst = Instance.new(className)
					if type(spec.properties) == "table" then
						local target = inst :: any
						for k, v in pairs(spec.properties) do
							pcall(function()
								target[k] = Serializer.deserialize(v)
							end)
						end
					end
					if inst:IsA("BasePart") then
						pcall(function()
							local part = inst :: any
							part.Anchored = true
							part.Position = Vector3.new(spacing.X * c, spacing.Y, spacing.Z * r)
						end)
					end
					inst.Parent = parent
					table.insert(made, pathInfo(inst))
				end
			end
		end)
		if not ok then
			return { ok = false, err = tostring(ret) }
		end
		return { ok = true, output = ("generated %d instance(s) in a %dx%d grid"):format(#made, rows, cols), result = made }
	end
	return { ok = false, err = "generate_build: unknown spec.kind '" .. tostring(spec.kind) .. "' (supported: grid, baseplate)" }
end

-- == Task 20: create_keyframe_sequence (animation build) ====================
-- Resolve an Enum item by name; fall back to `default` for missing/bad names
-- (per spec: never reject the whole call over one bad enum string).
local function enumOr(enumType: Enum, name: any, default: EnumItem): EnumItem
	if type(name) == "string" then
		local ok, item = pcall(function()
			return (enumType :: any)[name]
		end)
		if ok and typeof(item) == "EnumItem" then
			return item
		end
	end
	return default
end

-- Deserialize a tagged CFrame value; returns nil if it is not actually a CFrame.
local function toCFrame(v: any): CFrame?
	local ok, cf = pcall(function()
		return Serializer.deserialize(v)
	end)
	if ok and typeof(cf) == "CFrame" then
		return cf
	end
	return nil
end

local function createKeyframeSequence(p: any): any
	local kfs = p.keyframes
	if type(kfs) ~= "table" then
		return { ok = false, err = "create_keyframe_sequence needs a 'keyframes' array" }
	end
	local kfCount = #kfs
	if kfCount < 1 or kfCount > 240 then
		return { ok = false, err = "keyframes count out of range (1-240): " .. tostring(kfCount) }
	end
	-- Destination is a shared folder so the built sequence is easy to find and
	-- MANUALLY upload (right-click -> Save to Roblox, or open in the Animation
	-- Editor). Default base = ServerStorage; parentPath overrides the base if given.
	local baseParent
	if type(p.parentPath) == "string" and p.parentPath ~= "" then
		baseParent = resolvePath(p.parentPath)
		if not baseParent then
			return { ok = false, err = "path not found: " .. tostring(p.parentPath) }
		end
	else
		baseParent = game:GetService("ServerStorage")
	end
	local folderName = (type(p.folderName) == "string" and p.folderName ~= "") and p.folderName or "GeneratedAnimations"
	-- Validate EVERYTHING before creating anything (no partial writes).
	for i, kf in ipairs(kfs) do
		if type(kf) ~= "table" then
			return { ok = false, err = ("keyframe[%d]: not an object"):format(i) }
		end
		local t = kf.time
		if type(t) ~= "number" or t ~= t or t == math.huge or t == -math.huge or t < 0 then
			return { ok = false, err = ("keyframe[%d]: time must be finite and >= 0"):format(i) }
		end
		local poses = kf.poses
		if type(poses) ~= "table" then
			return { ok = false, err = ("keyframe[%d]: needs a 'poses' array"):format(i) }
		end
		local poseCount = #poses
		if poseCount < 1 or poseCount > 100 then
			return { ok = false, err = ("keyframe[%d]: poses count out of range (1-100): %d"):format(i, poseCount) }
		end
		local names: { [string]: boolean } = {}
		for j, pose in ipairs(poses) do
			if type(pose) ~= "table" or type(pose.part) ~= "string" or pose.part == "" then
				return { ok = false, err = ("keyframe[%d].pose[%d]: missing 'part' name"):format(i, j) }
			end
			if not toCFrame(pose.cframe) then
				return { ok = false, err = ("keyframe[%d].pose[%d]: invalid cframe"):format(i, j) }
			end
			names[pose.part] = true
		end
		-- parentPart must reference another pose.part in the SAME keyframe.
		for j, pose in ipairs(poses) do
			if pose.parentPart ~= nil then
				if type(pose.parentPart) ~= "string" or not names[pose.parentPart] then
					return {
						ok = false,
						err = ("keyframe[%d].pose[%d]: parentPart '%s' not found in this keyframe"):format(
							i,
							j,
							tostring(pose.parentPart)
						),
					}
				end
				if pose.parentPart == pose.part then
					return { ok = false, err = ("keyframe[%d].pose[%d]: parentPart cannot reference itself"):format(i, j) }
				end
			end
		end
	end

	local priority = enumOr(Enum.AnimationPriority, p.priority, Enum.AnimationPriority.Action)
	-- Whole build + (optional) preview registration in ONE undo waypoint.
	local ok, ret = recorded("create_keyframe_sequence", function()
		local seq = Instance.new("KeyframeSequence")
		seq.Name = (type(p.name) == "string" and p.name ~= "") and p.name or "Animation"
		seq.Loop = p.loop == true
		seq.Priority = priority
		local poseTotal = 0
		for i, kf in ipairs(kfs) do
			local keyframe = Instance.new("Keyframe")
			keyframe.Time = kf.time
			keyframe.Name = (type(kf.name) == "string" and kf.name ~= "") and kf.name or ("Keyframe" .. tostring(i))
			-- Build ALL poses before parenting any, so parentPart lookups resolve.
			local byName: { [string]: Instance } = {}
			local built: { { inst: Instance, parentPart: any } } = {}
			for _, pose in ipairs(kf.poses) do
				local pInst = Instance.new("Pose")
				pInst.Name = pose.part
				pInst.CFrame = toCFrame(pose.cframe) :: CFrame
				pInst.Weight = type(pose.weight) == "number" and pose.weight or 1
				pInst.EasingStyle = enumOr(Enum.PoseEasingStyle, pose.easingStyle, Enum.PoseEasingStyle.Linear)
				pInst.EasingDirection = enumOr(Enum.PoseEasingDirection, pose.easingDirection, Enum.PoseEasingDirection.In)
				byName[pose.part] = pInst
				table.insert(built, { inst = pInst, parentPart = pose.parentPart })
				poseTotal += 1
			end
			for _, b in ipairs(built) do
				if type(b.parentPart) == "string" then
					b.inst.Parent = byName[b.parentPart]
				else
					b.inst.Parent = keyframe
				end
			end
			keyframe.Parent = seq
		end
		-- Get-or-create the collection folder under the base, then park the KFS in it.
		local folder = baseParent:FindFirstChild(folderName)
		if not folder or not folder:IsA("Folder") then
			folder = Instance.new("Folder")
			folder.Name = folderName
			folder.Parent = baseParent
		end
		seq.Parent = folder
		local regId, regErr
		if p.registerPreview ~= false then
			local okReg, idOrErr = pcall(function()
				return game:GetService("KeyframeSequenceProvider"):RegisterKeyframeSequence(seq)
			end)
			if okReg then
				regId = tostring(idOrErr)
			else
				regErr = tostring(idOrErr)
			end
		end
		return { seq = seq, folder = folder, poseCount = poseTotal, regId = regId, regErr = regErr }
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	local seq = ret.seq
	local result: any = { path = seq:GetFullName(), keyframeCount = kfCount, poseCount = ret.poseCount }
	local output = "created KeyframeSequence in " .. ret.folder:GetFullName() .. " (ready for manual upload)"
	if ret.regId then
		result.tempAnimationId = ret.regId
	elseif ret.regErr then
		output = output .. " (preview registration failed: " .. ret.regErr .. ")"
	end
	return { ok = true, output = output, result = result }
end

-- == Task 22: create_sound / set_lighting (edit-context wrappers) =============
-- Coerce "rbxassetid://<n>" | "<n>" | <number> -> a canonical content id, else nil.
local function coerceAssetId(raw: any): string?
	if type(raw) == "number" then
		return "rbxassetid://" .. tostring(math.floor(raw))
	elseif type(raw) == "string" and raw ~= "" then
		if string.match(raw, "^%d+$") then
			return "rbxassetid://" .. raw
		end
		return raw
	end
	return nil
end

local ROLLOFF_MODES: { [string]: boolean } =
	{ Inverse = true, Linear = true, LinearSquare = true, InverseTapered = true }

local function createSound(p: any): any
	local parent = resolvePath(p.parentPath)
	if not parent then
		return { ok = false, err = "path not found: " .. tostring(p.parentPath) }
	end
	local soundId = coerceAssetId(p.soundId)
	if not soundId then
		return { ok = false, err = "create_sound: invalid soundId" }
	end
	local ok, ret = recorded("create_sound", function()
		local s = Instance.new("Sound")
		s.Name = (type(p.name) == "string" and p.name ~= "") and p.name or "Sound"
		s.SoundId = soundId
		local vol = type(p.volume) == "number" and p.volume or 0.5
		s.Volume = math.clamp(vol, 0, 10)
		if type(p.looped) == "boolean" then
			s.Looped = p.looped
		end
		if type(p.playbackSpeed) == "number" then
			s.PlaybackSpeed = p.playbackSpeed
		end
		if type(p.rollOffMode) == "string" and ROLLOFF_MODES[p.rollOffMode] then
			s.RollOffMode = (Enum.RollOffMode :: any)[p.rollOffMode]
		end
		if type(p.rollOffMinDistance) == "number" then
			s.RollOffMinDistance = p.rollOffMinDistance
		end
		if type(p.rollOffMaxDistance) == "number" then
			s.RollOffMaxDistance = p.rollOffMaxDistance
		end
		s.Parent = parent
		if p.playOnCreate == true then
			pcall(function()
				s:Play()
			end)
		end
		return s
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = "created Sound under " .. parent:GetFullName(), result = { path = ret:GetFullName() } }
end

local LIGHTING_EFFECT_CLASSES: { [string]: boolean } = {
	Atmosphere = true,
	Sky = true,
	BloomEffect = true,
	ColorCorrectionEffect = true,
	DepthOfFieldEffect = true,
	SunRaysEffect = true,
}

local function setLighting(p: any): any
	local Lighting = game:GetService("Lighting")
	local props = p.properties
	local effects = p.effects
	if props ~= nil and type(props) ~= "table" then
		return { ok = false, err = "set_lighting: 'properties' must be an object" }
	end
	if effects ~= nil and type(effects) ~= "table" then
		return { ok = false, err = "set_lighting: 'effects' must be an object" }
	end
	-- Phase 1: validate ALL keys/classes before any write (no partial commit). A real
	-- property is readable; an unknown key errors the read. Effect classes are
	-- whitelisted; effect prop names are validated against a scratch instance.
	local lt = Lighting :: any
	if type(props) == "table" then
		for key in pairs(props) do
			local okRead = pcall(function()
				return lt[key]
			end)
			if not okRead then
				return { ok = false, err = "set_lighting: unknown Lighting property '" .. tostring(key) .. "'" }
			end
		end
	end
	if type(effects) == "table" then
		for className, pmap in pairs(effects) do
			if not LIGHTING_EFFECT_CLASSES[className] then
				return { ok = false, err = "set_lighting: unknown effect class '" .. tostring(className) .. "'" }
			end
			if type(pmap) == "table" then
				local sample = Lighting:FindFirstChildOfClass(className)
				local scratch = nil
				if not sample then
					scratch = Instance.new(className)
					sample = scratch
				end
				local st = sample :: any
				for key in pairs(pmap) do
					local okRead = pcall(function()
						return st[key]
					end)
					if not okRead then
						if scratch then
							scratch:Destroy()
						end
						return { ok = false, err = "set_lighting: unknown " .. className .. " property '" .. tostring(key) .. "'" }
					end
				end
				if scratch then
					scratch:Destroy()
				end
			end
		end
	end
	-- Phase 2: apply, all validated -> single undo.
	local applied = {}
	local effectsApplied = {}
	local ok, ret = recorded("set_lighting", function()
		if type(props) == "table" then
			for key, raw in pairs(props) do
				lt[key] = Serializer.deserialize(raw)
				table.insert(applied, key)
			end
		end
		if type(effects) == "table" then
			for className, pmap in pairs(effects) do
				local inst = Lighting:FindFirstChildOfClass(className)
				if not inst then
					inst = Instance.new(className)
					inst.Parent = Lighting
				end
				local it = inst :: any
				if type(pmap) == "table" then
					for key, raw in pairs(pmap) do
						it[key] = Serializer.deserialize(raw)
					end
				end
				table.insert(effectsApplied, className)
			end
		end
		return true
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, result = { applied = applied, effects = effectsApplied } }
end

-- Multi-root scene import. scene = { roots: [ { parentPath, build } ] } (a bare
-- array is also accepted). mode='replace' clears each parent first (gated by confirm).
local function importScene(p: any): any
	local scene = p.scene
	local roots: any = nil
	if type(scene) == "table" then
		if type(scene.roots) == "table" then
			roots = scene.roots
		elseif scene[1] ~= nil then
			roots = scene
		end
	end
	if type(roots) ~= "table" then
		return { ok = false, err = "import_scene needs a 'scene' with roots[] of { parentPath, build }" }
	end
	local mode = p.mode or "merge"
	if mode == "replace" and p.confirm ~= true then
		return {
			ok = false,
			err = "import_scene mode='replace' is destructive (clears each target parent's children first); "
				.. "pass confirm:true to proceed.",
		}
	end
	local created, failed = {}, {}
	local ok, ret = recorded("import_scene", function()
		for _, entry in ipairs(roots) do
			local parent = resolvePath(entry.parentPath)
			if not parent then
				table.insert(failed, { parentPath = entry.parentPath, err = "parent not found" })
				continue
			end
			if mode == "replace" then
				for _, c in ipairs(parent:GetChildren()) do
					pcall(function()
						c:Destroy()
					end)
				end
			end
			if type(entry.build) == "table" and entry.build.className then
				local cok, cret = pcall(function()
					return instantiateBuild(entry.build, parent)
				end)
				if cok then
					table.insert(created, pathInfo(cret))
				else
					table.insert(failed, { parentPath = entry.parentPath, err = tostring(cret) })
				end
			else
				table.insert(failed, { parentPath = entry.parentPath, err = "entry has no build.className" })
			end
		end
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return {
		ok = true,
		output = ("imported %d root(s), %d failed"):format(#created, #failed),
		result = { created = created, failed = failed },
	}
end

-- Build a GUI hierarchy. Default parent = a fresh ScreenGui in StarterGui.
local function createUiTree(p: any): any
	if type(p.tree) ~= "table" or not p.tree.className then
		return { ok = false, err = "create_ui_tree needs a 'tree' object with a className" }
	end
	local ok, ret = recorded("create_ui_tree", function()
		local parent: Instance
		if p.parentPath then
			local resolved = resolvePath(p.parentPath)
			if not resolved then
				error("parent path not found: " .. tostring(p.parentPath))
			end
			parent = resolved
		else
			local sg = Instance.new("ScreenGui")
			sg.Name = (p.tree.name and tostring(p.tree.name) .. "Gui") or "McpScreenGui"
			sg.ResetOnSpawn = false
			sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
			sg.Parent = game:GetService("StarterGui")
			parent = sg
		end
		return instantiateBuild(p.tree, parent)
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = "built UI tree at " .. ret:GetFullName(), result = pathInfo(ret) }
end

-- Match instance names AND full paths (distinct from grep_scripts = content).
local function searchFiles(p: any): any
	local pattern = p.pattern
	if not pattern or pattern == "" then
		return { ok = false, err = "search_files: 'pattern' is required" }
	end
	local root = resolvePath(p.root or "game") or game
	local useRegex = p.regex == true
	local needle = useRegex and pattern or string.lower(pattern)
	local limit = p.limit or 500
	local out = {}
	local function hit(s: string): boolean
		if useRegex then
			return string.find(s, pattern) ~= nil
		end
		return string.find(string.lower(s), needle, 1, true) ~= nil
	end
	for _, inst in ipairs(root:GetDescendants()) do
		if hit(inst.Name) or hit(inst:GetFullName()) then
			table.insert(out, pathInfo(inst))
			if #out >= limit then
				break
			end
		end
	end
	return { ok = true, result = { matches = out, truncated = #out >= limit } }
end

-- == Task 16 Batch B: raycast / bounds / camera / perf / group / align =======
-- Coerce an [x,y,z] array (or a serialized/tagged Vector3) to a Vector3.
local function arrToV3(a: any): Vector3?
	if typeof(a) == "Vector3" then
		return a
	end
	if type(a) ~= "table" then
		return nil
	end
	if a.__t == "Vector3" then
		return Serializer.deserialize(a)
	end
	local x = a[1] or a.x
	local y = a[2] or a.y
	local z = a[3] or a.z
	if x and y and z then
		return Vector3.new(x, y, z)
	end
	return nil
end

local function axisGet(v: Vector3, comp: string): number
	if comp == "X" then
		return v.X
	elseif comp == "Y" then
		return v.Y
	end
	return v.Z
end

local function axisVector(comp: string, v: number): Vector3
	if comp == "X" then
		return Vector3.new(v, 0, 0)
	elseif comp == "Y" then
		return Vector3.new(0, v, 0)
	end
	return Vector3.new(0, 0, v)
end

local function raycastCmd(p: any): any
	local origin = arrToV3(p.origin)
	local dir = arrToV3(p.direction)
	if not origin or not dir then
		return { ok = false, err = "raycast needs origin:[x,y,z] and direction:[x,y,z]" }
	end
	if dir.Magnitude == 0 then
		return { ok = false, err = "raycast direction cannot be zero" }
	end
	local maxDist = p.maxDistance or 1000
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	local ignore = {}
	if type(p.ignorePaths) == "table" then
		for _, ip in ipairs(p.ignorePaths) do
			local inst = resolvePath(ip)
			if inst then
				table.insert(ignore, inst)
			end
		end
	end
	params.FilterDescendantsInstances = ignore
	local result = workspace:Raycast(origin, dir.Unit * maxDist, params)
	if not result then
		return { ok = true, result = { hit = false } }
	end
	return {
		ok = true,
		result = {
			hit = true,
			hitPath = result.Instance and result.Instance:GetFullName() or nil,
			position = Serializer.serialize(result.Position),
			normal = Serializer.serialize(result.Normal),
			material = result.Material.Name,
			distance = result.Distance,
		},
	}
end

local function boundsOf(inst: Instance): (CFrame?, Vector3?)
	if inst:IsA("Model") then
		local cf, size
		local ok = pcall(function()
			cf, size = (inst :: any):GetBoundingBox()
		end)
		if ok then
			return cf, size
		end
		return nil, nil
	elseif inst:IsA("BasePart") then
		return (inst :: any).CFrame, (inst :: any).Size
	end
	return nil, nil
end

local function getBoundingBox(p: any): any
	local inst = resolvePath(p.path)
	if not inst then
		return { ok = false, err = "path not found: " .. tostring(p.path) }
	end
	local cf, size = boundsOf(inst)
	if not cf or not size then
		return { ok = false, err = p.path .. " is not a Model or BasePart (no bounding box)" }
	end
	return {
		ok = true,
		result = { path = inst:GetFullName(), cframe = Serializer.serialize(cf), size = Serializer.serialize(size) },
	}
end

-- World-space AABB expansion over a part's 8 corners.
local function expandAabb(min: Vector3, max: Vector3, cf: CFrame, size: Vector3): (Vector3, Vector3)
	local hs = size / 2
	for sx = -1, 1, 2 do
		for sy = -1, 1, 2 do
			for sz = -1, 1, 2 do
				local wp = cf * Vector3.new(hs.X * sx, hs.Y * sy, hs.Z * sz)
				min = Vector3.new(math.min(min.X, wp.X), math.min(min.Y, wp.Y), math.min(min.Z, wp.Z))
				max = Vector3.new(math.max(max.X, wp.X), math.max(max.Y, wp.Y), math.max(max.Z, wp.Z))
			end
		end
	end
	return min, max
end

local function collectParts(insts: { Instance }): { BasePart }
	local parts = {}
	for _, inst in ipairs(insts) do
		if inst:IsA("BasePart") then
			table.insert(parts, inst)
		end
		for _, d in ipairs(inst:GetDescendants()) do
			if d:IsA("BasePart") then
				table.insert(parts, d)
			end
		end
	end
	return parts
end

local function getSelectionBounds(): any
	local sel = Selection:Get()
	if #sel == 0 then
		return { ok = false, err = "get_selection_bounds: selection is empty" }
	end
	local parts = collectParts(sel)
	if #parts == 0 then
		return { ok = false, err = "get_selection_bounds: selection contains no BaseParts" }
	end
	local min = Vector3.new(math.huge, math.huge, math.huge)
	local max = Vector3.new(-math.huge, -math.huge, -math.huge)
	for _, part in ipairs(parts) do
		min, max = expandAabb(min, max, (part :: any).CFrame, (part :: any).Size)
	end
	local center = (min + max) / 2
	return {
		ok = true,
		result = {
			partCount = #parts,
			center = Serializer.serialize(center),
			size = Serializer.serialize(max - min),
			min = Serializer.serialize(min),
			max = Serializer.serialize(max),
		},
	}
end

local function getCamera(): any
	local cam = workspace.CurrentCamera
	if not cam then
		return { ok = false, err = "no CurrentCamera in this context" }
	end
	return {
		ok = true,
		result = {
			cframe = Serializer.serialize(cam.CFrame),
			position = Serializer.serialize(cam.CFrame.Position),
			fieldOfView = cam.FieldOfView,
		},
	}
end

-- View-only (not a place mutation): kept OUT of WRITE_TOOLS so read-only sessions
-- can still aim the camera.
local function setCamera(p: any): any
	local cam = workspace.CurrentCamera
	if not cam then
		return { ok = false, err = "no CurrentCamera in this context" }
	end
	local ok, err = pcall(function()
		if p.cframe ~= nil then
			cam.CFrame = Serializer.deserialize(p.cframe)
		elseif p.position ~= nil then
			local pos = arrToV3(p.position)
			if not pos then
				error("set_camera: invalid position")
			end
			if p.lookAt ~= nil then
				local look = arrToV3(p.lookAt)
				if not look then
					error("set_camera: invalid lookAt")
				end
				cam.CFrame = CFrame.lookAt(pos, look)
			else
				cam.CFrame = CFrame.new(pos)
			end
		else
			error("set_camera needs cframe, or position (+ optional lookAt)")
		end
	end)
	if not ok then
		return { ok = false, err = tostring(err) }
	end
	return { ok = true, output = "moved camera", result = { cframe = Serializer.serialize(cam.CFrame) } }
end

local function focusInstance(p: any): any
	local inst = resolvePath(p.path)
	if not inst then
		return { ok = false, err = "path not found: " .. tostring(p.path) }
	end
	local ok, ret = recorded("focus_instance", function()
		Selection:Set({ inst })
	end)
	-- aim the camera at the instance (view change, outside the undo recording)
	local cam = workspace.CurrentCamera
	if cam then
		local cf, size = boundsOf(inst)
		if cf and size then
			local radius = math.max(size.X, size.Y, size.Z, 1)
			local dist = radius * 2 + 5
			local pos = cf.Position + Vector3.new(1, 1, 1).Unit * dist
			pcall(function()
				cam.CFrame = CFrame.lookAt(pos, cf.Position)
			end)
		end
	end
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = "focused " .. inst:GetFullName(), result = pathInfo(inst) }
end

local function getPerfStats(): any
	local totalMem: any = nil
	pcall(function()
		totalMem = Stats:GetTotalMemoryUsageMb()
	end)
	local instanceCount, partCount, scriptCount = 0, 0, 0
	for _, d in ipairs(game:GetDescendants()) do
		instanceCount += 1
		if d:IsA("BasePart") then
			partCount += 1
		elseif d:IsA("LuaSourceContainer") then
			scriptCount += 1
		end
	end
	return {
		ok = true,
		result = {
			totalMemoryMb = totalMem,
			instanceCount = instanceCount,
			partCount = partCount,
			scriptCount = scriptCount,
		},
	}
end

local function groupInstances(p: any): any
	local paths = p.paths
	if type(paths) ~= "table" or #paths == 0 then
		return { ok = false, err = "group_instances needs a non-empty 'paths' array" }
	end
	local insts = {}
	local commonParent: Instance? = nil
	for _, path in ipairs(paths) do
		local inst = resolvePath(path)
		if inst then
			table.insert(insts, inst)
			if not commonParent then
				commonParent = inst.Parent
			end
		end
	end
	if #insts == 0 then
		return { ok = false, err = "group_instances: no valid instances at the given paths" }
	end
	local ok, ret = recorded("group_instances", function()
		local model = Instance.new("Model")
		model.Name = p.name or "Group"
		model.Parent = commonParent or workspace
		for _, inst in ipairs(insts) do
			inst.Parent = model
		end
		for _, inst in ipairs(insts) do
			if inst:IsA("BasePart") then
				model.PrimaryPart = inst
				break
			end
		end
		return model
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = ("grouped %d instance(s)"):format(#insts), result = pathInfo(ret) }
end

local function ungroupInstance(p: any): any
	local inst = resolvePath(p.path)
	if not inst then
		return { ok = false, err = "path not found: " .. tostring(p.path) }
	end
	if not (inst:IsA("Model") or inst:IsA("Folder")) then
		return { ok = false, err = "ungroup_instance target must be a Model or Folder (got " .. inst.ClassName .. ")" }
	end
	local parent = inst.Parent
	if not parent then
		return { ok = false, err = "cannot ungroup the root" }
	end
	local moved = {}
	local ok, ret = recorded("ungroup_instance", function()
		for _, c in ipairs(inst:GetChildren()) do
			c.Parent = parent
			table.insert(moved, pathInfo(c))
		end
		inst:Destroy()
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = ("ungrouped %d child(ren)"):format(#moved), result = moved }
end

local AXIS_INDEX = { x = "X", y = "Y", z = "Z" }
local function alignInstances(p: any): any
	local axisKey = string.lower(tostring(p.axis or ""))
	local comp = AXIS_INDEX[axisKey]
	if not comp then
		return { ok = false, err = "align_instances needs axis 'x', 'y', or 'z'" }
	end
	local mode = p.mode or "center"
	local paths = p.paths
	if type(paths) ~= "table" or #paths < 2 then
		return { ok = false, err = "align_instances needs at least 2 'paths'" }
	end
	local items = {}
	for _, path in ipairs(paths) do
		local inst = resolvePath(path)
		if inst and inst:IsA("PVInstance") then
			local pivot = (inst :: any):GetPivot()
			table.insert(items, { inst = inst, v = axisGet(pivot.Position, comp) })
		end
	end
	if #items < 2 then
		return { ok = false, err = "align_instances needs at least 2 PVInstances (parts/models)" }
	end
	local count = 0
	local ok, ret = recorded("align_instances", function()
		if mode == "distribute" then
			table.sort(items, function(a, b)
				return a.v < b.v
			end)
			local startV = items[1].v
			local spacing = p.spacing and tonumber(p.spacing) or nil
			local endV = items[#items].v
			for i, it in ipairs(items) do
				local targetV
				if spacing then
					targetV = startV + spacing * (i - 1)
				else
					targetV = startV + (endV - startV) * ((i - 1) / (#items - 1))
				end
				local delta = targetV - it.v
				if math.abs(delta) > 1e-6 then
					local target = it.inst :: any
					target:PivotTo(target:GetPivot() + axisVector(comp, delta))
					count += 1
				end
			end
		else
			local ref
			if mode == "min" then
				ref = math.huge
				for _, it in ipairs(items) do
					ref = math.min(ref, it.v)
				end
			elseif mode == "max" then
				ref = -math.huge
				for _, it in ipairs(items) do
					ref = math.max(ref, it.v)
				end
			else
				local sum = 0
				for _, it in ipairs(items) do
					sum += it.v
				end
				ref = sum / #items
			end
			for _, it in ipairs(items) do
				local delta = ref - it.v
				if math.abs(delta) > 1e-6 then
					local target = it.inst :: any
					target:PivotTo(target:GetPivot() + axisVector(comp, delta))
					count += 1
				end
			end
		end
	end)
	if not ok then
		return { ok = false, err = tostring(ret) }
	end
	return { ok = true, output = ("aligned %d instance(s) on %s (%s)"):format(count, axisKey, mode), result = { moved = count } }
end

local function measureDistance(p: any): any
	local ia, ib = resolvePath(p.pathA), resolvePath(p.pathB)
	if not ia or not ib then
		return { ok = false, err = "measure_distance: one or both paths not found" }
	end
	local function pivotPos(inst: Instance): Vector3?
		if inst:IsA("PVInstance") then
			local ok, piv = pcall(function()
				return (inst :: any):GetPivot()
			end)
			if ok then
				return piv.Position
			end
		end
		return nil
	end
	local pa, pb = pivotPos(ia), pivotPos(ib)
	if not pa or not pb then
		return { ok = false, err = "measure_distance: both instances must be PVInstances (parts/models)" }
	end
	return {
		ok = true,
		result = {
			distance = (pa - pb).Magnitude,
			a = ia:GetFullName(),
			b = ib:GetFullName(),
			positionA = Serializer.serialize(pa),
			positionB = Serializer.serialize(pb),
		},
	}
end

-- Dispatch one command table -> result table.
-- (enable_playtest_agent is handled in the plugin entry, not here.)
function Executor.execute(cmd: { type: string, payload: any }): any
	local p = cmd.payload or {}
	if cmd.type == "run_luau" then
		return runLuau(p.code)
	elseif cmd.type == "get_instance_tree" then
		return getInstanceTree(p.path or "game", p.maxDepth or 4)
	elseif cmd.type == "set_property" then
		return setProperty(p.path, p.property, p.value)
	elseif cmd.type == "write_script" then
		return writeScript(p.path, p.source, p.className)
	-- read / inspect
	elseif cmd.type == "read_console" then
		return readConsole(p.count or 100, p.levelFilter)
	elseif cmd.type == "get_selection" then
		return getSelection()
	elseif cmd.type == "search_instances" then
		return searchInstances(p)
	elseif cmd.type == "get_script_source" then
		return getScriptSource(p.path)
	elseif cmd.type == "list_scripts" then
		return listScripts(p.root or "game")
	elseif cmd.type == "get_place_info" then
		return getPlaceInfo()
	elseif cmd.type == "get_tagged" then
		return getTagged(p.tag)
	elseif cmd.type == "get_properties" then
		return getProperties(p.path, p.propertyNames)
	-- write / edit
	elseif cmd.type == "set_selection" then
		return setSelection(p.paths or {})
	elseif cmd.type == "create_instance" then
		return createInstance(p)
	elseif cmd.type == "delete_instance" then
		return deleteInstance(p.path)
	elseif cmd.type == "clone_instance" then
		return cloneInstance(p.path, p.parentPath)
	elseif cmd.type == "rename_instance" then
		return renameInstance(p.path, p.name)
	elseif cmd.type == "set_parent" then
		return setParent(p.path, p.parentPath)
	elseif cmd.type == "move_instance" then
		return moveInstance(p)
	elseif cmd.type == "bulk_set_property" then
		return bulkSetProperty(p.paths or {}, p.property, p.value)
	elseif cmd.type == "tag_instance" then
		return tagInstance(p.path, p.tag, true)
	elseif cmd.type == "untag_instance" then
		return tagInstance(p.path, p.tag, false)
	elseif cmd.type == "insert_asset" then
		return insertAsset(p.assetId, p.parentPath)
	-- experimental
	elseif cmd.type == "capture_viewport" then
		return captureViewport()
	elseif cmd.type == "playtest_control" then
		return playtestControl(p)
	elseif cmd.type == "get_playtest_output" then
		return getPlaytestOutput(p)
	elseif cmd.type == "get_playtest_status" then
		return getPlaytestStatus()
	-- attributes
	elseif cmd.type == "get_attribute" then
		return getAttribute(p.path, p.name)
	elseif cmd.type == "get_attributes" then
		return getAttributes(p.path)
	elseif cmd.type == "set_attribute" then
		return setAttribute(p.path, p.name, p.value)
	elseif cmd.type == "set_attributes" then
		return setAttributes(p.path, p.attributes)
	elseif cmd.type == "delete_attribute" then
		return deleteAttribute(p.path, p.name)
	-- script editing depth
	elseif cmd.type == "edit_script_lines" then
		return editScriptLines(p)
	elseif cmd.type == "insert_script_lines" then
		return insertScriptLines(p)
	elseif cmd.type == "delete_script_lines" then
		return deleteScriptLines(p)
	elseif cmd.type == "find_and_replace_in_scripts" then
		return findReplaceInScripts(p)
	elseif cmd.type == "grep_scripts" then
		return grepScripts(p)
	elseif cmd.type == "get_script_analysis" then
		return getScriptAnalysis(p)
	-- undo/redo + mass ops
	elseif cmd.type == "undo" then
		return undo()
	elseif cmd.type == "redo" then
		return redo()
	elseif cmd.type == "mass_create_objects" then
		return massCreateObjects(p.items)
	elseif cmd.type == "mass_duplicate" then
		return massDuplicate(p)
	elseif cmd.type == "smart_duplicate" then
		return smartDuplicate(p)
	elseif cmd.type == "mass_get_property" then
		return massGetProperty(p.paths or {}, p.property)
	elseif cmd.type == "mass_set_property" then
		return bulkSetProperty(p.paths or {}, p.property, p.value)
	-- deeper inspection
	elseif cmd.type == "get_class_info" then
		return getClassInfo(p.className)
	elseif cmd.type == "get_services" then
		return getServices()
	elseif cmd.type == "get_descendants" then
		return getDescendants(p.path or "game", p.maxDepth)
	elseif cmd.type == "get_connected_instances" then
		return getConnectedInstances(p.path)
	elseif cmd.type == "compare_instances" then
		return compareInstances(p.pathA, p.pathB)
	elseif cmd.type == "get_project_structure" then
		return getProjectStructure()
	elseif cmd.type == "get_file_tree" then
		return getFileTree(p.root)
	elseif cmd.type == "set_properties" then
		return setProperties(p.path, p.properties)
	elseif cmd.type == "search_by_property" then
		return searchByProperty(p)
	elseif cmd.type == "get_tags" then
		return getTags(p.path)
	-- assets / marketplace
	elseif cmd.type == "get_asset_details" then
		return getAssetDetails(p.assetId)
	elseif cmd.type == "get_asset_thumbnail" then
		return getAssetThumbnail(p.assetId, p.size)
	elseif cmd.type == "preview_asset" then
		return previewAsset(p.assetId)
	elseif cmd.type == "search_materials" then
		return searchMaterials(p.query)
	elseif cmd.type == "search_assets" then
		return searchAssets()
	elseif cmd.type == "list_library" then
		return listLibrary()
	elseif cmd.type == "upload_decal" then
		return uploadDecal()
	-- build / scene / UI tree / file search (Task 16 Batch A)
	elseif cmd.type == "export_build" then
		return exportBuild(p)
	elseif cmd.type == "create_build" then
		return createBuild(p)
	elseif cmd.type == "import_build" then
		return importBuild(p)
	elseif cmd.type == "generate_build" then
		return generateBuild(p)
	elseif cmd.type == "create_keyframe_sequence" then
		return createKeyframeSequence(p)
	elseif cmd.type == "create_sound" then
		return createSound(p)
	elseif cmd.type == "set_lighting" then
		return setLighting(p)
	elseif cmd.type == "import_scene" then
		return importScene(p)
	elseif cmd.type == "create_ui_tree" then
		return createUiTree(p)
	elseif cmd.type == "search_files" then
		return searchFiles(p)
	-- raycast / bounds / camera / perf / group / align (Task 16 Batch B)
	elseif cmd.type == "raycast" then
		return raycastCmd(p)
	elseif cmd.type == "get_bounding_box" then
		return getBoundingBox(p)
	elseif cmd.type == "get_selection_bounds" then
		return getSelectionBounds()
	elseif cmd.type == "get_camera" then
		return getCamera()
	elseif cmd.type == "set_camera" then
		return setCamera(p)
	elseif cmd.type == "focus_instance" then
		return focusInstance(p)
	elseif cmd.type == "get_perf_stats" then
		return getPerfStats()
	elseif cmd.type == "group_instances" then
		return groupInstances(p)
	elseif cmd.type == "ungroup_instance" then
		return ungroupInstance(p)
	elseif cmd.type == "align_instances" then
		return alignInstances(p)
	elseif cmd.type == "measure_distance" then
		return measureDistance(p)
	-- input simulation
	elseif cmd.type == "simulate_keyboard_input" then
		return simulateKeyboardInput(p)
	elseif cmd.type == "simulate_mouse_input" then
		return simulateMouseInput(p)
	elseif cmd.type == "character_navigation" then
		return characterNavigation(p)
	else
		return { ok = false, err = "unknown command type: " .. tostring(cmd.type) }
	end
end

-- Called from the edit plugin's maintenance loop when a server context is live,
-- so a watched playtest doesn't look idle even without get_playtest_output calls.
function Executor.notePlaytestActivity()
	if playtestStartedAt ~= nil then
		playtestLastActivity = os.time()
	end
end

-- Auto-stop safety net for a Run-mode playtest started via playtest_control.
-- Stops if it has run past maxSeconds OR been idle past idleSeconds. Returns a
-- reason string when it stops (for the caller to log), else nil. No-op for
-- user-initiated playtests (playtestStartedAt is nil unless we started it).
function Executor.maybeAutoStopPlaytest(opts: any): string?
	if not opts or opts.enabled == false then
		return nil
	end
	-- A StudioTestService run lives in a separate DataModel, so edit-context
	-- RunService:IsRunning() is false; playtestStartedAt being set is our liveness.
	if playtestStartedAt == nil then
		return nil
	end
	local now = os.time()
	local maxSeconds = tonumber(opts.maxSeconds) or 300
	local idleSeconds = tonumber(opts.idleSeconds) or 120
	local ranFor = now - playtestStartedAt
	local idleFor = now - playtestLastActivity
	local reason: string? = nil
	if ranFor > maxSeconds then
		reason = ("ran %ds (cap %ds)"):format(ranFor, maxSeconds)
	elseif idleFor > idleSeconds then
		reason = ("idle %ds (cap %ds)"):format(idleFor, idleSeconds)
	end
	if not reason then
		return nil
	end
	-- Signal the in-run listener to EndTest; fall back to a direct EndTest.
	pcall(function()
		warn(PLAYTEST_STOP_SIGNAL)
	end)
	pcall(function()
		StudioTestService:EndTest("stopped_by_mcp")
	end)
	cleanupPlaytestStopListener()
	playtestCapturing = false
	playtestStartedAt = nil
	return reason
end

Executor.resolvePath = resolvePath
return Executor
]]></ProtectedString>
   </Properties>
  </Item>
  <Item class="ModuleScript" referent="RBX5">
   <Properties>
    <string name="Name">StatusWidget</string>
    <ProtectedString name="Source"><![CDATA[-- Dock widget: Nik Studio MCP control panel.
-- Layered dark dashboard: gradient-lifted header with a pulsing status pill,
-- a monospace address field-chip, a horizontally-scrolling port lane (state-
-- colored chips + pinned "+"), four status rows, an animated arm toggle on the
-- Playtest agent row, and a sheened Connect/Disconnect button.
-- Polish (hover, press-squash, pulse, soft click) per addictive-game-feel;
-- UIListLayout + AutomaticSize + ScrollingFrame sizing per roblox-ui-layout.
local StatusWidget = {}
StatusWidget.__index = StatusWidget

local SoundService = game:GetService("SoundService")
local TweenService = game:GetService("TweenService")

local Settings = require(script.Parent.Settings)

-- Style-from-config: one place to retune the panel.
-- Restrained dev-tool dark theme: near-black neutrals, subtle elevation, ONE
-- desaturated slate accent, muted semantic colors. Tuned for calm + legibility.
local Theme = {
	bg = Color3.fromRGB(17, 18, 22),
	bg2 = Color3.fromRGB(12, 13, 16),
	panel = Color3.fromRGB(24, 26, 31),
	panelHi = Color3.fromRGB(33, 36, 43),
	field = Color3.fromRGB(19, 20, 25),
	stroke = Color3.fromRGB(43, 46, 55),
	text = Color3.fromRGB(225, 227, 233),
	subtext = Color3.fromRGB(129, 134, 147),
	green = Color3.fromRGB(108, 167, 130), -- muted sage = ok
	amber = Color3.fromRGB(196, 165, 102), -- muted = partial
	red = Color3.fromRGB(196, 111, 111), -- desaturated = error/destructive
	accent = Color3.fromRGB(112, 132, 170), -- single restrained slate accent
	accent2 = Color3.fromRGB(132, 148, 184),
	idle = Color3.fromRGB(90, 95, 107),
}

local STATE_COLOR = {
	Connected = Theme.green,
	Connecting = Theme.amber,
	Disconnected = Theme.red,
}
local WORD = {
	Connected = "Connected",
	Connecting = "Connecting...",
	Disconnected = "Disconnected",
}
local AGENT_COLOR = {
	off = Theme.idle,
	armed = Theme.amber,
	active = Theme.green,
	error = Theme.red,
}

-- -- builders ---------------------------------------------------------------
local function corner(parent: Instance, radius: number): UICorner
	local c = Instance.new("UICorner")
	c.CornerRadius = UDim.new(0, radius)
	c.Parent = parent
	return c
end

local function padding(parent: Instance, top: number, right: number, bottom: number, left: number): UIPadding
	local p = Instance.new("UIPadding")
	p.PaddingTop = UDim.new(0, top)
	p.PaddingRight = UDim.new(0, right)
	p.PaddingBottom = UDim.new(0, bottom)
	p.PaddingLeft = UDim.new(0, left)
	p.Parent = parent
	return p
end

local function vlist(parent: Instance, gap: number): UIListLayout
	local l = Instance.new("UIListLayout")
	l.FillDirection = Enum.FillDirection.Vertical
	l.Padding = UDim.new(0, gap)
	l.SortOrder = Enum.SortOrder.LayoutOrder
	l.Parent = parent
	return l
end

local function hlist(parent: Instance, gap: number): UIListLayout
	local l = Instance.new("UIListLayout")
	l.FillDirection = Enum.FillDirection.Horizontal
	l.Padding = UDim.new(0, gap)
	l.VerticalAlignment = Enum.VerticalAlignment.Center
	l.SortOrder = Enum.SortOrder.LayoutOrder
	l.Parent = parent
	return l
end

local function stroke(parent: Instance, color: Color3, trans: number?): UIStroke
	local s = Instance.new("UIStroke")
	s.Color = color
	s.Transparency = trans or 0
	s.Thickness = 1
	s.Parent = parent
	return s
end

-- Subtle vertical sheen. UIGradient multiplies the background, so white->gray
-- gives a top-lit lift on any base color (survives recoloring).
local function sheen(parent: Instance, bottom: number, rotation: number?): UIGradient
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new(Color3.new(1, 1, 1), Color3.fromRGB(bottom, bottom, bottom))
	g.Rotation = rotation or 90
	g.Parent = parent
	return g
end

-- Two-stop color gradient (opaque; root background depth).
local function gradient(parent: Instance, cTop: Color3, cBottom: Color3, rot: number?): UIGradient
	local g = Instance.new("UIGradient")
	g.Color = ColorSequence.new(cTop, cBottom)
	g.Rotation = rot or 90
	g.Parent = parent
	return g
end

-- A grouped content card: lifted panel + sheen + hairline, padded vertical stack.
local function card(parent: Instance, order: number): Frame
	local c = Instance.new("Frame")
	c.Size = UDim2.new(1, 0, 0, 0)
	c.AutomaticSize = Enum.AutomaticSize.Y
	c.BackgroundColor3 = Theme.panel
	c.BorderSizePixel = 0
	c.LayoutOrder = order
	corner(c, 10)
	stroke(c, Theme.stroke, 0.18)
	sheen(c, 244)
	padding(c, 12, 12, 12, 12)
	vlist(c, 10)
	c.Parent = parent
	return c
end

local function textConstraint(lbl: Instance, max: number, min: number?)
	local c = Instance.new("UITextSizeConstraint")
	c.MaxTextSize = max
	c.MinTextSize = min or 8
	c.Parent = lbl
	return c
end

-- A status row: dot + label, with a right-side slot for trailing controls.
local function makeRow(parent: Instance, order: number, label: string)
	local row = Instance.new("Frame")
	row.Name = label
	row.Size = UDim2.new(1, 0, 0, 26)
	row.BackgroundTransparency = 1
	row.LayoutOrder = order
	row.Parent = parent

	local dot = Instance.new("Frame")
	dot.Name = "Dot"
	dot.Size = UDim2.fromOffset(9, 9)
	dot.Position = UDim2.new(0, 1, 0.5, 0)
	dot.AnchorPoint = Vector2.new(0, 0.5)
	dot.BackgroundColor3 = Theme.idle
	corner(dot, 5)
	dot.Parent = row

	local text = Instance.new("TextLabel")
	text.Size = UDim2.new(1, -64, 1, 0)
	text.Position = UDim2.fromOffset(20, 0)
	text.BackgroundTransparency = 1
	text.Font = Enum.Font.GothamMedium
	text.Text = label
	text.TextColor3 = Theme.text
	text.TextXAlignment = Enum.TextXAlignment.Left
	text.TextYAlignment = Enum.TextYAlignment.Center
	text.TextScaled = true
	textConstraint(text, 14, 10)
	text.Parent = row

	return row, dot
end

-- color a row dot by tri-state ok
local function paintDot(dot: Frame, ok: boolean?)
	if ok == nil then
		dot.BackgroundColor3 = Theme.idle
	elseif ok then
		dot.BackgroundColor3 = Theme.green
	else
		dot.BackgroundColor3 = Theme.red
	end
end

-- A reusable on/off switch pinned to the right of its parent row. Returns the
-- clickable track plus a setter that animates to the given state.
local function makeSwitch(parent: Instance): (TextButton, (boolean) -> ())
	local track = Instance.new("TextButton")
	track.AnchorPoint = Vector2.new(1, 0.5)
	track.Position = UDim2.new(1, 0, 0.5, 0)
	track.Size = UDim2.fromOffset(38, 20)
	track.BackgroundColor3 = Theme.idle
	track.AutoButtonColor = false
	track.Text = ""
	corner(track, 10)
	track.Parent = parent

	local knob = Instance.new("Frame")
	knob.Size = UDim2.fromOffset(16, 16)
	knob.AnchorPoint = Vector2.new(0, 0.5)
	knob.Position = UDim2.new(0, 2, 0.5, 0)
	knob.BackgroundColor3 = Theme.text
	corner(knob, 8)
	knob.Parent = track

	local function set(on: boolean)
		TweenService:Create(track, TweenInfo.new(0.12), {
			BackgroundColor3 = on and Theme.green or Theme.idle,
		}):Play()
		TweenService:Create(knob, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {
			Position = on and UDim2.new(1, -18, 0.5, 0) or UDim2.new(0, 2, 0.5, 0),
		}):Play()
	end
	return track, set
end

-- primary button feel: hover lighten (read from current base so it stays
-- correct after the button recolors between Connect/Disconnect) + press squash
local function wireButtonFeel(btn: TextButton)
	local scale = Instance.new("UIScale")
	scale.Parent = btn
	local function base(): Color3
		return (btn:GetAttribute("BaseColor") :: Color3) or btn.BackgroundColor3
	end
	btn.MouseEnter:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.12), {
			BackgroundColor3 = base():Lerp(Color3.new(1, 1, 1), 0.16),
		}):Play()
	end)
	btn.MouseButton1Up:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.12), { BackgroundColor3 = base() }):Play()
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.12), { BackgroundColor3 = base() }):Play()
		TweenService:Create(scale, TweenInfo.new(0.08), { Scale = 1 }):Play()
	end)
	btn.MouseButton1Down:Connect(function()
		TweenService:Create(scale, TweenInfo.new(0.06), { Scale = 0.95 }):Play()
	end)
end

-- -- constructor ------------------------------------------------------------
function StatusWidget.new(plugin: Plugin)
	local self = setmetatable({}, StatusWidget)

	-- InitialEnabled=false + overrideRestore=false: start HIDDEN and respect the
	-- user's last placement (restored if saved). This stops the dock from forcing
	-- itself open on every plugin reload -- including when entering a playtest,
	-- where it used to overlay gameplay. It opens only when Nik clicks the toolbar
	-- button (StatusWidget:toggle is the only place that sets widget.Enabled).
	local info = DockWidgetPluginGuiInfo.new(Enum.InitialDockState.Float, false, false, 300, 440, 240, 360)
	local widget = plugin:CreateDockWidgetPluginGui("RobloxStudioMCP_Status", info)
	widget.Title = "Nik Studio MCP"

	local root = Instance.new("Frame")
	root.Size = UDim2.fromScale(1, 1)
	root.BackgroundColor3 = Theme.bg
	root.BorderSizePixel = 0
	gradient(root, Theme.bg, Theme.bg2, 90)
	root.Parent = widget

	-- Tab strip: Status / Settings / Activity. Body holds the three views.
	local tabBar = Instance.new("Frame")
	tabBar.Size = UDim2.new(1, 0, 0, 38)
	tabBar.BackgroundColor3 = Theme.bg
	tabBar.BorderSizePixel = 0
	tabBar.Parent = root
	padding(tabBar, 8, 8, 0, 8)
	hlist(tabBar, 6)

	local body = Instance.new("Frame")
	body.Size = UDim2.new(1, 0, 1, -38)
	body.Position = UDim2.fromOffset(0, 38)
	body.BackgroundTransparency = 1
	body.BorderSizePixel = 0
	body.Parent = root

	-- helper: a vertical scrolling view that fills the body
	local function makeView(): ScrollingFrame
		local v = Instance.new("ScrollingFrame")
		v.Size = UDim2.fromScale(1, 1)
		v.BackgroundTransparency = 1
		v.BorderSizePixel = 0
		v.ScrollBarThickness = 4
		v.ScrollBarImageColor3 = Theme.stroke
		v.CanvasSize = UDim2.new()
		v.AutomaticCanvasSize = Enum.AutomaticSize.Y
		v.CanvasPosition = Vector2.new(0, 0)
		v.Visible = false
		padding(v, 12, 12, 12, 12)
		vlist(v, 10)
		v.Parent = body
		return v
	end

	-- the Status view (existing content scrolls vertically when the dock is short)
	local scroller = makeView()
	scroller.Visible = true
	-- center compact items (the secondary Disconnect button); full-width cards,
	-- header and the Connect CTA span the width so centering is a no-op for them.
	local scrollerList = scroller:FindFirstChildOfClass("UIListLayout")
	if scrollerList then
		scrollerList.HorizontalAlignment = Enum.HorizontalAlignment.Center
	end

	-- Status tab order: header(1) -> ports(2) -> Connect button(3) -> status card(4).
	local portsCard = card(scroller, 2)
	local connCard = card(scroller, 4)
	-- ports reads as a slim strip: trim the card's vertical padding
	local pcPad = portsCard:FindFirstChildOfClass("UIPadding")
	if pcPad then
		pcPad.PaddingTop = UDim.new(0, 6)
		pcPad.PaddingBottom = UDim.new(0, 6)
	end

	-- Small serif build stamp, tucked into the top-left just under the tab strip and
	-- above the header (the empty strip in the body's top padding). Additive overlay
	-- parented to root -- not part of any UIListLayout -- so existing layout/bindings
	-- are untouched. Same muted color as the header subtitle (Theme.subtext). Keep the
	-- text in sync with package.json "version".
	local version = Instance.new("TextLabel")
	version.Name = "VersionTag"
	version.Position = UDim2.fromOffset(12, 39)
	version.Size = UDim2.fromOffset(120, 9)
	version.BackgroundTransparency = 1
	version.Font = Enum.Font.Merriweather -- readable serif at small sizes
	version.Text = "version 0.1.2"
	version.TextColor3 = Theme.subtext
	version.TextXAlignment = Enum.TextXAlignment.Left
	version.TextYAlignment = Enum.TextYAlignment.Top
	version.TextScaled = true
	textConstraint(version, 9, 7)
	version.Parent = root

	self.widget = widget
	self.connState = "Disconnected" -- the SELECTED port's state (drives pill + rows)
	self.ports = {}
	self.selectedPort = nil -- which port the Status tab shows (display only)
	self.portStates = {} -- [port] = display state; each chip shows its own
	self.armed = false
	self.soundEnabled = true
	self.settings = Settings.default()
	self.toolSwitches = {}
	self.flagSwitches = {}
	self.activityRows = {}

	-- callbacks the edit plugin assigns
	self.onPrimary = nil
	self.onAddPort = nil
	self.onRemovePort = nil
	self.onSelectPort = nil
	self.onArm = nil
	self.onToggleTool = nil
	self.onSetFlag = nil
	self.onSetAuth = nil

	-- Header: lifted gradient panel with title + subtitle and a status pill.
	local header = Instance.new("Frame")
	header.Size = UDim2.new(1, 0, 0, 60)
	header.BackgroundColor3 = Theme.panelHi
	header.BorderSizePixel = 0
	header.LayoutOrder = 1
	corner(header, 14)
	stroke(header, Theme.stroke, 0.2)
	sheen(header, 232)
	padding(header, 11, 12, 11, 14)
	header.Parent = scroller

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, -120, 0, 22)
	title.BackgroundTransparency = 1
	title.Font = Enum.Font.GothamBold
	title.Text = "Nik Studios MCP"
	title.TextColor3 = Theme.text
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.TextScaled = true
	textConstraint(title, 18, 12)
	title.Parent = header

	local subtitle = Instance.new("TextLabel")
	subtitle.Size = UDim2.new(1, -120, 0, 14)
	subtitle.Position = UDim2.fromOffset(0, 24)
	subtitle.BackgroundTransparency = 1
	subtitle.Font = Enum.Font.Gotham
	subtitle.Text = "Studio <-> Node bridge"
	subtitle.TextColor3 = Theme.subtext
	subtitle.TextXAlignment = Enum.TextXAlignment.Left
	subtitle.TextScaled = true
	textConstraint(subtitle, 12, 9)
	subtitle.Parent = header

	-- Status pill (the signature element): dot + word, state-tinted, pulses.
	local pill = Instance.new("Frame")
	pill.Name = "Pill"
	pill.AnchorPoint = Vector2.new(1, 0.5)
	pill.Position = UDim2.new(1, 0, 0.5, 0)
	pill.Size = UDim2.fromOffset(0, 26)
	pill.AutomaticSize = Enum.AutomaticSize.X
	pill.BackgroundColor3 = Theme.red
	pill.BackgroundTransparency = 0.82
	corner(pill, 13)
	local pillStroke = stroke(pill, Theme.red, 0.4)
	local pillPad = Instance.new("UIPadding")
	pillPad.PaddingLeft = UDim.new(0, 9)
	pillPad.PaddingRight = UDim.new(0, 11)
	pillPad.Parent = pill
	hlist(pill, 6)
	local pillScale = Instance.new("UIScale")
	pillScale.Parent = pill
	pill.Parent = header

	local pillDot = Instance.new("Frame")
	pillDot.Size = UDim2.fromOffset(8, 8)
	pillDot.BackgroundColor3 = Theme.red
	pillDot.LayoutOrder = 1
	corner(pillDot, 4)
	pillDot.Parent = pill

	local pillWord = Instance.new("TextLabel")
	pillWord.AutomaticSize = Enum.AutomaticSize.X
	pillWord.Size = UDim2.fromOffset(0, 26)
	pillWord.BackgroundTransparency = 1
	pillWord.Font = Enum.Font.GothamMedium
	pillWord.Text = WORD.Disconnected
	pillWord.TextColor3 = Theme.text
	pillWord.TextSize = 13
	pillWord.LayoutOrder = 2
	pillWord.Parent = pill

	self.pill, self.pillDot, self.pillWord, self.pillStroke, self.pillScale =
		pill, pillDot, pillWord, pillStroke, pillScale

	-- Monospace address rendered as a field-chip with a state-colored marker.
	local addr = Instance.new("Frame")
	addr.Size = UDim2.new(1, 0, 0, 32)
	addr.BackgroundColor3 = Theme.field
	addr.BorderSizePixel = 0
	addr.LayoutOrder = 1
	corner(addr, 10)
	stroke(addr, Theme.stroke, 0.3)
	padding(addr, 0, 12, 0, 12)
	addr.Parent = connCard

	local addrDot = Instance.new("Frame")
	addrDot.Size = UDim2.fromOffset(7, 7)
	addrDot.Position = UDim2.new(0, 0, 0.5, 0)
	addrDot.AnchorPoint = Vector2.new(0, 0.5)
	addrDot.BackgroundColor3 = Theme.red
	corner(addrDot, 4)
	addrDot.Parent = addr

	local address = Instance.new("TextLabel")
	address.Size = UDim2.new(1, -16, 1, 0)
	address.Position = UDim2.fromOffset(16, 0)
	address.BackgroundTransparency = 1
	address.Font = Enum.Font.Code
	address.Text = "http://127.0.0.1:---"
	address.TextColor3 = Theme.text
	address.TextXAlignment = Enum.TextXAlignment.Left
	address.TextScaled = true
	textConstraint(address, 15, 10)
	address.Parent = addr
	self.address, self.addrDot = address, addrDot

	-- Port lane: horizontally-scrolling chips + a "+" pinned outside the scroll.
	-- Slim strip: chips vertically centered, just enough room for the scrollbar.
	local lane = Instance.new("Frame")
	lane.Name = "PortLane"
	lane.Size = UDim2.new(1, 0, 0, 26)
	lane.BackgroundTransparency = 1
	lane.LayoutOrder = 1
	lane.Parent = portsCard

	local chipScroll = Instance.new("ScrollingFrame")
	chipScroll.Size = UDim2.new(1, -38, 1, 0) -- room on the right for "+"; the editor overlays on top
	chipScroll.BackgroundTransparency = 1
	chipScroll.BorderSizePixel = 0
	chipScroll.ScrollingDirection = Enum.ScrollingDirection.X
	chipScroll.AutomaticCanvasSize = Enum.AutomaticSize.X
	chipScroll.CanvasSize = UDim2.new()
	chipScroll.ScrollBarThickness = 3
	chipScroll.ScrollBarImageColor3 = Theme.stroke
	chipScroll.ScrollBarImageTransparency = 0.2
	chipScroll.Parent = lane
	local chipLayout = hlist(chipScroll, 6)
	chipLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	local chipPad = Instance.new("UIPadding")
	chipPad.PaddingBottom = UDim.new(0, 4) -- room for the bottom scrollbar
	chipPad.Parent = chipScroll
	self.chipScroll = chipScroll

	-- "+" add control, pinned to the right of the lane (outside the scroll).
	local add = Instance.new("TextButton")
	add.Name = "AddPort"
	add.AnchorPoint = Vector2.new(1, 0.5)
	add.Position = UDim2.new(1, 0, 0.5, 0)
	add.Size = UDim2.fromOffset(32, 22)
	add.BackgroundColor3 = Theme.panel
	add.AutoButtonColor = false
	add.Text = "+"
	add.Font = Enum.Font.GothamBold
	add.TextColor3 = Theme.text
	add.TextScaled = true
	corner(add, 8)
	stroke(add, Theme.stroke, 0.1)
	textConstraint(add, 18, 12)
	add.Parent = lane

	self.dir = "up" -- persisted "+" suggestion direction (default; init pushes saved value)
	self.defaultPort = 58741 -- overridden by init (Config.DEFAULT_PORT)

	-- ONE reusable inline port editor (hidden by default), shared by the "+" flow
	-- (adds a port) and the chip-click flow (edits a port in place). Overlays the
	-- right of the chip lane, just left of "+". The ^/v steppers live INSIDE here,
	-- so the arrows are only visible while an editor is open.
	local editor = Instance.new("Frame")
	editor.Name = "PortEditor"
	editor.AnchorPoint = Vector2.new(1, 0.5)
	editor.Position = UDim2.new(1, -38, 0.5, 0)
	editor.Size = UDim2.fromOffset(96, 22)
	editor.BackgroundTransparency = 1
	editor.Visible = false
	editor.ZIndex = 10
	editor.Parent = lane
	self.editor = editor
	self.overStepper = nil -- "up" | "down" while the mouse hovers a stepper

	local editBox = Instance.new("TextBox")
	editBox.Size = UDim2.new(1, -22, 1, 0)
	editBox.BackgroundColor3 = Theme.field
	editBox.Text = ""
	editBox.PlaceholderText = "port"
	editBox.Font = Enum.Font.Code
	editBox.TextColor3 = Theme.text
	editBox.PlaceholderColor3 = Theme.subtext
	editBox.TextScaled = true
	editBox.ClearTextOnFocus = false
	editBox.ZIndex = 10
	corner(editBox, 8)
	stroke(editBox, Theme.accent, 0.1)
	textConstraint(editBox, 14, 10)
	editBox.Parent = editor
	self.editBox = editBox

	-- stepper: stacked ^/v that adjust the number being edited (skip taken, clamp)
	local stepper = Instance.new("Frame")
	stepper.AnchorPoint = Vector2.new(1, 0)
	stepper.Position = UDim2.new(1, 0, 0, 0)
	stepper.Size = UDim2.new(0, 20, 1, 0)
	stepper.BackgroundColor3 = Theme.panel
	stepper.BorderSizePixel = 0
	stepper.ZIndex = 10
	corner(stepper, 8)
	stroke(stepper, Theme.stroke, 0.1)
	stepper.Parent = editor

	local function stepBtn(glyph: string, dir: string, top: boolean): TextButton
		local b = Instance.new("TextButton")
		b.Size = UDim2.new(1, 0, 0, 12)
		b.Position = top and UDim2.new(0, 0, 0, 1) or UDim2.new(0, 0, 1, -13)
		b.BackgroundTransparency = 1
		b.Text = glyph
		b.Font = Enum.Font.GothamBold
		b.TextColor3 = Theme.subtext
		b.TextSize = 11
		b.AutoButtonColor = false
		b.ZIndex = 11
		b.Parent = stepper
		-- The actual step is done in editBox.FocusLost (we know which stepper the
		-- mouse is over), so clicking a stepper never cancels the editor.
		b.MouseEnter:Connect(function()
			self.overStepper = dir
			b.TextColor3 = Theme.accent
		end)
		b.MouseLeave:Connect(function()
			self.overStepper = nil
			b.TextColor3 = Theme.subtext
		end)
		return b
	end
	stepBtn("^", "up", true)
	stepBtn("v", "down", false)

	editBox.FocusLost:Connect(function(enterPressed)
		if enterPressed then
			self:_commitEditor()
		elseif self.overStepper then
			-- focus was lost because the user pressed a stepper: step + keep editing
			self:_step(self.overStepper)
			editBox:CaptureFocus()
			editBox.CursorPosition = #editBox.Text + 1
		else
			self:_cancelEditor() -- Esc or clicked away
		end
	end)

	add.MouseEnter:Connect(function()
		TweenService:Create(add, TweenInfo.new(0.1), { BackgroundColor3 = Theme.panelHi }):Play()
	end)
	add.MouseLeave:Connect(function()
		TweenService:Create(add, TweenInfo.new(0.1), { BackgroundColor3 = Theme.panel }):Play()
	end)
	add.MouseButton1Click:Connect(function()
		self:_click()
		if self.editor.Visible then
			self:_cancelEditor() -- toggle the add editor off
			return
		end
		self:_openEditor(self:_suggestPort())
	end)

	-- thin divider
	local divider = Instance.new("Frame")
	divider.Size = UDim2.new(1, 0, 0, 1)
	divider.BackgroundColor3 = Theme.stroke
	divider.BackgroundTransparency = 0.3
	divider.BorderSizePixel = 0
	divider.LayoutOrder = 2
	divider.Parent = connCard

	-- status rows
	local rows = Instance.new("Frame")
	rows.Size = UDim2.new(1, 0, 0, 116)
	rows.BackgroundTransparency = 1
	rows.LayoutOrder = 3
	vlist(rows, 4)
	rows.Parent = connCard

	local _httpRow, httpDot = makeRow(rows, 1, "HTTP server")
	local _mcpRow, mcpDot = makeRow(rows, 2, "MCP bridge")
	local _cmdRow, cmdDot = makeRow(rows, 3, "Commands")
	local agentRow, agentDot = makeRow(rows, 4, "Playtest agent")
	self.httpDot, self.mcpDot, self.cmdDot, self.agentDot = httpDot, mcpDot, cmdDot, agentDot
	paintDot(httpDot, false)
	paintDot(mcpDot, nil)
	paintDot(cmdDot, nil)
	agentDot.BackgroundColor3 = Theme.idle

	-- arm toggle switch on the Playtest agent row
	local track = Instance.new("TextButton")
	track.Name = "ArmToggle"
	track.AnchorPoint = Vector2.new(1, 0.5)
	track.Position = UDim2.new(1, 0, 0.5, 0)
	track.Size = UDim2.fromOffset(38, 20)
	track.BackgroundColor3 = Theme.idle
	track.AutoButtonColor = false
	track.Text = ""
	corner(track, 10)
	track.Parent = agentRow

	local knob = Instance.new("Frame")
	knob.Size = UDim2.fromOffset(16, 16)
	knob.AnchorPoint = Vector2.new(0, 0.5)
	knob.Position = UDim2.new(0, 2, 0.5, 0)
	knob.BackgroundColor3 = Theme.text
	corner(knob, 8)
	knob.Parent = track
	self.armTrack, self.armKnob = track, knob
	track.MouseButton1Click:Connect(function()
		self:_click()
		if self.onArm then
			self.onArm()
		end
	end)

	-- Primary Connect/Disconnect button (sheened, hover-lighten, press-squash).
	local primary = Instance.new("TextButton")
	primary.Size = UDim2.new(1, 0, 0, 36)
	primary.BackgroundColor3 = Theme.accent
	primary.TextColor3 = Color3.new(1, 1, 1)
	primary.Font = Enum.Font.GothamBold
	primary.Text = "Connect"
	primary.TextScaled = true
	primary.AutoButtonColor = false
	primary.LayoutOrder = 3 -- directly under the ports card
	primary:SetAttribute("BaseColor", Theme.accent)
	corner(primary, 11)
	sheen(primary, 205)
	textConstraint(primary, 18, 13)
	primary.Parent = scroller
	self.primary = primary
	wireButtonFeel(primary)
	primary.MouseButton1Click:Connect(function()
		self:_click()
		if self.onPrimary then
			self.onPrimary()
		end
	end)

	-- Settings + Activity views and the tab strip that switches between them.
	local settingsView = makeView()
	local activityView = makeView()
	self.settingsView = settingsView
	self.activityView = activityView
	self.views = { Status = scroller, Settings = settingsView, Activity = activityView }
	self:_buildSettings(settingsView)
	self:_buildActivity(activityView)

	self.tabs = {}
	for i, name in ipairs({ "Status", "Settings", "Activity" }) do
		local tab = Instance.new("TextButton")
		tab.Name = name
		tab.Size = UDim2.fromOffset(80, 24)
		tab.BackgroundColor3 = Theme.panel
		tab.AutoButtonColor = false
		tab.Text = name
		tab.Font = Enum.Font.GothamMedium
		tab.TextColor3 = Theme.subtext
		tab.TextScaled = true
		tab.LayoutOrder = i
		corner(tab, 8)
		textConstraint(tab, 13, 10)
		tab.Parent = tabBar
		self.tabs[name] = tab
		tab.MouseButton1Click:Connect(function()
			self:_click()
			self:_showTab(name)
		end)
	end
	self:_showTab("Status")

	self:_applyConnectionState("Disconnected")
	return self
end

-- -- tab switching ----------------------------------------------------------
function StatusWidget:_showTab(name: string)
	for tabName, view in pairs(self.views) do
		view.Visible = tabName == name
		local tab = self.tabs[tabName]
		local active = tabName == name
		-- subtle selected state: lifted panel + bright text vs recessed + muted
		tab.BackgroundColor3 = active and Theme.panelHi or Theme.bg2
		tab.TextColor3 = active and Theme.text or Theme.subtext
	end
end

-- -- port chips -------------------------------------------------------------
-- Live-state color for the connected chip's fill (idle/connecting/connected).
local function connColor(state: string): Color3
	if state == "Connected" then
		return Theme.green
	elseif state == "Connecting" then
		return Theme.amber
	elseif state == "Error" then
		return Theme.red
	end
	return Theme.idle
end

function StatusWidget:_rebuildChips()
	for _, child in ipairs(self.chipScroll:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end

	local order = 1
	for _, port in ipairs(self.ports) do
		local isSelected = port == self.selectedPort
		-- each chip shows ITS OWN connection state (many can be green at once)
		local pState = self.portStates[port] or "Disconnected"
		local colored = pState == "Connected" or pState == "Connecting" or pState == "Error"
		local bg = colored and connColor(pState) or Theme.panel
		local fg = colored and Theme.bg or Theme.text

		local chip = Instance.new("TextButton")
		chip.Name = "Port" .. tostring(port)
		-- ponytail: fixed chip footprint (tiny element); AutomaticSize.X with a
		-- Scale-width child inside an X-scroll is a layout-feedback footgun.
		chip.Size = UDim2.fromOffset(84, 22)
		chip.BackgroundColor3 = bg
		chip.AutoButtonColor = false
		chip.Text = ""
		chip.LayoutOrder = order
		order += 1
		corner(chip, 8)
		-- selected chip outlined in accent; others a hairline
		stroke(chip, isSelected and Theme.accent or Theme.stroke, isSelected and 0 or 0.2)
		chip.Parent = self.chipScroll

		local lbl = Instance.new("TextLabel")
		lbl.BackgroundTransparency = 1
		lbl.Font = Enum.Font.Code
		lbl.Text = ":" .. tostring(port)
		lbl.TextColor3 = fg
		lbl.TextXAlignment = Enum.TextXAlignment.Left
		lbl.Size = UDim2.new(1, -24, 1, 0)
		lbl.Position = UDim2.fromOffset(9, 0)
		lbl.TextScaled = true
		textConstraint(lbl, 13, 10)
		lbl.Parent = chip

		-- hover lighten on plain (not-colored) chips only
		if not colored then
			chip.MouseEnter:Connect(function()
				TweenService:Create(chip, TweenInfo.new(0.1), { BackgroundColor3 = Theme.panelHi }):Play()
			end)
			chip.MouseLeave:Connect(function()
				TweenService:Create(chip, TweenInfo.new(0.1), { BackgroundColor3 = Theme.panel }):Play()
			end)
		end

		-- clicking the chip body selects this port (never auto-connects)
		chip.MouseButton1Click:Connect(function()
			self:_click()
			if self.onSelectPort then
				self.onSelectPort(port)
			end
		end)

		local x = Instance.new("TextButton")
		x.Name = "Remove"
		x.Size = UDim2.fromOffset(18, 18)
		x.Position = UDim2.new(1, -4, 0.5, 0)
		x.AnchorPoint = Vector2.new(1, 0.5)
		x.ZIndex = 2 -- above the chip body so "x" removes instead of selecting
		x.BackgroundTransparency = 1
		x.Text = "x"
		x.Font = Enum.Font.GothamBold
		x.TextColor3 = colored and fg or Theme.subtext
		x.TextScaled = true
		textConstraint(x, 14, 9)
		x.Parent = chip
		x.MouseButton1Click:Connect(function()
			self:_click()
			if self.onRemovePort then
				self.onRemovePort(port)
			end
		end)
	end
end

-- -- port editor (shared by "+" add and chip-click edit) --------------------
-- init pushes the persisted "+" suggestion direction at startup.
function StatusWidget:setDirection(dir: string)
	self.dir = (dir == "down") and "down" or "up"
end

function StatusWidget:_openEditor(prefill: number?)
	self.editBox.Text = prefill and tostring(prefill) or ""
	self.editor.Visible = true
	self.editBox:CaptureFocus()
	self.editBox.CursorPosition = #self.editBox.Text + 1
end

function StatusWidget:_closeEditor()
	self.overStepper = nil
	self.editor.Visible = false
end

function StatusWidget:_cancelEditor()
	self:_closeEditor()
end

-- commit the (edited) value: add a new port.
function StatusWidget:_commitEditor()
	local raw = self.editBox.Text
	self:_closeEditor()
	local n = tonumber(raw)
	if not (n and n == math.floor(n) and n >= 1 and n <= 65535) then
		return -- out of range / non-integer: ignore
	end
	if self.onAddPort then
		self.onAddPort(n)
	end
end

-- step the number being edited by 1, skipping taken ports, clamped 1..65535
function StatusWidget:_step(dir: string)
	local cur = tonumber(self.editBox.Text) or self.defaultPort or 1
	cur = math.floor(cur)
	local taken = {}
	for _, p in ipairs(self.ports) do
		taken[p] = true
	end
	local n = cur
	if dir == "up" then
		n += 1
		while n <= 65535 and taken[n] do
			n += 1
		end
		if n > 65535 then
			return
		end
	else
		n -= 1
		while n >= 1 and taken[n] do
			n -= 1
		end
		if n < 1 then
			return
		end
	end
	self.editBox.Text = tostring(n)
end

-- Next free port for the current direction, clamped to 1..65535. nil if none.
function StatusWidget:_suggestPort(): number?
	local ports = self.ports
	if #ports == 0 then
		return self.defaultPort
	end
	local taken = {}
	local lo, hi = ports[1], ports[1]
	for _, p in ipairs(ports) do
		taken[p] = true
		if p < lo then
			lo = p
		end
		if p > hi then
			hi = p
		end
	end
	if self.dir == "down" then
		local c = lo - 1
		while c >= 1 do
			if not taken[c] then
				return c
			end
			c -= 1
		end
		return nil
	end
	local c = hi + 1
	while c <= 65535 do
		if not taken[c] then
			return c
		end
		c += 1
	end
	return nil
end

-- -- settings view ----------------------------------------------------------
-- a single labeled row with a switch on the right; returns the switch setter
function StatusWidget:_settingsRow(parent: Instance, order: number, label: string, initial: boolean, onChange: (boolean) -> ()): (boolean) -> ()
	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 28)
	row.BackgroundTransparency = 1
	row.LayoutOrder = order
	row.Parent = parent

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(1, -50, 1, 0)
	lbl.BackgroundTransparency = 1
	lbl.Font = Enum.Font.Gotham
	lbl.Text = label
	lbl.TextColor3 = Theme.text
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	lbl.TextScaled = true
	textConstraint(lbl, 13, 9)
	lbl.Parent = row

	local track, set = makeSwitch(row)
	local state = initial
	set(state)
	track.MouseButton1Click:Connect(function()
		self:_click()
		state = not state
		set(state)
		onChange(state)
	end)
	return set
end

function StatusWidget:_sectionHeader(parent: Instance, order: number, text: string)
	local h = Instance.new("TextLabel")
	h.Size = UDim2.new(1, 0, 0, 20)
	h.BackgroundTransparency = 1
	h.Font = Enum.Font.GothamBold
	h.Text = text
	h.TextColor3 = Theme.subtext
	h.TextXAlignment = Enum.TextXAlignment.Left
	h.TextScaled = true
	h.LayoutOrder = order
	textConstraint(h, 13, 10)
	h.Parent = parent
end

function StatusWidget:_buildSettings(view: ScrollingFrame)
	local order = 0
	local function nextOrder(): number
		order += 1
		return order
	end

	-- Tools grouped under Read / Write / Experimental
	for _, group in ipairs(Settings.GROUPS) do
		self:_sectionHeader(view, nextOrder(), group.label)
		for _, tool in ipairs(Settings.TOOLS) do
			if tool.group == group.key then
				local name = tool.name
				local setter = self:_settingsRow(view, nextOrder(), tool.label, true, function(on)
					self.settings.tools[name] = on
					if self.onToggleTool then
						self.onToggleTool(name, on)
					end
				end)
				self.toolSwitches[name] = setter
			end
		end
	end

	-- Misc flags
	self:_sectionHeader(view, nextOrder(), "Misc")
	local FLAGS = {
		{ key = "readOnly", label = "Read-only mode (block writes)" },
		{ key = "confirmDestructive", label = "Confirm destructive (stub)" },
		{ key = "soundEnabled", label = "Sound" },
		{ key = "activityLog", label = "Activity log" },
		{ key = "playtestAutoStop", label = "Auto-stop abandoned playtests" },
	}
	for _, f in ipairs(FLAGS) do
		local key = f.key
		local setter = self:_settingsRow(view, nextOrder(), f.label, true, function(on)
			self.settings[key] = on
			if key == "soundEnabled" then
				self.soundEnabled = on
			end
			if self.onSetFlag then
				self.onSetFlag(key, on)
			end
		end)
		self.flagSwitches[key] = setter
	end

	-- Playtest auto-stop thresholds (seconds). Pairs with the toggle above.
	self:_sectionHeader(view, nextOrder(), "Playtest auto-stop (seconds)")
	self.numberFields = {}
	local function numberField(labelText: string, key: string)
		local row = Instance.new("Frame")
		row.Size = UDim2.new(1, 0, 0, 28)
		row.BackgroundTransparency = 1
		row.LayoutOrder = nextOrder()
		row.Parent = view
		local lbl = Instance.new("TextLabel")
		lbl.Size = UDim2.new(1, -76, 1, 0)
		lbl.BackgroundTransparency = 1
		lbl.Font = Enum.Font.Gotham
		lbl.Text = labelText
		lbl.TextColor3 = Theme.text
		lbl.TextXAlignment = Enum.TextXAlignment.Left
		lbl.TextScaled = true
		textConstraint(lbl, 13, 9)
		lbl.Parent = row
		local box = Instance.new("TextBox")
		box.AnchorPoint = Vector2.new(1, 0.5)
		box.Position = UDim2.new(1, 0, 0.5, 0)
		box.Size = UDim2.new(0, 64, 0, 24)
		box.BackgroundColor3 = Theme.field
		box.Font = Enum.Font.Code
		box.TextColor3 = Theme.text
		box.TextScaled = true
		box.ClearTextOnFocus = false
		box.Text = tostring(self.settings[key] or "")
		corner(box, 6)
		stroke(box, Theme.stroke, 0.2)
		textConstraint(box, 13, 9)
		box.Parent = row
		box.FocusLost:Connect(function()
			local n = tonumber(box.Text)
			if n and n > 0 then
				n = math.floor(n)
				self.settings[key] = n
				box.Text = tostring(n)
				if self.onSetNumber then
					self.onSetNumber(key, n)
				end
			else
				box.Text = tostring(self.settings[key] or "")
			end
		end)
		self.numberFields[key] = box
	end
	numberField("Max run time", "playtestMaxSeconds")
	numberField("Idle timeout", "playtestIdleSeconds")

	-- Auth: enable switch + token field (TOFU; off by default)
	self:_sectionHeader(view, nextOrder(), "Auth (optional, TOFU)")
	local authRow = Instance.new("Frame")
	authRow.Size = UDim2.new(1, 0, 0, 28)
	authRow.BackgroundTransparency = 1
	authRow.LayoutOrder = nextOrder()
	authRow.Parent = view
	local authLbl = Instance.new("TextLabel")
	authLbl.Size = UDim2.new(1, -50, 1, 0)
	authLbl.BackgroundTransparency = 1
	authLbl.Font = Enum.Font.Gotham
	authLbl.Text = "Require token"
	authLbl.TextColor3 = Theme.text
	authLbl.TextXAlignment = Enum.TextXAlignment.Left
	authLbl.TextScaled = true
	textConstraint(authLbl, 13, 9)
	authLbl.Parent = authRow
	local authTrack, authSet = makeSwitch(authRow)
	authSet(false)
	self.authSwitch = authSet

	local tokenBox = Instance.new("TextBox")
	tokenBox.Size = UDim2.new(1, 0, 0, 28)
	tokenBox.BackgroundColor3 = Theme.field
	tokenBox.Text = ""
	tokenBox.PlaceholderText = "token (e.g. a random string)"
	tokenBox.Font = Enum.Font.Code
	tokenBox.TextColor3 = Theme.text
	tokenBox.PlaceholderColor3 = Theme.subtext
	tokenBox.TextScaled = true
	tokenBox.ClearTextOnFocus = false
	tokenBox.LayoutOrder = nextOrder()
	corner(tokenBox, 8)
	stroke(tokenBox, Theme.stroke, 0.2)
	textConstraint(tokenBox, 13, 9)
	tokenBox.Parent = view
	self.tokenBox = tokenBox

	local authEnabled = false
	local function pushAuth()
		if self.onSetAuth then
			self.onSetAuth(authEnabled, tokenBox.Text)
		end
	end
	authTrack.MouseButton1Click:Connect(function()
		self:_click()
		authEnabled = not authEnabled
		authSet(authEnabled)
		self.settings.auth.enabled = authEnabled
		pushAuth()
	end)
	tokenBox.FocusLost:Connect(function()
		self.settings.auth.token = tokenBox.Text
		pushAuth()
	end)
end

-- -- activity view ----------------------------------------------------------
function StatusWidget:_buildActivity(view: ScrollingFrame)
	local header = Instance.new("TextLabel")
	header.Name = "ActivityHeader"
	header.Size = UDim2.new(1, 0, 0, 18)
	header.BackgroundTransparency = 1
	header.Font = Enum.Font.GothamBold
	header.Text = "Recent commands"
	header.TextColor3 = Theme.subtext
	header.TextXAlignment = Enum.TextXAlignment.Left
	header.TextScaled = true
	header.LayoutOrder = -1000000 -- stay on top; rows sort newest-first below it
	textConstraint(header, 13, 10)
	header.Parent = view
	self.activityHeader = header
	self.activityList = view
	self.activitySeq = 0
end

-- entry = { tool, target, ok, ms, time }
function StatusWidget:addActivity(entry: any)
	local view = self.activityList
	if not view then
		return
	end
	self.activitySeq += 1

	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 30)
	row.BackgroundColor3 = Theme.panel
	row.BorderSizePixel = 0
	-- newest on top: header is LayoutOrder 0, rows use decreasing negative order
	row.LayoutOrder = -self.activitySeq
	corner(row, 6)
	stroke(row, Theme.stroke, 0.4)
	padding(row, 0, 8, 0, 8)
	row.Parent = view

	local dot = Instance.new("Frame")
	dot.Size = UDim2.fromOffset(7, 7)
	dot.Position = UDim2.new(0, 0, 0.5, 0)
	dot.AnchorPoint = Vector2.new(0, 0.5)
	dot.BackgroundColor3 = entry.ok and Theme.green or Theme.red
	corner(dot, 4)
	dot.Parent = row

	local name = Instance.new("TextLabel")
	name.Size = UDim2.new(1, -64, 0, 16)
	name.Position = UDim2.fromOffset(14, 2)
	name.BackgroundTransparency = 1
	name.Font = Enum.Font.Code
	name.Text = tostring(entry.tool)
	name.TextColor3 = Theme.text
	name.TextXAlignment = Enum.TextXAlignment.Left
	name.TextScaled = true
	textConstraint(name, 12, 9)
	name.Parent = row

	local target = Instance.new("TextLabel")
	target.Size = UDim2.new(1, -64, 0, 11)
	target.Position = UDim2.fromOffset(14, 18)
	target.BackgroundTransparency = 1
	target.Font = Enum.Font.Gotham
	local stamp = ""
	pcall(function()
		stamp = os.date("%H:%M:%S", entry.time) :: string
	end)
	target.Text = (stamp ~= "" and (stamp .. "  ") or "") .. tostring(entry.target or "")
	target.TextColor3 = Theme.subtext
	target.TextXAlignment = Enum.TextXAlignment.Left
	target.TextScaled = true
	textConstraint(target, 10, 8)
	target.Parent = row

	local ms = Instance.new("TextLabel")
	ms.Size = UDim2.fromOffset(50, 16)
	ms.AnchorPoint = Vector2.new(1, 0.5)
	ms.Position = UDim2.new(1, 0, 0.5, 0)
	ms.BackgroundTransparency = 1
	ms.Font = Enum.Font.Code
	ms.Text = (entry.ms and (tostring(entry.ms) .. "ms")) or ""
	ms.TextColor3 = entry.ok and Theme.green or Theme.red
	ms.TextXAlignment = Enum.TextXAlignment.Right
	ms.TextScaled = true
	textConstraint(ms, 11, 8)
	ms.Parent = row

	table.insert(self.activityRows, row)
	-- cap at ~50 rows; drop the oldest
	if #self.activityRows > 50 then
		local oldest = table.remove(self.activityRows, 1)
		oldest:Destroy()
	end
end

-- -- sound ------------------------------------------------------------------
function StatusWidget:_click()
	if not self.soundEnabled then
		return
	end
	local sound = self._sound
	if not sound then
		sound = Instance.new("Sound")
		sound.SoundId = "rbxassetid://9112824440"
		sound.Volume = 0.4
		sound.Parent = SoundService
		self._sound = sound
	end
	pcall(function()
		SoundService:PlayLocalSound(sound)
	end)
end

-- pulse the status pill on a connection state change
function StatusWidget:_pulse()
	local scale = self.pillScale
	local up = TweenService:Create(scale, TweenInfo.new(0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Scale = 1.08 })
	local down = TweenService:Create(scale, TweenInfo.new(0.18), { Scale = 1 })
	up:Play()
	up.Completed:Once(function()
		down:Play()
	end)
end

-- -- public API -------------------------------------------------------------
function StatusWidget:_applyConnectionState(state: string)
	self.connState = state
	local color = STATE_COLOR[state] or Theme.idle
	self.pill.BackgroundColor3 = color
	self.pillStroke.Color = color
	self.pillDot.BackgroundColor3 = color
	self.pillWord.Text = WORD[state] or state
	self.addrDot.BackgroundColor3 = connColor(state) -- gray idle / amber / green
	-- Disconnect is offered whenever a connection is up or being attempted.
	local live = state == "Connected" or state == "Connecting"
	if live then
		-- compact, muted secondary: dark chip + red text (destructive, restrained),
		-- centered by the scroller's list layout -- NOT a full-width red block.
		self.primary.Text = "Disconnect"
		self.primary.Size = UDim2.fromOffset(128, 28)
		self.primary.BackgroundColor3 = Theme.panel
		self.primary.TextColor3 = Theme.red
		self.primary:SetAttribute("BaseColor", Theme.panel)
	else
		-- prominent primary CTA: full-width accent
		self.primary.Text = "Connect"
		self.primary.Size = UDim2.new(1, 0, 0, 36)
		self.primary.BackgroundColor3 = Theme.accent
		self.primary.TextColor3 = Color3.new(1, 1, 1)
		self.primary:SetAttribute("BaseColor", Theme.accent)
	end
	self:_rebuildChips() -- recolor the connected chip to match the new state
end

function StatusWidget:setConnectionState(state: string)
	local changed = self.connState ~= state
	self:_applyConnectionState(state)
	if changed then
		self:_pulse()
		if state == "Connected" then
			self:_click()
		end
	end
end

-- The selected port drives the address line + the accent chip outline.
function StatusWidget:setSelectedPort(port: number?)
	self.selectedPort = port
	if port then
		self.address.Text = ("http://127.0.0.1:%d"):format(port)
	else
		self.address.Text = "http://127.0.0.1:---"
	end
	self:_rebuildChips()
end

-- Per-port connection states { [port] = "Connected"|"Connecting"|"Disconnected"|"Error" }.
-- Each chip is filled from its own entry, so several can be green at once.
function StatusWidget:setPortStates(states: { [number]: string })
	self.portStates = states or {}
	self:_rebuildChips()
end

function StatusWidget:refreshPorts(ports: { number })
	self.ports = ports
	self:_rebuildChips()
end

function StatusWidget:setHttp(ok: boolean?)
	paintDot(self.httpDot, ok)
end
function StatusWidget:setMcp(ok: boolean?)
	paintDot(self.mcpDot, ok)
end
function StatusWidget:setCommands(ok: boolean?)
	paintDot(self.cmdDot, ok)
end

-- "off" | "armed" | "active" | "error" -> gray / amber / green / red
function StatusWidget:setAgentState(state: string)
	self.agentDot.BackgroundColor3 = AGENT_COLOR[state] or Theme.idle
end

function StatusWidget:setArmed(on: boolean)
	self.armed = on
	local toColor = on and Theme.green or Theme.idle
	local toPos = on and UDim2.new(1, -18, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)
	TweenService:Create(self.armTrack, TweenInfo.new(0.15), { BackgroundColor3 = toColor }):Play()
	TweenService:Create(self.armKnob, TweenInfo.new(0.15, Enum.EasingStyle.Quad), { Position = toPos }):Play()
end

function StatusWidget:setSoundEnabled(on: boolean)
	self.soundEnabled = on
end

-- init pushes the live settings table; reflect every switch + token to it.
function StatusWidget:setSettings(s: any)
	self.settings = s
	self.soundEnabled = s.soundEnabled ~= false
	for name, setter in pairs(self.toolSwitches) do
		setter(s.tools[name] ~= false)
	end
	for key, setter in pairs(self.flagSwitches) do
		setter(s[key] == true)
	end
	if self.numberFields then
		for key, box in pairs(self.numberFields) do
			box.Text = tostring(s[key] or "")
		end
	end
	if self.authSwitch then
		self.authSwitch(s.auth ~= nil and s.auth.enabled == true)
	end
	if self.tokenBox and s.auth then
		self.tokenBox.Text = s.auth.token or ""
	end
end

function StatusWidget:toggle()
	self.widget.Enabled = not self.widget.Enabled
end

return StatusWidget
]]></ProtectedString>
   </Properties>
  </Item>
  <Item class="ModuleScript" referent="RBX6">
   <Properties>
    <string name="Name">RuntimeAgentSource</string>
    <ProtectedString name="Source"><![CDATA[-- Returns the runtime-agent source as a string. The {{PORT}} token is replaced
-- by the plugin (init.server.luau) before the source is written into a Script
-- in ServerScriptService. The agent activates only inside an F5 playtest server.
local SOURCE = [==[
--!nonstrict
-- Roblox Studio MCP - runtime agent. Auto-injected by the Studio MCP plugin.
-- Does nothing in edit mode; activates only inside an F5 playtest server.
local RunService = game:GetService("RunService")
if not RunService:IsRunning() or not RunService:IsServer() then
	return
end

local HttpService = game:GetService("HttpService")
local PORT = script:GetAttribute("McpPort") or {{PORT}}
local TOKEN = script:GetAttribute("McpToken") or ""
local CANDIDATES = { PORT, 58741, 58742, 58743 }
local POLL_INTERVAL = 0.5
local BACKOFF_START = 1
local BACKOFF_MAX = 5
local CONTEXT = "server"
local base = nil

local function urlFor(port)
	return ("http://127.0.0.1:%d"):format(port)
end

-- Optional auth header (matches the edit plugin's TOFU token); nil when off.
local function authHeaders()
	if TOKEN ~= "" then
		return { ["x-mcp-token"] = TOKEN }
	end
	return nil
end

local function tryHeartbeat(port)
	local ok = pcall(function()
		HttpService:GetAsync(urlFor(port) .. "/heartbeat?context=" .. CONTEXT)
	end)
	return ok
end

-- Try to resolve a bridge port now (fast path). If the run DM's networking isn't
-- ready yet at t=0 (heavy boot), that's fine -- do NOT early-exit: the Heartbeat
-- scheduler below reprobes with backoff until the bridge answers.
for _, port in ipairs(CANDIDATES) do
	if tryHeartbeat(port) then
		base = urlFor(port)
		break
	end
end

-- Minimal serializer (returned values only).
local function serialize(v)
	local t = typeof(v)
	if t == "Vector3" then
		return { __t = "Vector3", x = v.X, y = v.Y, z = v.Z }
	elseif t == "CFrame" then
		return { __t = "CFrame", comps = { v:GetComponents() } }
	elseif t == "Color3" then
		return { __t = "Color3", r = v.R, g = v.G, b = v.B }
	elseif t == "Vector2" then
		return { __t = "Vector2", x = v.X, y = v.Y }
	elseif t == "EnumItem" then
		return { __t = "EnumItem", enum = tostring(v.EnumType), name = v.Name }
	elseif t == "Instance" then
		return { __t = "Instance", className = v.ClassName, path = v:GetFullName() }
	elseif t == "table" then
		local out = {}
		for k, val in pairs(v) do
			out[k] = serialize(val)
		end
		return out
	elseif t == "string" or t == "number" or t == "boolean" or t == "nil" then
		return v
	else
		-- any other datatype: stringify so JSONEncode never fails on the response
		return { __t = t, value = tostring(v) }
	end
end

-- Shared resolve + a console ring so read tools have parity with the edit
-- Executor during a live playtest.
local CollectionService = game:GetService("CollectionService")
local LogService = game:GetService("LogService")
local function resolve(path)
	if not path or path == "" or path == "game" then
		return game
	end
	local node = game
	for seg in string.gmatch(path, "[^%.]+") do
		if seg ~= "game" then
			node = node and node:FindFirstChild(seg)
		end
	end
	return node
end
local function pathInfo(inst)
	return { path = inst:GetFullName(), className = inst.ClassName, name = inst.Name }
end
local CURATED = {
	"Archivable", "Position", "Size", "CFrame", "Orientation", "Anchored", "CanCollide",
	"CanTouch", "CanQuery", "Transparency", "Reflectance", "Color", "Material", "CastShadow",
	"Enabled", "Visible", "Active", "Text", "Value", "Locked", "PrimaryPart", "Name", "ClassName",
}
-- Build serializer (parity with the edit Executor's export_build).
local function buildOf(inst, depth, maxDepth)
	local node = { className = inst.ClassName, name = inst.Name }
	local props = {}
	for _, name in ipairs(CURATED) do
		local ok, val = pcall(function()
			return inst[name]
		end)
		if ok and val ~= nil and typeof(val) ~= "Instance" then
			props[name] = serialize(val)
		end
	end
	if next(props) then
		node.properties = props
	end
	local attrs = {}
	for k, v in pairs(inst:GetAttributes()) do
		attrs[k] = serialize(v)
	end
	if next(attrs) then
		node.attributes = attrs
	end
	local tags = CollectionService:GetTags(inst)
	if #tags > 0 then
		node.tags = tags
	end
	if depth < maxDepth then
		local kids = {}
		for _, c in ipairs(inst:GetChildren()) do
			table.insert(kids, buildOf(c, depth + 1, maxDepth))
		end
		if #kids > 0 then
			node.children = kids
		end
	end
	return node
end

local consoleRing = {}
LogService.MessageOut:Connect(function(msg, mt)
	table.insert(consoleRing, { text = tostring(msg), level = mt.Name, t = os.time() })
	if #consoleRing > 500 then
		table.remove(consoleRing, 1)
	end
end)

local function runLuau(code)
	local buffer = {}
	local function capture(...)
		local n = select("#", ...)
		local parts = table.create(n)
		for i = 1, n do
			parts[i] = tostring((select(i, ...)))
		end
		table.insert(buffer, table.concat(parts, "\t"))
	end
	local chunk, compileErr = loadstring(code) -- requires LoadStringEnabled
	if not chunk then
		return { ok = false, output = "", err = "compile error: " .. tostring(compileErr) }
	end
	local env = setmetatable({ print = capture, warn = capture }, { __index = getfenv() })
	setfenv(chunk, env)
	local packed = table.pack(pcall(chunk))
	local output = table.concat(buffer, "\n")
	if not packed[1] then
		return { ok = false, output = output, err = tostring(packed[2]) }
	end
	local result = nil
	if packed.n > 1 then
		result = serialize(packed[2])
	end
	return { ok = true, output = output, result = result }
end

-- Keep played tracks referenced so they are not GC'd mid-play (play_animation).
local playingTracks = {}

-- Read-tool parity: these all work against the running server's DataModel so
-- playtest debugging mirrors the edit Executor. Edit-only tools (script editing,
-- selection, undo, asset insert) fall through to the unsupported message.
local function execute(cmd)
	local p = cmd.payload or {}
	if cmd.type == "run_luau" then
		return runLuau(p.code)
	elseif cmd.type == "get_instance_tree" then
		local root = resolve(p.path)
		if not root then
			return { ok = false, err = "path not found" }
		end
		local maxDepth = p.maxDepth or 4
		local function walk(inst, d)
			local node = { name = inst.Name, className = inst.ClassName, children = {} }
			if d < maxDepth then
				for _, c in ipairs(inst:GetChildren()) do
					table.insert(node.children, walk(c, d + 1))
				end
			end
			return node
		end
		return { ok = true, result = walk(root, 0) }
	elseif cmd.type == "read_console" then
		local count = p.count or 100
		local picked = {}
		for i = math.max(1, #consoleRing - count + 1), #consoleRing do
			table.insert(picked, consoleRing[i])
		end
		return { ok = true, result = { lines = picked, total = #consoleRing } }
	elseif cmd.type == "search_instances" then
		local root = resolve(p.root or "game") or game
		local query = p.query and string.lower(tostring(p.query)) or nil
		local out = {}
		local limit = p.limit or 100
		for _, inst in ipairs(root:GetDescendants()) do
			local ok = true
			if p.className then
				local okc, isa = pcall(function()
					return inst:IsA(p.className)
				end)
				if not okc or not isa then
					ok = false
				end
			end
			if ok and query and not string.find(string.lower(inst.Name), query, 1, true) then
				ok = false
			end
			if ok and p.tag and not CollectionService:HasTag(inst, p.tag) then
				ok = false
			end
			if ok then
				table.insert(out, pathInfo(inst))
				if #out >= limit then
					break
				end
			end
		end
		return { ok = true, result = out }
	elseif cmd.type == "list_scripts" then
		local root = resolve(p.root or "game") or game
		local out = {}
		for _, inst in ipairs(root:GetDescendants()) do
			if inst:IsA("LuaSourceContainer") then
				table.insert(out, pathInfo(inst))
			end
		end
		return { ok = true, result = out }
	elseif cmd.type == "get_place_info" then
		local counts = {}
		for _, child in ipairs(game:GetChildren()) do
			counts[child.Name] = #child:GetChildren()
		end
		return { ok = true, result = { placeId = game.PlaceId, gameId = game.GameId, topLevelCounts = counts, running = true } }
	elseif cmd.type == "get_tagged" then
		local out = {}
		for _, inst in ipairs(CollectionService:GetTagged(p.tag)) do
			table.insert(out, pathInfo(inst))
		end
		return { ok = true, result = out }
	elseif cmd.type == "get_tags" then
		local inst = resolve(p.path)
		if not inst then
			return { ok = false, err = "path not found" }
		end
		return { ok = true, result = { path = inst:GetFullName(), tags = CollectionService:GetTags(inst) } }
	elseif cmd.type == "get_properties" then
		local inst = resolve(p.path)
		if not inst then
			return { ok = false, err = "path not found" }
		end
		local names = p.propertyNames or CURATED
		local props = {}
		for _, name in ipairs(names) do
			local ok, val = pcall(function()
				return inst[name]
			end)
			if ok and val ~= nil then
				props[name] = serialize(val)
			end
		end
		return { ok = true, result = { path = inst:GetFullName(), className = inst.ClassName, properties = props } }
	elseif cmd.type == "get_attribute" then
		local inst = resolve(p.path)
		if not inst then
			return { ok = false, err = "path not found" }
		end
		return { ok = true, result = { path = inst:GetFullName(), name = p.name, value = serialize(inst:GetAttribute(p.name)) } }
	elseif cmd.type == "get_attributes" then
		local inst = resolve(p.path)
		if not inst then
			return { ok = false, err = "path not found" }
		end
		local out = {}
		for k, v in pairs(inst:GetAttributes()) do
			out[k] = serialize(v)
		end
		return { ok = true, result = { path = inst:GetFullName(), attributes = out } }
	elseif cmd.type == "get_descendants" then
		local root = resolve(p.path)
		if not root then
			return { ok = false, err = "path not found" }
		end
		local out = {}
		for _, d in ipairs(root:GetDescendants()) do
			table.insert(out, pathInfo(d))
			if #out >= 5000 then
				break
			end
		end
		return { ok = true, result = { descendants = out, truncated = #out >= 5000 } }
	elseif cmd.type == "get_services" then
		local out = {}
		for _, child in ipairs(game:GetChildren()) do
			table.insert(out, { name = child.Name, className = child.ClassName })
		end
		return { ok = true, result = out }
	elseif cmd.type == "search_by_property" then
		local root = resolve(p.root or "game") or game
		local out = {}
		local limit = p.limit or 100
		for _, inst in ipairs(root:GetDescendants()) do
			local ok, val = pcall(function()
				return inst[p.property]
			end)
			if ok and val == p.value then
				table.insert(out, pathInfo(inst))
				if #out >= limit then
					break
				end
			end
		end
		return { ok = true, result = out }
	elseif cmd.type == "character_navigation" then
		local Players = game:GetService("Players")
		local player = Players:GetPlayers()[1]
		if not player or not player.Character then
			return { ok = false, err = "no player character in the running game" }
		end
		local hum = player.Character:FindFirstChildOfClass("Humanoid")
		if not hum then
			return { ok = false, err = "player has no Humanoid" }
		end
		local pos = p.position
		local target = typeof(pos) == "Vector3" and pos
			or (type(pos) == "table" and pos.x and Vector3.new(pos.x, pos.y, pos.z))
		if not target then
			return { ok = false, err = "character_navigation needs a Vector3 'position'" }
		end
		hum:MoveTo(target)
		return { ok = true, output = "moving character toward target" }
	elseif cmd.type == "export_build" then
		local inst = resolve(p.path)
		if not inst then
			return { ok = false, err = "path not found" }
		end
		return { ok = true, result = buildOf(inst, 0, p.maxDepth or 8) }
	elseif cmd.type == "create_build" then
		local inst = resolve(p.path)
		if not inst then
			return { ok = false, err = "path not found" }
		end
		local b = buildOf(inst, 0, p.maxDepth or 8)
		return { ok = true, result = { kind = "build", name = p.name or b.name, build = b } }
	elseif cmd.type == "search_files" then
		local root = resolve(p.root or "game") or game
		local pat = p.pattern
		if not pat or pat == "" then
			return { ok = false, err = "search_files: 'pattern' is required" }
		end
		local useRegex = p.regex == true
		local needle = useRegex and pat or string.lower(pat)
		local limit = p.limit or 500
		local out = {}
		local function hit(s)
			if useRegex then
				return string.find(s, pat) ~= nil
			end
			return string.find(string.lower(s), needle, 1, true) ~= nil
		end
		for _, inst in ipairs(root:GetDescendants()) do
			if hit(inst.Name) or hit(inst:GetFullName()) then
				table.insert(out, pathInfo(inst))
				if #out >= limit then
					break
				end
			end
		end
		return { ok = true, result = { matches = out, truncated = #out >= limit } }
	elseif cmd.type == "raycast" then
		local function v3(a)
			if type(a) ~= "table" then
				return nil
			end
			local x = a[1] or a.x
			local y = a[2] or a.y
			local z = a[3] or a.z
			if x and y and z then
				return Vector3.new(x, y, z)
			end
			return nil
		end
		local origin, dir = v3(p.origin), v3(p.direction)
		if not origin or not dir or dir.Magnitude == 0 then
			return { ok = false, err = "raycast needs origin and a non-zero direction [x,y,z]" }
		end
		local params = RaycastParams.new()
		params.FilterType = Enum.RaycastFilterType.Exclude
		local ignore = {}
		if type(p.ignorePaths) == "table" then
			for _, ip in ipairs(p.ignorePaths) do
				local i = resolve(ip)
				if i then
					table.insert(ignore, i)
				end
			end
		end
		params.FilterDescendantsInstances = ignore
		local r = workspace:Raycast(origin, dir.Unit * (p.maxDistance or 1000), params)
		if not r then
			return { ok = true, result = { hit = false } }
		end
		return {
			ok = true,
			result = {
				hit = true,
				hitPath = r.Instance and r.Instance:GetFullName() or nil,
				position = serialize(r.Position),
				normal = serialize(r.Normal),
				material = r.Material.Name,
				distance = r.Distance,
			},
		}
	elseif cmd.type == "get_bounding_box" then
		local inst = resolve(p.path)
		if not inst then
			return { ok = false, err = "path not found" }
		end
		local cf, size
		if inst:IsA("Model") then
			local ok = pcall(function()
				cf, size = inst:GetBoundingBox()
			end)
			if not ok then
				return { ok = false, err = "GetBoundingBox failed" }
			end
		elseif inst:IsA("BasePart") then
			cf, size = inst.CFrame, inst.Size
		else
			return { ok = false, err = "not a Model or BasePart" }
		end
		return { ok = true, result = { path = inst:GetFullName(), cframe = serialize(cf), size = serialize(size) } }
	elseif cmd.type == "measure_distance" then
		local ia, ib = resolve(p.pathA), resolve(p.pathB)
		if not ia or not ib then
			return { ok = false, err = "one or both paths not found" }
		end
		local function pp(inst)
			if inst:IsA("PVInstance") then
				local ok, piv = pcall(function()
					return inst:GetPivot()
				end)
				if ok then
					return piv.Position
				end
			end
			return nil
		end
		local pa, pb = pp(ia), pp(ib)
		if not pa or not pb then
			return { ok = false, err = "both instances must be PVInstances" }
		end
		return { ok = true, result = { distance = (pa - pb).Magnitude, a = ia:GetFullName(), b = ib:GetFullName() } }
	elseif cmd.type == "get_perf_stats" then
		local Stats = game:GetService("Stats")
		local mem = nil
		pcall(function()
			mem = Stats:GetTotalMemoryUsageMb()
		end)
		local instanceCount, partCount, scriptCount = 0, 0, 0
		for _, d in ipairs(game:GetDescendants()) do
			instanceCount += 1
			if d:IsA("BasePart") then
				partCount += 1
			elseif d:IsA("LuaSourceContainer") then
				scriptCount += 1
			end
		end
		return {
			ok = true,
			result = { totalMemoryMb = mem, instanceCount = instanceCount, partCount = partCount, scriptCount = scriptCount },
		}
	elseif cmd.type == "playtest_control" then
		-- Only stop is handled here: EndTest is legal ONLY from the run DataModel,
		-- which is exactly this agent's context. Start stays an edit-plugin op.
		if tostring(p.action) == "stop" then
			local StudioTestService = game:GetService("StudioTestService")
			local ok, err = pcall(function()
				StudioTestService:EndTest("stopped_by_mcp")
			end)
			if ok then
				return { ok = true, output = "ended playtest via StudioTestService:EndTest (run DataModel)" }
			end
			return { ok = false, err = "EndTest failed: " .. tostring(err) }
		end
		return { ok = false, err = "playtest_control start is an edit-only operation" }
	elseif cmd.type == "play_animation" then
		-- First server-context write tool: play a track on a live rig's Animator.
		local Players = game:GetService("Players")
		local targetInst
		if p.target == "player" or p.target == nil then
			local player = Players:GetPlayers()[1]
			targetInst = player and player.Character
			if not targetInst then
				return { ok = false, err = "play_animation: no player character yet" }
			end
		else
			targetInst = resolve(p.target)
			if not targetInst then
				return { ok = false, err = "play_animation: target not found: " .. tostring(p.target) }
			end
		end
		local controller = targetInst:FindFirstChildOfClass("Humanoid")
			or targetInst:FindFirstChildOfClass("AnimationController")
		if not controller then
			return { ok = false, err = "play_animation: " .. tostring(p.target) .. " has no Humanoid/AnimationController" }
		end
		local animator = controller:FindFirstChildOfClass("Animator")
		if not animator then
			animator = Instance.new("Animator")
			animator.Parent = controller
		end
		local idStr
		local rawId = p.animationId
		if type(rawId) == "number" then
			idStr = "rbxassetid://" .. tostring(math.floor(rawId))
		elseif type(rawId) == "string" and rawId ~= "" then
			if string.match(rawId, "^%d+$") then
				idStr = "rbxassetid://" .. rawId
			else
				idStr = rawId
			end
		else
			return { ok = false, err = "play_animation: invalid animationId" }
		end
		local anim = Instance.new("Animation")
		anim.AnimationId = idStr
		local okLoad, trackOrErr = pcall(function()
			return animator:LoadAnimation(anim)
		end)
		if not okLoad then
			return { ok = false, err = "play_animation: LoadAnimation failed: " .. tostring(trackOrErr) }
		end
		local track = trackOrErr
		if p.priority then
			pcall(function()
				track.Priority = Enum.AnimationPriority[p.priority]
			end)
		end
		if type(p.looped) == "boolean" then
			track.Looped = p.looped
		end
		local fadeTime = type(p.fadeTime) == "number" and p.fadeTime or 0.1
		local weight = type(p.weight) == "number" and p.weight or 1
		local speed = type(p.speed) == "number" and p.speed or 1
		local okPlay, playErr = pcall(function()
			track:Play(fadeTime, weight, speed)
		end)
		if not okPlay then
			return { ok = false, err = "play_animation: Play failed: " .. tostring(playErr) }
		end
		table.insert(playingTracks, track)
		return { ok = true, result = { length = track.Length, isPlaying = true, targetPath = targetInst:GetFullName() } }
	else
		return { ok = false, err = "agent does not support command: " .. tostring(cmd.type) }
	end
end

-- Heartbeat-driven poll scheduler. Hardened against the silent-stop deadlock:
-- the ENTIRE poll body runs inside a pcall and isPolling is reset UNCONDITIONALLY
-- after it, so a throw in a command handler or an HTTP read can never leave the
-- scheduler wedged (which silently killed the agent before). The connection lives
-- as long as the run DataModel; reprobe + backoff handle a not-yet-ready bridge.
local lastReported = nil
local backoff = BACKOFF_START
local lastPoll = 0
local isPolling = false
local pollCount = 0
local pollConn = nil

-- Preallocated header tables: no per-poll / per-frame allocation.
local pollHeaders = authHeaders() or {}
local responseHeaders = authHeaders() or {}
responseHeaders["Content-Type"] = "application/json"

-- Self-diagnostics: POST a tiny event to the bridge (/diag) so the agent's last
-- state + drop reason are readable via get_status WITHOUT Studio Output. Never
-- throws, never blocks (pcall); skipped until a bridge is resolved.
local function sendDiag(event, extra)
	if not base then
		return
	end
	pcall(function()
		local payload = { event = event, t = os.time(), context = CONTEXT, pollCount = pollCount }
		if extra then
			for k, v in pairs(extra) do
				payload[k] = v
			end
		end
		HttpService:RequestAsync({
			Url = base .. "/diag",
			Method = "POST",
			Headers = responseHeaders,
			Body = HttpService:JSONEncode(payload),
		})
	end)
end

local function reprobe()
	for _, port in ipairs(CANDIDATES) do
		if tryHeartbeat(port) then
			base = urlFor(port)
			return true
		end
	end
	return false
end

local function handleBody(body)
	if not body or body == "" then
		return
	end
	local decoded = HttpService:JSONDecode(body) -- throws on bad JSON -> caught by doPoll's pcall
	local cmd = decoded and decoded.command or nil
	if cmd and cmd.id then
		-- A bad command handler must NOT kill the loop.
		local okExec, result = pcall(execute, cmd)
		if not okExec then
			sendDiag("handler_error", { cmdType = tostring(cmd.type), err = tostring(result) })
			result = { ok = false, err = "handler error: " .. tostring(result) }
		end
		if result and result.ok == false then
			warn(("[MCP agent] command %q failed: %s"):format(tostring(cmd.type), tostring(result.err)))
		end
		result.id = cmd.id
		pcall(function()
			HttpService:RequestAsync({
				Url = base .. "/response",
				Method = "POST",
				Headers = responseHeaders,
				Body = HttpService:JSONEncode(result),
			})
		end)
	end
end

-- One poll iteration. ENTIRE body in pcall; isPolling reset UNCONDITIONALLY after,
-- so no error path (HTTP read, JSON decode, handler) can ever wedge the scheduler.
local function doPoll()
	local ok, err = pcall(function()
		if not base then
			if not reprobe() then
				if lastReported ~= "noBridge" then
					warn("[MCP agent] no reachable bridge; ensure 'Allow HTTP Requests' is on and the server is running")
					lastReported = "noBridge"
				end
				backoff = math.min(backoff * 2, BACKOFF_MAX)
				return
			end
			lastReported = "up"
			backoff = BACKOFF_START
			sendDiag("connect", { base = base })
		end
		local res = HttpService:RequestAsync({
			Url = base .. "/poll?context=" .. CONTEXT,
			Method = "GET",
			Headers = pollHeaders,
		})
		if not (res.Success or res.StatusCode == 503) then
			error("poll HTTP status " .. tostring(res.StatusCode))
		end
		if lastReported == "dropped" then
			print("[MCP agent] reconnected to " .. base)
			sendDiag("reconnect", { base = base })
		end
		lastReported = "up"
		backoff = BACKOFF_START
		pollCount += 1
		if pollCount == 1 or pollCount % 10 == 0 then
			sendDiag("poll", { count = pollCount })
		end
		handleBody(res.Body)
	end)
	if not ok then
		if lastReported ~= "dropped" then
			warn("[MCP agent] poll error on " .. tostring(base) .. ": " .. tostring(err))
			lastReported = "dropped"
		end
		sendDiag("poll_error", { err = tostring(err) }) -- base still set here, so this reaches the bridge
		base = nil
		backoff = math.min(backoff * 2, BACKOFF_MAX)
	end
	isPolling = false -- UNCONDITIONAL: an error must never leave the scheduler stuck
end

-- Per-frame handler allocates nothing: it compares timers and defers the yielding
-- poll to a spawned task. isPolling prevents overlap; backoff paces reconnects.
pollConn = RunService.Heartbeat:Connect(function()
	if isPolling then
		return
	end
	local interval = if base then POLL_INTERVAL else backoff
	if tick() - lastPoll < interval then
		return
	end
	lastPoll = tick()
	isPolling = true
	task.spawn(doPoll)
end)

-- Janitor: report shutdown and drop the connection when the run DataModel tears down.
game:BindToClose(function()
	sendDiag("shutdown", { pollCount = pollCount })
	if pollConn then
		pollConn:Disconnect()
		pollConn = nil
	end
end)

if base then
	print("[MCP agent] connected to " .. base)
else
	print("[MCP agent] scheduler armed; probing for bridge...")
end
]==]

return SOURCE
]]></ProtectedString>
   </Properties>
  </Item>
